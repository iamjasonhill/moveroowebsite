---
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
	canonical?: string;
	robots?: string;
	ogType?: string;
	ogImage?: string;
}

const {
	title = "Moveroo",
	description,
	canonical,
	robots = "index, follow",
	ogType = "website",
	ogImage = "https://moveroo.com.au/og-image.png",
} = Astro.props as Props;

const navItems = [
	{ label: "Home", href: "/", external: false, variant: "link" },
	{
		label: "Moving Quote",
		href: "https://removalists.moveroo.com.au",
		external: true,
		variant: "link",
	},
	{
		label: "Vehicle Transport Quote",
		href: "https://cars.moveroo.com.au",
		external: true,
		variant: "link",
	},
	{
		label: "Moving Cars",
		href: "/moving-cars/",
		external: false,
		variant: "link",
	},
	{
		label: "Contact Us",
		href: "/contact/",
		external: false,
		variant: "link",
	},
	{
		label: "Book Your Move",
		href: "https://removalists.moveroo.com.au/booking/create",
		external: true,
		variant: "button",
	},
];
---

<!doctype html>
<html lang="en" class="h-full bg-slate-50 text-slate-900">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="manifest" href="/manifest.json" />
		<meta name="generator" content={Astro.generator} />
		{robots && <meta name="robots" content={robots} />}
		<title>{title}</title>
		{description && <meta name="description" content={description} />}
		{canonical && <link rel="canonical" href={canonical} />}
		<meta property="og:title" content={title} />
		{
			description && (
				<meta property="og:description" content={description} />
			)
		}
		{canonical && <meta property="og:url" content={canonical} />}
		<meta property="og:type" content={ogType} />
		<meta property="og:site_name" content="Moveroo Australia" />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={title} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		{
			description && (
				<meta name="twitter:description" content={description} />
			)
		}
		<meta name="twitter:image" content={ogImage} />
		<meta name="twitter:image:alt" content={title} />
		<script
			type="text/partytown"
			async
			src="https://www.googletagmanager.com/gtag/js?id=G-4DN533CFGK"
		></script>
		<script type="text/partytown">
			window.dataLayer = window.dataLayer || [];
			function gtag() {
				dataLayer.push(arguments);
			}
			gtag("js", new Date());
			gtag("config", "G-4DN533CFGK");
		</script>
		<script
			type="text/partytown"
			defer
			src="https://againanalytics.vercel.app/script.js"
			data-website-id="3004f4eb-2b2c-4d61-a2fc-2cd23e627f64"></script>
		<slot name="head" />
	</head>
	<body class="flex min-h-screen flex-col bg-white">
		<a
			href="#main-content"
			class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:bg-white focus:p-4 focus:text-emerald-700"
			>Skip to content</a
		>
		<header class="border-b border-slate-200 bg-white/90 backdrop-blur">
			<div
				class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-5"
			>
				<a
					href="/"
					class="text-lg font-semibold tracking-tight text-slate-900"
					>Moveroo</a
				>
				<button
					class="inline-flex items-center justify-center rounded-full border border-slate-200 p-2 text-slate-700 transition hover:border-emerald-300 hover:text-emerald-700 md:hidden"
					type="button"
					aria-controls="mobile-nav"
					aria-expanded="false"
					data-mobile-nav-toggle
				>
					<span class="sr-only">Toggle navigation</span>
					<svg
						class="h-5 w-5"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="1.5"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M4 6h16M4 12h16M4 18h16"></path>
					</svg>
				</button>
				<nav
					class="hidden items-center gap-6 text-sm font-semibold text-slate-700 md:flex"
				>
					{
						navItems.map((item) => (
							<a
								class={
									item.variant === "button"
										? "rounded-full border border-emerald-200 px-4 py-2 text-emerald-700 transition hover:border-emerald-300 hover:bg-emerald-50 hover:text-emerald-900"
										: "transition hover:text-emerald-600"
								}
								href={item.href}
								target={item.external ? "_blank" : undefined}
								rel={item.external ? "noopener" : undefined}
								aria-label={
									item.external
										? `${item.label} (opens in a new tab)`
										: undefined
								}
							>
								{item.label}
							</a>
						))
					}
				</nav>
			</div>
			<div class="md:hidden" data-mobile-nav-panel hidden id="mobile-nav">
				<div
					class="border-t border-slate-200 bg-white px-6 py-4 shadow-lg shadow-emerald-100/60"
				>
					<nav
						class="flex flex-col gap-4 text-sm font-semibold text-slate-700"
					>
						{
							navItems.map((item) => (
								<a
									class={
										item.variant === "button"
											? "inline-flex items-center justify-center rounded-full border border-emerald-200 px-4 py-2 text-emerald-700 transition hover:border-emerald-300 hover:bg-emerald-50 hover:text-emerald-900"
											: "transition hover:text-emerald-600"
									}
									href={item.href}
									target={
										item.external ? "_blank" : undefined
									}
									rel={item.external ? "noopener" : undefined}
									aria-label={
										item.external
											? `${item.label} (opens in a new tab)`
											: undefined
									}
								>
									{item.label}
								</a>
							))
						}
					</nav>
				</div>
			</div>
		</header>
		<main id="main-content" class="flex-1 bg-white">
			<slot />
		</main>
		<footer class="border-t border-slate-200 bg-slate-50">
			<div
				class="mx-auto flex max-w-6xl flex-col gap-6 px-6 py-10 text-sm text-slate-600 md:flex-row md:items-start md:justify-between"
			>
				<div>
					<p class="text-base font-semibold text-slate-900">
						Moveroo
					</p>
					<p class="mt-2 max-w-sm text-sm text-slate-600">
						Reimagining the relocation experience with transparent
						pricing, dependable partners and friendly support.
					</p>
				</div>
				<nav
					class="flex flex-col gap-2 text-sm font-medium text-slate-700"
				>
					<a
						class="transition hover:text-slate-900"
						href="/privacy-policy/">Privacy Policy</a
					>
					<a
						class="transition hover:text-slate-900"
						href="/terms-of-use/">Terms of Use</a
					>
					<a
						class="transition hover:text-slate-900"
						href="/terms-and-conditions-transport/"
						>Transport Terms &amp; Conditions</a
					>
					<a
						class="transition hover:text-slate-900"
						href="/sitemap-index.xml">Sitemap</a
					>
				</nav>
			</div>
			<div class="border-t border-slate-200 bg-slate-50">
				<div
					class="mx-auto max-w-6xl px-6 py-6 text-xs uppercase tracking-[0.3em] text-slate-600"
				>
					© {new Date().getFullYear()} Moveroo. All rights reserved.
				</div>
			</div>
		</footer>
		<script is:inline>
			const toggle = document.querySelector("[data-mobile-nav-toggle]");
			const panel = document.querySelector("[data-mobile-nav-panel]");
			if (toggle && panel) {
				toggle.addEventListener("click", () => {
					const expanded =
						toggle.getAttribute("aria-expanded") === "true";
					toggle.setAttribute("aria-expanded", String(!expanded));
					panel.hidden = expanded;
				});
				panel.querySelectorAll("a").forEach((link) => {
					link.addEventListener("click", () => {
						toggle.setAttribute("aria-expanded", "false");
						panel.hidden = true;
					});
				});
			}
		</script>
	</body>
</html>
