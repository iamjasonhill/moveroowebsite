---
import "../styles/global.css";
import Analytics from "../components/analytics/Analytics.astro";
import DarkModeToggle from "../components/DarkModeToggle.astro";
import { site } from "../config/site";

interface BreadcrumbItem {
	name: string;
	url: string;
}

interface Props {
	title?: string;
	description?: string;
	canonical?: string;
	robots?: string;
	ogType?: string;
	ogImage?: string;
	breadcrumbs?: BreadcrumbItem[];
	includeBaseSchema?: boolean;
}

const {
	title = "Moveroo",
	description,
	canonical,
	robots = "index, follow",
	ogType = "website",
	ogImage = "https://moveroo.com.au/og-image.png",
	breadcrumbs,
	includeBaseSchema = true,
} = Astro.props as Props;

// Generate breadcrumbs from URL if not provided
const currentPath = Astro.url.pathname;
const generateBreadcrumbs = (): BreadcrumbItem[] => {
	if (breadcrumbs) return breadcrumbs;

	const items: BreadcrumbItem[] = [{ name: "Home", url: "https://moveroo.com.au/" }];

	if (currentPath !== "/" && currentPath !== "") {
		const segments = currentPath.split("/").filter(Boolean);
		let accumulatedPath = "";

		segments.forEach((segment) => {
			accumulatedPath += `/${segment}`;
			const name = segment
				.split("-")
				.map((word) => word.charAt(0).toUpperCase() + word.slice(1))
				.join(" ");
			items.push({
				name,
				url: `https://moveroo.com.au${accumulatedPath}/`,
			});
		});
	}

	return items;
};

// Base schema for Organization and WebSite (shared across all pages)
const baseSchema = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "Organization",
			"@id": "https://moveroo.com.au/#organization",
			name: "Moveroo Australia",
			url: "https://moveroo.com.au/",
			logo: {
				"@type": "ImageObject",
				"@id": "https://moveroo.com.au/#logo",
				url: "https://moveroo.com.au/og-image.png",
				contentUrl: "https://moveroo.com.au/og-image.png",
				caption: "Moveroo Australia",
			},
			contactPoint: [
				{
					"@type": "ContactPoint",
					telephone: "+61 7 2143 2557",
					contactType: "customer support",
					areaServed: "AU",
					availableLanguage: "English",
				},
			],
			sameAs: ["https://twitter.com/MoverooAU"],
		},
		{
			"@type": "WebSite",
			"@id": "https://moveroo.com.au/#website",
			url: "https://moveroo.com.au/",
			name: "Moveroo Australia",
			description: "Trusted moving and vehicle transport services across Australia",
			publisher: {
				"@id": "https://moveroo.com.au/#organization",
			},
			inLanguage: "en-AU",
		},
		{
			"@type": "BreadcrumbList",
			"@id": `https://moveroo.com.au${currentPath}#breadcrumb`,
			itemListElement: generateBreadcrumbs().map((item, index) => ({
				"@type": "ListItem",
				position: index + 1,
				name: item.name,
				item: item.url,
			})),
		},
	],
};

const navItems = [
	{ label: "Home", href: "/", external: false, variant: "link" },
	{ label: "Services", href: "/services/", external: false, variant: "link" },
	{
		label: "Start your quote",
		href: site.destinations.householdQuote,
		external: true,
		variant: "link",
	},
	{
		label: "Vehicle Transport Quote",
		href: site.destinations.vehicleQuote,
		external: true,
		variant: "link",
	},
	{
		label: "Moving Cars",
		href: "/moving-cars/",
		external: false,
		variant: "link",
	},
	{
		label: "Request a callback",
		href: site.destinations.contactPage,
		external: false,
		variant: "link",
	},
	{
		label: "Book Your Move",
		href: site.destinations.bookingPage,
		external: true,
		variant: "button",
	},
];

const footerServiceLinks = [
	{
		label: "Household Removals",
		href: "/household-removals/",
		external: false,
	},
	{
		label: "Backloading Removals",
		href: "/backloading-removals/",
		external: false,
	},
	{
		label: "Combined Household + Vehicle Relocation",
		href: "/household-vehicle-relocation/",
		external: false,
	},
	{
		label: "Vehicle Transport Quote",
		href: site.destinations.vehicleQuote,
		external: true,
	},
	{ label: "Moving Cars", href: "/moving-cars/", external: false },
	{
		label: "How Moveroo Protects Your Move",
		href: "/how-moveroo-protects-your-move/",
		external: false,
	},
	{ label: "Contact Team", href: site.destinations.contactPage, external: false },
];

const footerLegalLinks = [
	{ label: "Privacy Policy", href: "/privacy-policy/" },
	{ label: "Terms of Use", href: "/terms-of-use/" },
	{ label: "Transport Terms", href: "/terms-and-conditions-transport/" },
	{ label: "Cancellation Policy", href: "/cancellation/" },
	{ label: "HTML Sitemap", href: "/sitemap/" },
	{ label: "XML Sitemap", href: "/sitemap-index.xml" },
];

const footerSignals = ["Household relocations", "Vehicle transport", "Nationwide coordination"];
---

<!doctype html>
<html lang="en" class="h-full bg-slate-50 text-slate-900 dark:bg-slate-900 dark:text-white">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<script is:inline>
			(function () {
				const getTheme = () => {
					if (typeof localStorage !== "undefined" && localStorage.getItem("theme")) {
						return localStorage.getItem("theme");
					}
					return "dark";
				};
				const theme = getTheme();
				if (theme === "dark") {
					document.documentElement.classList.add("dark");
				} else {
					document.documentElement.classList.remove("dark");
				}
			})();
		</script>
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/manifest.json" />
		<!-- Resource Hints for Performance -->
		<link rel="preconnect" href="https://www.googletagmanager.com" />
		<link rel="dns-prefetch" href="https://www.google-analytics.com" />
		<link rel="dns-prefetch" href="https://analytics.google.com" />
		<meta name="generator" content={Astro.generator} />
		{robots && <meta name="robots" content={robots} />}
		<title>{title}</title>
		{description && <meta name="description" content={description} />}
		{canonical && <link rel="canonical" href={canonical} />}
		<link rel="alternate" type="application/rss+xml" title="Moveroo RSS feed" href="/rss.xml" />
		<link rel="sitemap" href="/sitemap-index.xml" />
		<link rel="llms" href="/llms.txt" />
		<!-- Hreflang tags for single-language site -->
		<link rel="alternate" hreflang="en-AU" href={canonical || "https://moveroo.com.au/"} />
		<link rel="alternate" hreflang="x-default" href={canonical || "https://moveroo.com.au/"} />
		<meta property="og:title" content={title} />
		{description && <meta property="og:description" content={description} />}
		{canonical && <meta property="og:url" content={canonical} />}
		<meta property="og:type" content={ogType} />
		<meta property="og:site_name" content="Moveroo Australia" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content="@MoverooAU" />
		<meta name="twitter:title" content={title} />
		{description && <meta name="twitter:description" content={description} />}
		<meta name="twitter:image" content={ogImage} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:type" content="image/png" />
		<!-- PWA / Mobile Web App Meta Tags -->
		<meta name="mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="default" />
		<meta name="apple-mobile-web-app-title" content="Moveroo" />
		<meta name="theme-color" content="#10b981" />
		<Analytics />
		{
			includeBaseSchema && (
				<script type="application/ld+json" set:html={JSON.stringify(baseSchema)} />
			)
		}
		<slot name="head" />
	</head>
	<body class="site-shell flex min-h-screen flex-col pb-24 transition-colors md:pb-0">
		<a href="#main-content" class="site-skip-link">Skip to content</a>
		<header class="site-header sticky top-0 z-40 border-b backdrop-blur">
			<div class="mx-auto max-w-6xl px-6">
				<div class="flex items-center justify-between gap-6 py-4">
					<a href="/" class="group flex min-w-0 items-center gap-4">
						<span
							class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-2xl border border-emerald-200/80 bg-emerald-600 text-white shadow-[0_14px_36px_-18px_rgba(5,150,105,0.7)] transition group-hover:bg-emerald-700 dark:border-emerald-400/20 dark:bg-emerald-500 dark:text-slate-950 dark:group-hover:bg-emerald-400"
							aria-hidden="true"
						>
							<span class="text-lg font-semibold tracking-[-0.08em]">M</span>
						</span>
						<span class="flex min-w-0 flex-col">
							<span class="site-wordmark-kicker">Australia move network</span>
							<span class="site-wordmark text-xl font-semibold text-slate-900 dark:text-white">
								Moveroo
							</span>
						</span>
					</a>

					<nav
						class="hidden items-center gap-6 text-sm font-semibold text-slate-700 dark:text-slate-300 xl:flex"
					>
						{
							navItems.map((item) => (
								<a
									class={item.variant === "button" ? "site-nav-button" : "site-nav-link"}
									href={item.href}
									target={item.external ? "_blank" : undefined}
									rel={item.external ? "noopener" : undefined}
									aria-label={item.external ? `${item.label} (opens in a new tab)` : undefined}
								>
									{item.label}
								</a>
							))
						}
					</nav>

					<div class="flex items-center gap-3">
						<a
							href="tel:+61721432557"
							class="site-contact-chip hidden lg:inline-flex"
							aria-label="Call Moveroo on +61 7 2143 2557"
						>
							<span class="h-2 w-2 rounded-full bg-emerald-500"></span>
							<span>07 2143 2557</span>
						</a>
						<div class="hidden md:block">
							<DarkModeToggle />
						</div>
						<button
							class="site-mobile-toggle inline-flex items-center justify-center rounded-full border p-0 text-slate-700 transition dark:text-slate-300 xl:hidden"
							type="button"
							aria-controls="mobile-nav"
							aria-expanded="false"
							data-mobile-nav-toggle
						>
							<span class="sr-only">Toggle navigation</span>
							<svg
								class="h-5 w-5"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="1.5"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path d="M4 6h16M4 12h16M4 18h16"></path>
							</svg>
						</button>
					</div>
				</div>
			</div>
			<div class="xl:hidden" data-mobile-nav-panel hidden id="mobile-nav">
				<div class="site-mobile-panel border-t px-6 py-5 shadow-lg">
					<div class="flex flex-col gap-5">
						<div class="flex items-start justify-between gap-4">
							<div class="max-w-xs">
								<p class="site-wordmark-kicker">Plan with Moveroo</p>
								<p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
									Household moves, vehicle transport and interstate coordination from one team.
								</p>
							</div>
							<DarkModeToggle />
						</div>
						<nav
							class="flex flex-col gap-3 text-sm font-semibold text-slate-700 dark:text-slate-300"
						>
							{
								navItems.map((item) => (
									<a
										class={
											item.variant === "button"
												? "site-nav-button justify-center"
												: "site-mobile-link"
										}
										href={item.href}
										target={item.external ? "_blank" : undefined}
										rel={item.external ? "noopener" : undefined}
										aria-label={item.external ? `${item.label} (opens in a new tab)` : undefined}
									>
										{item.label}
									</a>
								))
							}
						</nav>
						<a
							href="tel:+61721432557"
							class="site-contact-chip w-full justify-center"
							aria-label="Call Moveroo on +61 7 2143 2557"
						>
							<span class="h-2 w-2 rounded-full bg-emerald-500"></span>
							<span>Call 07 2143 2557</span>
						</a>
					</div>
				</div>
			</div>
		</header>
		<main id="main-content" class="flex-1 bg-white dark:bg-slate-900 transition-colors">
			<slot />
		</main>
		<footer class="site-footer border-t">
			<div class="mx-auto max-w-6xl px-6 py-14 md:py-16">
				<div class="grid gap-12 xl:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] xl:gap-16">
					<div class="max-w-xl">
						<p class="site-wordmark-kicker">Moveroo Australia</p>
						<h2
							class="mt-5 text-4xl font-semibold tracking-[-0.05em] text-slate-900 dark:text-white"
						>
							One nationwide desk for moves, vehicles and freight.
						</h2>
						<p class="mt-5 text-base leading-relaxed text-slate-600 dark:text-slate-400">
							We connect households, businesses and vehicle owners with vetted transport partners
							across Australia, then help keep the plan clear from quote through delivery.
						</p>
						<div
							class="mt-8 flex flex-wrap gap-3 text-sm font-semibold text-slate-700 dark:text-slate-300"
						>
							{footerSignals.map((item) => <span class="site-footer-signal">{item}</span>)}
						</div>
						<div class="mt-8 flex flex-wrap gap-4">
							<a
								href={site.destinations.householdQuote}
								target="_blank"
								rel="noopener"
								class="site-nav-button"
							>
								Get a moving quote
							</a>
							<a
								href={site.destinations.bookingPage}
								target="_blank"
								rel="noopener"
								class="inline-flex items-center justify-center rounded-full border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-slate-400 hover:text-slate-950 dark:border-slate-700 dark:text-slate-300 dark:hover:border-slate-500 dark:hover:text-white"
							>
								Book your move
							</a>
						</div>
					</div>

					<div class="grid gap-x-10 gap-y-8 md:grid-cols-2">
						<div class="md:col-span-2">
							<p class="site-footer-heading">Services</p>
							<nav class="mt-4 flex flex-col gap-3">
								{
									footerServiceLinks.map((item) => (
										<a
											class="site-footer-link"
											href={item.href}
											target={item.external ? "_blank" : undefined}
											rel={item.external ? "noopener" : undefined}
										>
											{item.label}
										</a>
									))
								}
							</nav>
						</div>

						<div>
							<p class="site-footer-heading">Contact</p>
							<div class="mt-4 flex flex-col gap-4 text-sm text-slate-600 dark:text-slate-400">
								<div>
									<p class="font-semibold text-slate-900 dark:text-white">Phone</p>
									<a class="site-footer-link mt-1 inline-flex" href="tel:+61721432557">
										+61 7 2143 2557
									</a>
								</div>
								<div>
									<p class="font-semibold text-slate-900 dark:text-white">Email</p>
									<a
										class="site-footer-link mt-1 inline-flex"
										href="mailto:removals@moveroo.com.au"
									>
										removals@moveroo.com.au
									</a>
								</div>
								<div>
									<p class="font-semibold text-slate-900 dark:text-white">Response window</p>
									<p class="mt-1">Typically within one business day.</p>
								</div>
							</div>
						</div>

						<div>
							<p class="site-footer-heading">Legal</p>
							<nav class="mt-4 flex flex-col gap-3">
								{
									footerLegalLinks.map((item) => (
										<a class="site-footer-link" href={item.href}>
											{item.label}
										</a>
									))
								}
							</nav>
						</div>
					</div>
				</div>
			</div>
			<div class="site-footer-meta border-t">
				<div class="mx-auto max-w-6xl px-6 py-6">
					<div class="flex flex-col items-center justify-between gap-4 md:flex-row">
						<div class="text-xs uppercase tracking-[0.3em] text-slate-500 dark:text-slate-400">
							© {new Date().getFullYear()} Moveroo. All rights reserved.
						</div>
						<div
							class="flex flex-wrap items-center justify-center gap-3 text-xs text-slate-400 dark:text-slate-300"
						>
							<span class="site-footer-meta-pill">
								<span class="h-2 w-2 rounded-full bg-emerald-500"></span>
								<span>Secure SSL</span>
							</span>
							<span class="site-footer-meta-pill">Partner coordination</span>
							<span class="site-footer-meta-pill">Australian owned</span>
						</div>
					</div>
				</div>
			</div>
		</footer>
		<nav
			class="fixed inset-x-0 bottom-0 z-50 border-t border-slate-200 bg-white/95 px-3 py-3 shadow-[0_-16px_40px_-28px_rgba(15,23,42,0.55)] backdrop-blur md:hidden dark:border-slate-800 dark:bg-slate-950/95"
			aria-label="Quick actions"
		>
			<div class="mx-auto grid max-w-md grid-cols-3 gap-2">
				<a
					href="tel:+61721432557"
					class="inline-flex min-h-12 items-center justify-center rounded-2xl border border-slate-200 px-3 text-center text-xs font-semibold text-slate-700 transition hover:border-emerald-300 hover:text-emerald-700 dark:border-slate-800 dark:text-slate-300 dark:hover:border-emerald-500/50 dark:hover:text-emerald-300"
					aria-label="Call Moveroo on 07 2143 2557"
				>
					Call
				</a>
				<a
					href={site.destinations.householdQuote}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex min-h-12 items-center justify-center rounded-2xl bg-emerald-600 px-3 text-center text-xs font-semibold text-slate-950 shadow-lg shadow-emerald-950/20 transition hover:bg-emerald-500"
					aria-label="Start your Moveroo quote"
				>
					Quote
				</a>
				<a
					href={site.destinations.contactPage}
					class="inline-flex min-h-12 items-center justify-center rounded-2xl border border-slate-200 px-3 text-center text-xs font-semibold text-slate-700 transition hover:border-emerald-300 hover:text-emerald-700 dark:border-slate-800 dark:text-slate-300 dark:hover:border-emerald-500/50 dark:hover:text-emerald-300"
					aria-label="Request a callback from Moveroo"
				>
					Callback
				</a>
			</div>
		</nav>
		<script is:inline>
			(function () {
				const toggle = document.querySelector("[data-mobile-nav-toggle]");
				const panel = document.querySelector("[data-mobile-nav-panel]");

				if (toggle && panel) {
					toggle.addEventListener("click", () => {
						const expanded = toggle.getAttribute("aria-expanded") === "true";
						toggle.setAttribute("aria-expanded", String(!expanded));
						panel.hidden = expanded;
					});

					panel.querySelectorAll("a").forEach((link) => {
						link.addEventListener("click", () => {
							toggle.setAttribute("aria-expanded", "false");
							panel.hidden = true;
						});
					});
				}

				function initDarkMode() {
					const toggles = document.querySelectorAll("[data-dark-mode-toggle]");
					const html = document.documentElement;

					if (toggles.length === 0) {
						return;
					}

					const updateIcons = () => {
						const isDark = html.classList.contains("dark");
						const sunIcons = document.querySelectorAll("[data-sun-icon]");
						const moonIcons = document.querySelectorAll("[data-moon-icon]");

						sunIcons.forEach((icon) => {
							if (isDark) {
								icon.classList.remove("hidden");
							} else {
								icon.classList.add("hidden");
							}
						});
						moonIcons.forEach((icon) => {
							if (isDark) {
								icon.classList.add("hidden");
							} else {
								icon.classList.remove("hidden");
							}
						});
					};

					const setTheme = (theme) => {
						if (theme === "dark") {
							html.classList.add("dark");
						} else {
							html.classList.remove("dark");
						}
						if (typeof localStorage !== "undefined") {
							localStorage.setItem("theme", theme);
						}
						updateIcons();
					};

					updateIcons();

					toggles.forEach((toggle) => {
						toggle.addEventListener("click", (e) => {
							e.preventDefault();
							e.stopPropagation();
							const currentTheme = html.classList.contains("dark") ? "dark" : "light";
							const newTheme = currentTheme === "dark" ? "light" : "dark";
							setTheme(newTheme);
						});
					});
				}

				if (document.readyState === "loading") {
					document.addEventListener("DOMContentLoaded", initDarkMode, { once: true });
				} else {
					initDarkMode();
				}
			})();
		</script>
	</body>
</html>
