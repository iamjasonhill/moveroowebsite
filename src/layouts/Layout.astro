---
import "../styles/global.css";
import DarkModeToggle from "../components/DarkModeToggle.astro";

interface BreadcrumbItem {
	name: string;
	url: string;
}

interface Props {
	title?: string;
	description?: string;
	canonical?: string;
	robots?: string;
	ogType?: string;
	ogImage?: string;
	breadcrumbs?: BreadcrumbItem[];
	includeBaseSchema?: boolean;
}

const {
	title = "Moveroo",
	description,
	canonical,
	robots = "index, follow",
	ogType = "website",
	ogImage = "https://moveroo.com.au/og-image.png",
	breadcrumbs,
	includeBaseSchema = true,
} = Astro.props as Props;

// Generate breadcrumbs from URL if not provided
const currentPath = Astro.url.pathname;
const generateBreadcrumbs = (): BreadcrumbItem[] => {
	if (breadcrumbs) return breadcrumbs;

	const items: BreadcrumbItem[] = [{ name: "Home", url: "https://moveroo.com.au/" }];

	if (currentPath !== "/" && currentPath !== "") {
		const segments = currentPath.split("/").filter(Boolean);
		let accumulatedPath = "";

		segments.forEach((segment) => {
			accumulatedPath += `/${segment}`;
			const name = segment
				.split("-")
				.map((word) => word.charAt(0).toUpperCase() + word.slice(1))
				.join(" ");
			items.push({
				name,
				url: `https://moveroo.com.au${accumulatedPath}/`,
			});
		});
	}

	return items;
};

// Base schema for Organization and WebSite (shared across all pages)
const baseSchema = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "Organization",
			"@id": "https://moveroo.com.au/#organization",
			name: "Moveroo Australia",
			url: "https://moveroo.com.au/",
			logo: {
				"@type": "ImageObject",
				"@id": "https://moveroo.com.au/#logo",
				url: "https://moveroo.com.au/og-image.png",
				contentUrl: "https://moveroo.com.au/og-image.png",
				caption: "Moveroo Australia",
			},
			contactPoint: [
				{
					"@type": "ContactPoint",
					telephone: "+61 7 2143 2557",
					contactType: "customer support",
					areaServed: "AU",
					availableLanguage: "English",
				},
			],
			sameAs: ["https://twitter.com/MoverooAU"],
		},
		{
			"@type": "WebSite",
			"@id": "https://moveroo.com.au/#website",
			url: "https://moveroo.com.au/",
			name: "Moveroo Australia",
			description: "Trusted moving and vehicle transport services across Australia",
			publisher: {
				"@id": "https://moveroo.com.au/#organization",
			},
			inLanguage: "en-AU",
		},
		{
			"@type": "BreadcrumbList",
			"@id": `https://moveroo.com.au${currentPath}#breadcrumb`,
			itemListElement: generateBreadcrumbs().map((item, index) => ({
				"@type": "ListItem",
				position: index + 1,
				name: item.name,
				item: item.url,
			})),
		},
	],
};

// Google Analytics: set PUBLIC_GA_MEASUREMENT_ID in .env to enable or use a different ID
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID || "G-4DN533CFGK";

const navItems = [
	{ label: "Home", href: "/", external: false, variant: "link" },
	{
		label: "Moving Quote",
		href: "https://removalists.moveroo.com.au/quote/household",
		external: true,
		variant: "link",
	},
	{
		label: "Vehicle Transport Quote",
		href: "https://cars.moveroo.com.au/quote/v2",
		external: true,
		variant: "link",
	},
	{
		label: "Moving Cars",
		href: "/moving-cars/",
		external: false,
		variant: "link",
	},
	{
		label: "Contact Us",
		href: "/contact/",
		external: false,
		variant: "link",
	},
	{
		label: "Book Your Move",
		href: "https://removalists.moveroo.com.au/booking/create",
		external: true,
		variant: "button",
	},
];
---

<!doctype html>
<html lang="en" class="h-full bg-slate-50 text-slate-900 dark:bg-slate-900 dark:text-white">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<script is:inline>
			(function () {
				const getTheme = () => {
					if (typeof localStorage !== "undefined" && localStorage.getItem("theme")) {
						return localStorage.getItem("theme");
					}
					return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
				};
				const theme = getTheme();
				if (theme === "dark") {
					document.documentElement.classList.add("dark");
				} else {
					document.documentElement.classList.remove("dark");
				}
			})();
		</script>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/manifest.json" />
		<!-- Resource Hints for Performance -->
		<link rel="preconnect" href="https://www.googletagmanager.com" />
		<link rel="preconnect" href="https://againanalytics.vercel.app" />
		<link rel="dns-prefetch" href="https://www.google-analytics.com" />
		<link rel="dns-prefetch" href="https://analytics.google.com" />
		<meta name="generator" content={Astro.generator} />
		{robots && <meta name="robots" content={robots} />}
		<title>{title}</title>
		{description && <meta name="description" content={description} />}
		{canonical && <link rel="canonical" href={canonical} />}
		<!-- Hreflang tags for single-language site -->
		<link rel="alternate" hreflang="en-AU" href={canonical || "https://moveroo.com.au/"} />
		<link rel="alternate" hreflang="x-default" href={canonical || "https://moveroo.com.au/"} />
		<meta property="og:title" content={title} />
		{description && <meta property="og:description" content={description} />}
		{canonical && <meta property="og:url" content={canonical} />}
		<meta property="og:type" content={ogType} />
		<meta property="og:site_name" content="Moveroo Australia" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content="@MoverooAU" />
		<meta name="twitter:title" content={title} />
		{description && <meta name="twitter:description" content={description} />}
		<meta name="twitter:image" content={ogImage} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:type" content="image/png" />
		<!-- PWA / Mobile Web App Meta Tags -->
		<meta name="mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="default" />
		<meta name="apple-mobile-web-app-title" content="Moveroo" />
		<meta name="theme-color" content="#10b981" />
		{
			gaMeasurementId && (
				<>
					<script
						type="text/partytown"
						async
						src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}
					/>
					{/* Inline config so Partytown worker gets the correct ID (window.__GA_MEASUREMENT_ID__ is not visible in worker) */}
					<script
						type="text/partytown"
						set:html={`window.dataLayer = window.dataLayer || []; function gtag(){ dataLayer.push(arguments); } gtag("js", new Date()); var hostname = window.location.hostname; var gaConfig = { cookie_domain: hostname === "localhost" || hostname === "127.0.0.1" ? hostname : "auto" }; gtag("config", "${gaMeasurementId}", gaConfig);`}
					/>
				</>
			)
		}
		<script
			type="text/partytown"
			defer
			src="https://againanalytics.vercel.app/script.js"
			data-website-id="3004f4eb-2b2c-4d61-a2fc-2cd23e627f64"></script>
		{
			includeBaseSchema && (
				<script type="application/ld+json" set:html={JSON.stringify(baseSchema)} />
			)
		}
		<slot name="head" />
	</head>
	<body class="flex min-h-screen flex-col bg-white dark:bg-slate-900 transition-colors">
		<a
			href="#main-content"
			class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:bg-white focus:p-4 focus:text-emerald-700 dark:focus:bg-slate-800 dark:focus:text-emerald-400"
			>Skip to content</a
		>
		<header
			class="border-b border-slate-200 bg-white/90 backdrop-blur dark:border-slate-800 dark:bg-slate-900/90"
		>
			<div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-5">
				<a href="/" class="text-lg font-semibold tracking-tight text-slate-900 dark:text-white"
					>Moveroo</a
				>
				<div class="flex items-center gap-4">
					<div class="hidden md:block">
						<DarkModeToggle />
					</div>
					<button
						class="inline-flex items-center justify-center rounded-full border border-slate-200 p-2 text-slate-700 transition hover:border-emerald-300 hover:text-emerald-700 dark:border-slate-700 dark:text-slate-300 dark:hover:border-emerald-500 dark:hover:text-emerald-400 md:hidden"
						type="button"
						aria-controls="mobile-nav"
						aria-expanded="false"
						data-mobile-nav-toggle
					>
						<span class="sr-only">Toggle navigation</span>
						<svg
							class="h-5 w-5"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"
						>
							<path d="M4 6h16M4 12h16M4 18h16"></path>
						</svg>
					</button>
				</div>
				<nav
					class="hidden items-center gap-6 text-sm font-semibold text-slate-700 dark:text-slate-300 md:flex"
				>
					{
						navItems.map((item) => (
							<a
								class={
									item.variant === "button"
										? "rounded-full border border-emerald-200 px-4 py-2 text-emerald-700 transition hover:border-emerald-300 hover:bg-emerald-50 hover:text-emerald-900 dark:border-emerald-500/50 dark:text-emerald-400 dark:hover:border-emerald-400 dark:hover:bg-emerald-500/10 dark:hover:text-emerald-300"
										: "transition hover:text-emerald-600 dark:hover:text-emerald-400"
								}
								href={item.href}
								target={item.external ? "_blank" : undefined}
								rel={item.external ? "noopener" : undefined}
								aria-label={item.external ? `${item.label} (opens in a new tab)` : undefined}
							>
								{item.label}
							</a>
						))
					}
				</nav>
			</div>
			<div class="md:hidden" data-mobile-nav-panel hidden id="mobile-nav">
				<div
					class="border-t border-slate-200 bg-white px-6 py-4 shadow-lg shadow-emerald-100/60 dark:border-slate-800 dark:bg-slate-900 dark:shadow-black/40"
				>
					<div class="mb-4 flex items-center justify-end">
						<DarkModeToggle />
					</div>
					<nav class="flex flex-col gap-4 text-sm font-semibold text-slate-700 dark:text-slate-300">
						{
							navItems.map((item) => (
								<a
									class={
										item.variant === "button"
											? "inline-flex items-center justify-center rounded-full border border-emerald-200 px-4 py-2 text-emerald-700 transition hover:border-emerald-300 hover:bg-emerald-50 hover:text-emerald-900 dark:border-emerald-500/50 dark:text-emerald-400 dark:hover:border-emerald-400 dark:hover:bg-emerald-500/10 dark:hover:text-emerald-300"
											: "transition hover:text-emerald-600 dark:hover:text-emerald-400"
									}
									href={item.href}
									target={item.external ? "_blank" : undefined}
									rel={item.external ? "noopener" : undefined}
									aria-label={item.external ? `${item.label} (opens in a new tab)` : undefined}
								>
									{item.label}
								</a>
							))
						}
					</nav>
				</div>
			</div>
		</header>
		<main id="main-content" class="flex-1 bg-white dark:bg-slate-900 transition-colors">
			<slot />
		</main>
		<footer class="border-t border-slate-200 bg-slate-50 dark:border-slate-800 dark:bg-slate-900">
			<div
				class="mx-auto flex max-w-6xl flex-col gap-6 px-6 py-10 text-sm text-slate-600 dark:text-slate-400 md:flex-row md:items-start md:justify-between"
			>
				<div>
					<p class="text-base font-semibold text-slate-900 dark:text-white">Moveroo</p>
					<p class="mt-2 max-w-sm text-sm text-slate-600 dark:text-slate-400">
						Reimagining the relocation experience with transparent pricing, dependable partners and
						friendly support.
					</p>
				</div>
				<nav class="flex flex-col gap-2 text-sm font-medium text-slate-700 dark:text-slate-300">
					<a class="transition hover:text-slate-900 dark:hover:text-white" href="/privacy-policy/"
						>Privacy Policy</a
					>
					<a class="transition hover:text-slate-900 dark:hover:text-white" href="/terms-of-use/"
						>Terms of Use</a
					>
					<a
						class="transition hover:text-slate-900 dark:hover:text-white"
						href="/terms-and-conditions-transport/">Transport Terms &amp; Conditions</a
					>
					<a class="transition hover:text-slate-900 dark:hover:text-white" href="/cancellation/"
						>Cancellation Policy</a
					>
					<a class="transition hover:text-slate-900 dark:hover:text-white" href="/sitemap-index.xml"
						>Sitemap</a
					>
				</nav>
			</div>
			<div class="border-t border-slate-200 bg-slate-50 dark:border-slate-800 dark:bg-slate-900">
				<div class="mx-auto max-w-6xl px-6 py-6">
					<div class="flex flex-col items-center justify-between gap-4 md:flex-row">
						<div class="text-xs uppercase tracking-[0.3em] text-slate-600 dark:text-slate-500">
							© {new Date().getFullYear()} Moveroo. All rights reserved.
						</div>
						<div
							class="flex flex-wrap items-center justify-center gap-4 text-xs text-slate-500 dark:text-slate-400"
						>
							<span class="flex items-center gap-1.5">
								<svg
									class="h-4 w-4 text-emerald-600 dark:text-emerald-400"
									fill="currentColor"
									viewBox="0 0 20 20"
									aria-hidden="true"
								>
									<path
										fill-rule="evenodd"
										d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z"
										clip-rule="evenodd"></path>
								</svg>
								<span>Secure SSL</span>
							</span>
							<span class="text-slate-300 dark:text-slate-600">|</span>
							<span>Licensed & Insured</span>
							<span class="text-slate-300 dark:text-slate-600">|</span>
							<span>Australian Owned</span>
						</div>
					</div>
				</div>
			</div>
		</footer>
		<script is:inline src="/scripts/mobile-nav.js"></script>
		<script is:inline>
			console.log("Dark mode script: Starting initialization");
			(function () {
				function initDarkMode() {
					console.log("Dark mode script: initDarkMode called");
					const toggles = document.querySelectorAll("[data-dark-mode-toggle]");
					const html = document.documentElement;

					console.log("Dark mode script: Found", toggles.length, "toggle buttons");

					if (toggles.length === 0) {
						console.error("Dark mode script: No toggle buttons found!");
						return;
					}

					const updateIcons = () => {
						const isDark = html.classList.contains("dark");
						console.log("Dark mode script: Updating icons, isDark =", isDark);
						// When in dark mode, show sun icon (to switch to light)
						// When in light mode, show moon icon (to switch to dark)
						const sunIcons = document.querySelectorAll("[data-sun-icon]");
						const moonIcons = document.querySelectorAll("[data-moon-icon]");
						console.log(
							"Dark mode script: Found",
							sunIcons.length,
							"sun icons and",
							moonIcons.length,
							"moon icons"
						);

						sunIcons.forEach((icon) => {
							if (isDark) {
								icon.classList.remove("hidden");
							} else {
								icon.classList.add("hidden");
							}
						});
						moonIcons.forEach((icon) => {
							if (isDark) {
								icon.classList.add("hidden");
							} else {
								icon.classList.remove("hidden");
							}
						});
					};

					const setTheme = (theme) => {
						console.log("Dark mode script: Setting theme to", theme);
						if (theme === "dark") {
							html.classList.add("dark");
						} else {
							html.classList.remove("dark");
						}
						console.log("Dark mode script: HTML element classes:", html.className);
						console.log("Dark mode script: Has dark class?", html.classList.contains("dark"));
						if (typeof localStorage !== "undefined") {
							localStorage.setItem("theme", theme);
						}
						updateIcons();
					};

					// Initialize icons based on current theme
					updateIcons();

					// Toggle theme on button click
					toggles.forEach((toggle, index) => {
						console.log("Dark mode script: Adding click listener to toggle", index);
						toggle.addEventListener("click", (e) => {
							console.log("Dark mode script: Toggle clicked!");
							e.preventDefault();
							e.stopPropagation();
							const currentTheme = html.classList.contains("dark") ? "dark" : "light";
							const newTheme = currentTheme === "dark" ? "light" : "dark";
							console.log("Dark mode script: Switching from", currentTheme, "to", newTheme);
							setTheme(newTheme);
						});
					});
					console.log("Dark mode script: Initialization complete");
				}

				// Run when DOM is ready
				if (document.readyState === "loading") {
					console.log("Dark mode script: Waiting for DOMContentLoaded");
					document.addEventListener("DOMContentLoaded", initDarkMode);
				} else {
					console.log("Dark mode script: DOM already ready, running immediately");
					initDarkMode();
				}
			})();
		</script>
	</body>
</html>
