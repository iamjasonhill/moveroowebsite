---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	canonical?: string;
	robots?: string;
	ogType?: string;
}

const {
	title = 'Moveroo',
	description,
	canonical,
	robots = 'index, follow',
	ogType = 'website'
} = Astro.props as Props;
---

<!doctype html>
<html lang="en" class="h-full bg-slate-50 text-slate-900">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		{robots && <meta name="robots" content={robots} />}
		{description && <meta name="description" content={description} />}
		<title>{title}</title>
		{canonical && <link rel="canonical" href={canonical} />}
		<meta property="og:title" content={title} />
		{description && <meta property="og:description" content={description} />}
		{canonical && <meta property="og:url" content={canonical} />}
		<meta property="og:type" content={ogType} />
		<meta property="og:site_name" content="Moveroo Australia" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		{description && <meta name="twitter:description" content={description} />}
		<slot name="head" />
	</head>
	<body class="flex min-h-screen flex-col bg-white">
		<header class="border-b border-slate-200 bg-white/90 backdrop-blur">
			<div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
				<a href="/" class="text-lg font-semibold tracking-tight text-slate-900">Moveroo</a>
			</div>
		</header>
		<main class="flex-1 bg-white">
			<slot />
		</main>
		<footer class="border-t border-slate-200 bg-slate-50">
			<div class="mx-auto flex max-w-6xl flex-col gap-6 px-6 py-10 text-sm text-slate-600 md:flex-row md:items-start md:justify-between">
				<div>
					<p class="text-base font-semibold text-slate-900">Moveroo</p>
					<p class="mt-2 max-w-sm text-sm text-slate-600">Reimagining the relocation experience with transparent pricing, dependable partners and friendly support.</p>
				</div>
				<nav class="flex flex-col gap-2 text-sm font-medium text-slate-700">
					<a class="transition hover:text-slate-900" href="/privacy-policy/">Privacy Policy</a>
					<a class="transition hover:text-slate-900" href="/terms-of-use/">Terms of Use</a>
					<a class="transition hover:text-slate-900" href="/terms-and-conditions-transport/">Transport Terms &amp; Conditions</a>
				</nav>
			</div>
			<div class="border-t border-slate-200 bg-slate-50">
				<div class="mx-auto max-w-6xl px-6 py-6 text-xs uppercase tracking-[0.3em] text-slate-600">© {new Date().getFullYear()} Moveroo. All rights reserved.</div>
			</div>
		</footer>
	</body>
</html>
