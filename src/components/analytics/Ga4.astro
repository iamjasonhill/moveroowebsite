---
interface Props {
	measurementId?: string;
	tagUrl?: string;
	sendPageView?: boolean | string;
	anonymizeIp?: boolean | string;
	siteKey?: string;
	trackedLinks?: Array<{
		href: string;
		eventName: string;
		linkType?: string;
		params?: Record<string, string>;
	}>;
}

const {
	measurementId = "",
	tagUrl = "https://www.googletagmanager.com/gtag/js",
	sendPageView = true,
	anonymizeIp = false,
	siteKey = "moveroo",
	trackedLinks = [],
} = Astro.props;

const gaMeasurementId = measurementId.trim();
const gaTagUrl = tagUrl.trim() || "https://www.googletagmanager.com/gtag/js";
const gaSendPageView =
	typeof sendPageView === "string" ? sendPageView !== "false" : Boolean(sendPageView);
const gaAnonymizeIp =
	typeof anonymizeIp === "string" ? anonymizeIp === "true" : Boolean(anonymizeIp);

const gaConfig: Record<string, boolean | string> = {};

gaConfig.send_page_view = gaSendPageView;

if (gaAnonymizeIp) {
	gaConfig.anonymize_ip = true;
}

const normalizedTrackedLinks = trackedLinks
	.filter((link) => link?.href && link?.eventName)
	.map((link) => ({
		href: link.href.replace(/\/$/, ""),
		eventName: link.eventName,
		linkType: link.linkType || "",
		params: link.params || {},
	}));
---

{
	import.meta.env.PROD && gaMeasurementId && (
		<>
			<link rel="dns-prefetch" href="https://www.google-analytics.com" />
			<script
				is:inline
				set:html={`window.dataLayer = window.dataLayer || []; window.gtag = function () { window.dataLayer.push(arguments); }; gtag('js', new Date()); gtag('config', '${gaMeasurementId}', ${JSON.stringify(gaConfig)}); window.mmTrack = function (eventName, params) { gtag('event', eventName, Object.assign({ site_key: '${siteKey}' }, params || {})); }; (function () { var trackedLinks = ${JSON.stringify(normalizedTrackedLinks)}; var scriptLoaded = false; function normalizeUrl(url) { var raw = String(url || '').trim(); if (raw.indexOf('tel:') === 0 || raw.indexOf('mailto:') === 0) return raw.replace(/\\/$/, ''); try { var parsed = new URL(raw, window.location.origin); return (parsed.origin + parsed.pathname).replace(/\\/$/, ''); } catch (_) { return raw.replace(/\\/$/, ''); } } function getLinkText(target) { return (target.getAttribute('aria-label') || target.textContent || '').replace(/\\s+/g, ' ').trim().slice(0, 120); } function loadAnalytics() { if (scriptLoaded) return; scriptLoaded = true; var script = document.createElement('script'); script.async = true; script.src = '${gaTagUrl}?id=${gaMeasurementId}'; document.head.appendChild(script); } function scheduleAnalyticsLoad() { if ('requestIdleCallback' in window) { window.requestIdleCallback(loadAnalytics, { timeout: 2500 }); return; } window.setTimeout(loadAnalytics, 1500); } if (document.readyState === 'complete') { scheduleAnalyticsLoad(); } else { window.addEventListener('load', scheduleAnalyticsLoad, { once: true }); } ['pointerdown', 'keydown', 'touchstart'].forEach(function (eventName) { window.addEventListener(eventName, loadAnalytics, { once: true, passive: true }); }); if (trackedLinks.length) { document.addEventListener('click', function (event) { var target = event.target instanceof Element ? event.target.closest('a[href]') : null; if (!target || target.dataset.mmTracked === 'true') return; var href = target.getAttribute('href'); if (!href) return; var normalizedHref = normalizeUrl(href); for (var i = 0; i < trackedLinks.length; i += 1) { var item = trackedLinks[i]; if (normalizedHref === item.href) { window.mmTrack(item.eventName, Object.assign({}, item.params || {}, { link_url: href, link_text: getLinkText(target), link_type: item.linkType || undefined, page_path: window.location.pathname })); break; } } }); } document.addEventListener('toggle', function (event) { var target = event.target; if (!(target instanceof HTMLDetailsElement) || !target.open) return; var section = target.closest('section'); if (!section || section.id !== 'faq') return; var question = target.querySelector('summary h3'); window.mmTrack('faq_open', { faq_question: question ? getLinkText(question) : '', page_path: window.location.pathname }); }, true); })();`}
			/>
		</>
	)
}
