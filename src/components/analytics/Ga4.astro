---
interface Props {
	measurementId?: string;
	tagUrl?: string;
	sendPageView?: boolean | string;
	anonymizeIp?: boolean | string;
	siteKey?: string;
	trackedLinks?: Array<{
		href: string;
		eventName: string;
		params?: Record<string, string>;
	}>;
}

const {
	measurementId = "",
	tagUrl = "https://www.googletagmanager.com/gtag/js",
	sendPageView = true,
	anonymizeIp = false,
	siteKey = "moveroo",
	trackedLinks = [],
} = Astro.props;

const gaMeasurementId = measurementId.trim();
const gaTagUrl = tagUrl.trim() || "https://www.googletagmanager.com/gtag/js";
const gaSendPageView =
	typeof sendPageView === "string" ? sendPageView !== "false" : Boolean(sendPageView);
const gaAnonymizeIp =
	typeof anonymizeIp === "string" ? anonymizeIp === "true" : Boolean(anonymizeIp);

const gaConfig: Record<string, boolean | string> = {};

gaConfig.send_page_view = gaSendPageView;

if (gaAnonymizeIp) {
	gaConfig.anonymize_ip = true;
}

const normalizedTrackedLinks = trackedLinks
	.filter((link) => link?.href && link?.eventName)
	.map((link) => ({
		href: link.href.replace(/\/$/, ""),
		eventName: link.eventName,
		params: link.params || {},
	}));
---

{
	import.meta.env.PROD && gaMeasurementId && (
		<>
			<link rel="dns-prefetch" href="https://www.google-analytics.com" />
			<script
				is:inline
				set:html={`window.dataLayer = window.dataLayer || []; window.gtag = function () { window.dataLayer.push(arguments); }; gtag('js', new Date()); gtag('config', '${gaMeasurementId}', ${JSON.stringify(gaConfig)}); window.mmTrack = function (eventName, params) { gtag('event', eventName, Object.assign({ site_key: '${siteKey}' }, params || {})); }; (function () { var trackedLinks = ${JSON.stringify(normalizedTrackedLinks)}; var scriptLoaded = false; function normalizeUrl(url) { var raw = String(url || '').trim(); if (raw.indexOf('tel:') === 0 || raw.indexOf('mailto:') === 0) return raw.replace(/\\/$/, ''); try { var parsed = new URL(raw, window.location.origin); return (parsed.origin + parsed.pathname).replace(/\\/$/, ''); } catch (_) { return raw.replace(/\\/$/, ''); } } function getLinkText(target) { return (target.getAttribute('aria-label') || target.textContent || '').replace(/\\s+/g, ' ').trim().slice(0, 120); } function loadAnalytics() { if (scriptLoaded) return; scriptLoaded = true; var script = document.createElement('script'); script.async = true; script.src = '${gaTagUrl}?id=${gaMeasurementId}'; document.head.appendChild(script); } function scheduleAnalyticsLoad() { if ('requestIdleCallback' in window) { window.requestIdleCallback(loadAnalytics, { timeout: 2500 }); return; } window.setTimeout(loadAnalytics, 1500); } if (document.readyState === 'complete') { scheduleAnalyticsLoad(); } else { window.addEventListener('load', scheduleAnalyticsLoad, { once: true }); } ['pointerdown', 'keydown', 'touchstart'].forEach(function (eventName) { window.addEventListener(eventName, loadAnalytics, { once: true, passive: true }); }); var leadIntentByEventName = { quote_household_click: 'quote_household', quote_vehicle_click: 'quote_vehicle', booking_household_click: 'booking_household', contact_intent_click: 'contact' }; function leadIntentId() { var source = String('${siteKey}' || window.location.hostname || 'site').toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_+|_+$/g, '').slice(0, 40) || 'site'; var random = Math.random().toString(36).slice(2, 12); if (window.crypto && window.crypto.getRandomValues) { var values = new Uint32Array(2); window.crypto.getRandomValues(values); random = Array.prototype.map.call(values, function (value) { return value.toString(36); }).join(''); } return 'li_' + source + '_' + Date.now().toString(36) + '_' + random; } function decorateLeadIntentHref(target, eventName) { var intentType = leadIntentByEventName[eventName]; if (!intentType) return; try { var url = new URL(target.href, window.location.href); if (url.protocol !== 'http:' && url.protocol !== 'https:') return; if (url.hostname === window.location.hostname) return; if (!url.searchParams.has('lead_intent_id')) url.searchParams.set('lead_intent_id', leadIntentId()); if (!url.searchParams.has('source_site')) url.searchParams.set('source_site', window.location.hostname); if (!url.searchParams.has('source_path')) url.searchParams.set('source_path', window.location.pathname || '/'); if (!url.searchParams.has('intent_type')) url.searchParams.set('intent_type', intentType); target.href = url.toString(); } catch (_) {} } document.addEventListener('click', function (event) { var customTarget = event.target instanceof Element ? event.target.closest('[data-mm-event]') : null; if (!customTarget) return; window.mmTrack(customTarget.getAttribute('data-mm-event'), { link_url: customTarget.getAttribute('href') || '', link_text: getLinkText(customTarget), service_lane: customTarget.getAttribute('data-mm-lane') || '', surface: customTarget.getAttribute('data-mm-surface') || '', page_path: window.location.pathname }); }); if (trackedLinks.length) { document.addEventListener('click', function (event) { var target = event.target instanceof Element ? event.target.closest('a[href]') : null; if (!target || target.dataset.mmTracked === 'true') return; var href = target.getAttribute('href'); if (!href) return; var normalizedHref = normalizeUrl(href); for (var i = 0; i < trackedLinks.length; i += 1) { var item = trackedLinks[i]; if (normalizedHref === item.href) { decorateLeadIntentHref(target, item.eventName); var eventParams = Object.assign({}, item.params || {}, { link_url: href, link_text: getLinkText(target), page_path: window.location.pathname }); if (eventParams.handoff_event_name) { eventParams.handoff_path = window.location.pathname; } window.mmTrack(item.eventName, eventParams); break; } } }); } document.addEventListener('toggle', function (event) { var target = event.target; if (!(target instanceof HTMLDetailsElement) || !target.open) return; var section = target.closest('section'); if (!section || section.id !== 'faq') return; var question = target.querySelector('summary h3'); window.mmTrack('faq_open', { faq_question: question ? getLinkText(question) : '', page_path: window.location.pathname }); }, true); var scrollMilestones = [25, 50, 75, 90]; var sentScrollMilestones = {}; var scrollQueued = false; function checkScrollDepth() { scrollQueued = false; var documentElement = document.documentElement; var scrollable = Math.max(1, documentElement.scrollHeight - window.innerHeight); var percent = Math.min(100, Math.round((window.scrollY / scrollable) * 100)); for (var i = 0; i < scrollMilestones.length; i += 1) { var milestone = scrollMilestones[i]; if (percent >= milestone && !sentScrollMilestones[milestone]) { sentScrollMilestones[milestone] = true; window.mmTrack('scroll_depth', { scroll_percent: String(milestone), page_path: window.location.pathname }); } } } window.addEventListener('scroll', function () { if (scrollQueued) return; scrollQueued = true; window.requestAnimationFrame(checkScrollDepth); }, { passive: true }); checkScrollDepth(); })();`}
			/>
		</>
	)
}
