---
import { site } from "../../config/site";

interface Props {
	title: string;
	subtitle: string;
	ctaPrimaryLabel: string;
	ctaPrimaryHref: string;
	ctaSecondaryLabel?: string;
	ctaSecondaryHref?: string;
}

const { title, subtitle, ctaPrimaryLabel, ctaPrimaryHref, ctaSecondaryLabel, ctaSecondaryHref } =
	Astro.props as Props;

function resolveHref(href: string) {
	if (href === site.destinations.householdQuote) return site.destinations.householdQuote;
	if (href === site.destinations.vehicleQuote) return site.destinations.vehicleQuote;
	if (href === site.destinations.contactPage) return site.destinations.contactPage;
	if (href === site.destinations.bookingPage) return site.destinations.bookingPage;
	return href;
}

const primaryHref = resolveHref(ctaPrimaryHref);
const secondaryHref = ctaSecondaryHref ? resolveHref(ctaSecondaryHref) : undefined;

const opensQuoteWorkspace =
	primaryHref.startsWith("https://quotes.moveroo.com.au") ||
	secondaryHref?.startsWith("https://quotes.moveroo.com.au");

const quoteNextSteps = [
	"Tell us what is moving, where it is going and any dates we need to work around.",
	"Moveroo reviews the details and explains the next step.",
	"You can review the quote before anything is booked.",
];
---

<section class="bg-white py-20 dark:bg-slate-900">
	<div class="mx-auto max-w-6xl px-6">
		<div
			class="motion-rise overflow-hidden rounded-[2rem] border border-slate-200 bg-slate-950 text-white shadow-[0_28px_90px_-48px_rgba(15,23,42,0.7)] dark:border-slate-800"
		>
			<div
				class="bg-[radial-gradient(circle_at_top_left,_rgba(16,185,129,0.28),_transparent_26%),linear-gradient(135deg,_#052e2b_0%,_#0f172a_44%,_#111827_100%)] px-6 py-10 md:px-8 md:py-12"
			>
				<div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
					<div class="max-w-2xl">
						<p class="section-kicker text-emerald-300">Next step</p>
						<h2 class="section-title mt-5 text-4xl font-semibold text-white md:text-5xl">
							{title}
						</h2>
						<p class="mt-5 text-base leading-relaxed text-slate-300 md:text-lg">{subtitle}</p>
						<div
							class="mt-6 grid gap-3 rounded-2xl border border-white/10 bg-white/5 p-4 text-sm leading-relaxed text-slate-300 md:grid-cols-3"
						>
							{
								quoteNextSteps.map((step, index) => (
									<div class="flex gap-3">
										<span class="font-semibold text-emerald-300">0{index + 1}</span>
										<span>{step}</span>
									</div>
								))
							}
						</div>
					</div>

					<div class="motion-rise motion-rise-delay-1 flex flex-col gap-4 lg:items-end">
						<a
							class="inline-flex items-center justify-center rounded-full bg-emerald-400 px-6 py-3 text-sm font-semibold text-slate-950 shadow-lg shadow-emerald-950/30 transition hover:bg-emerald-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-300"
							href={primaryHref}
							target={primaryHref.startsWith("http") ? "_blank" : undefined}
							rel={primaryHref.startsWith("http") ? "noopener noreferrer" : undefined}
						>
							{ctaPrimaryLabel}
						</a>
						{
							ctaSecondaryLabel && secondaryHref && (
								<a
									class="inline-flex items-center justify-center rounded-full border border-white/20 px-6 py-3 text-sm font-semibold text-white transition hover:border-emerald-300 hover:bg-white/5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-300"
									href={secondaryHref}
									rel={secondaryHref.startsWith("http") ? "noopener noreferrer" : undefined}
									target={secondaryHref.startsWith("http") ? "_blank" : undefined}
								>
									{ctaSecondaryLabel}
								</a>
							)
						}
						<a
							href="/how-moveroo-protects-your-move/"
							class="site-text-action text-sm font-medium text-slate-300 underline decoration-slate-500 underline-offset-4 transition hover:text-emerald-200 hover:decoration-emerald-300"
						>
							See how Moveroo protects your move
						</a>
						{
							opensQuoteWorkspace && (
								<p class="max-w-xs text-sm leading-relaxed text-slate-400 lg:text-right">
									Opens Moveroo's secure quote workspace. Submitting a quote request does not create
									a booking.
								</p>
							)
						}
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
