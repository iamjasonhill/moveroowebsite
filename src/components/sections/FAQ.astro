---
interface FAQItem {
	question: string;
	answer: string;
}

const faqs: FAQItem[] = [
	{
		question: "How do I get a moving quote from Moveroo?",
		answer:
			"Simply visit our quote page and enter your move details including pickup and delivery locations, move date, and inventory size. We'll connect you with multiple verified removalists who will provide competitive quotes within 24 hours.",
	},
	{
		question: "What areas does Moveroo service in Australia?",
		answer:
			"Moveroo services all major cities and regional areas across Australia, including Sydney, Melbourne, Brisbane, Perth, Adelaide, Hobart, Darwin, and Canberra. We handle both local moves and interstate relocations.",
	},
	{
		question: "Are the removalists on Moveroo verified and insured?",
		answer:
			"Yes, all removalists on our platform are thoroughly vetted for reliability, professionalism, and proper insurance coverage. We only partner with licensed operators who meet our strict quality standards.",
	},
	{
		question: "How much does it cost to move house in Australia?",
		answer:
			"Moving costs vary based on distance, volume of items, and additional services required. Local moves typically start from $300-$500, while interstate moves can range from $1,500 to $5,000+. Get a free quote for an accurate estimate tailored to your specific move.",
	},
	{
		question: "Can Moveroo help with vehicle transport?",
		answer:
			"Absolutely! We offer comprehensive vehicle transport services across Australia. Whether you're moving interstate, buying a car from another city, or need enclosed transport for a classic vehicle, we connect you with trusted car carriers.",
	},
	{
		question: "How far in advance should I book my move?",
		answer:
			"We recommend booking at least 2-4 weeks in advance for local moves and 4-6 weeks for interstate relocations. During peak periods (end of month, holidays), booking earlier ensures better availability and pricing.",
	},
];

export { faqs };
---

<section class="bg-slate-50 py-24 dark:bg-slate-900" id="faq">
	<div class="mx-auto max-w-6xl px-6">
		<div
			class="grid gap-12 lg:grid-cols-[minmax(0,0.82fr)_minmax(0,1.18fr)] lg:items-start lg:gap-16"
		>
			<div class="motion-rise lg:sticky lg:top-28">
				<p class="section-kicker">FAQ</p>
				<h2
					class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
				>
					Common planning questions, answered before you even start the quote.
				</h2>
				<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
					Most people want clarity on timing, coverage, verification and how pricing works before
					they commit to anything. This section should feel calm, direct and easy to scan.
				</p>

				<div class="page-panel page-panel-soft mt-8 p-6 md:p-7">
					<p
						class="text-xs font-semibold uppercase tracking-[0.24em] text-emerald-700 dark:text-emerald-400"
					>
						Still unsure?
					</p>
					<p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
						If your move has multiple drop-offs, vehicle transport, storage or tight timing, our
						coordinators can talk through the setup with you directly.
					</p>
					<a
						href="/contact/"
						class="mt-5 inline-flex items-center justify-center rounded-full border border-emerald-500 px-5 py-2.5 text-sm font-semibold text-emerald-700 transition hover:border-emerald-600 hover:bg-emerald-50 hover:text-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700 dark:border-emerald-500/50 dark:text-emerald-400 dark:hover:border-emerald-400 dark:hover:bg-emerald-500/10 dark:hover:text-emerald-300 dark:focus-visible:outline-emerald-400"
					>
						Contact our friendly team
					</a>
				</div>
			</div>

			<div
				class="motion-rise motion-rise-delay-1 overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-[0_28px_80px_-48px_rgba(15,23,42,0.28)] dark:border-slate-800 dark:bg-slate-950/45 dark:shadow-black/40"
			>
				{
					faqs.map((faq, index) => (
						<details
							class="group border-b border-slate-200 px-6 py-6 last:border-b-0 dark:border-slate-800 md:px-8"
							open={index === 0}
						>
							<summary class="flex cursor-pointer items-start justify-between gap-5 list-none">
								<div class="pr-2">
									<p class="text-xs font-semibold uppercase tracking-[0.24em] text-emerald-700 dark:text-emerald-400">
										0{index + 1}
									</p>
									<h3 class="mt-3 text-xl font-semibold tracking-tight text-slate-900 dark:text-white md:text-2xl">
										{faq.question}
									</h3>
								</div>
								<span class="mt-1 inline-flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full border border-slate-200 bg-slate-50 text-slate-600 transition group-open:rotate-180 group-open:border-emerald-200 group-open:bg-emerald-50 group-open:text-emerald-700 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300 dark:group-open:border-emerald-500/40 dark:group-open:bg-emerald-500/10 dark:group-open:text-emerald-300">
									<svg
										class="h-5 w-5"
										fill="none"
										viewBox="0 0 24 24"
										stroke="currentColor"
										stroke-width="2"
									>
										<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
									</svg>
								</span>
							</summary>
							<p class="mt-5 max-w-3xl text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
								{faq.answer}
							</p>
						</details>
					))
				}
			</div>
		</div>
	</div>
</section>
