---
const primaryCta = {
  label: 'Request a callback',
  href: '/contact/'
};

const secondaryCta = {
  label: 'Explore moving services',
  href: '/services/'
};
---

<section class="relative overflow-hidden bg-gradient-to-br from-emerald-50 via-emerald-100 to-white py-24">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(16,185,129,0.16),_transparent_55%)]" aria-hidden="true"></div>
  </div>

  <div class="relative mx-auto flex max-w-6xl flex-col gap-12 px-6 md:flex-row md:items-center">
    <div class="max-w-xl">
      <p class="text-sm font-semibold uppercase tracking-[0.4em] text-emerald-600">Moveroo</p>
      <h1 class="mt-6 text-4xl font-semibold leading-tight text-slate-900 md:text-5xl">
        We match every move with the right removalists across Australia
      </h1>
      <p class="mt-6 text-lg text-slate-600">
        Tell us about your relocation and we’ll shortlist trusted removalists, vehicle carriers and storage partners tailored to your timelines, inventory and budget.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          class="inline-flex items-center justify-center rounded-full bg-emerald-500 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-emerald-500/40 transition hover:bg-emerald-600"
          href={primaryCta.href}
        >
          {primaryCta.label}
        </a>
        <a
          class="rounded-full border border-emerald-200 px-6 py-3 text-sm font-semibold text-emerald-700 transition hover:border-emerald-300 hover:text-emerald-900"
          href={secondaryCta.href}
        >
          {secondaryCta.label}
        </a>
      </div>
      <div class="mt-12 flex flex-wrap items-center gap-6 text-xs uppercase tracking-[0.35em] text-slate-500">
        <span class="text-slate-700">Trusted by families, fleet managers &amp; small businesses nationwide</span>
      </div>
    </div>

    <div class="flex-1 space-y-6 rounded-3xl border border-slate-200 bg-white p-8 shadow-2xl shadow-slate-200/50">
      <h2 class="text-lg font-semibold text-slate-900">What we handle</h2>
      <ul class="space-y-3 text-sm text-slate-600">
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2 w-2 rounded-full bg-emerald-500" aria-hidden="true"></span>
          <span>Household removals with packing, storage and staged delivery options.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2 w-2 rounded-full bg-emerald-500" aria-hidden="true"></span>
          <span>Specialty transport for vehicles, oversized items and fragile collections.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2 w-2 rounded-full bg-emerald-500" aria-hidden="true"></span>
          <span>Coordinated support for corporate relocations and repeat move programs.</span>
        </li>
      </ul>
    </div>
  </div>
</section>
