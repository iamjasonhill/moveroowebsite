---
import { site } from "../../config/site";
import { getTrackedOnClick } from "../../utils/tracking";

interface Plan {
	name: string;
	price: string;
	description: string;
	highlights: string[];
	cta: string;
	href: string;
}

const plans: Plan[] = [
	{
		name: "Backloading move",
		price: "From $450",
		description:
			"Leverage returning trucks to reduce costs when your schedule has room for flexible pickup and delivery windows.",
		highlights: [
			"Lowest rates by sharing capacity across compatible routes",
			"Move windows coordinated with proactive SMS and email updates",
			"Ideal for apartments, partial loads and date-flexible relocations",
		],
		cta: "Grab your free quote",
		href: site.destinations.householdQuote,
	},
	{
		name: "Dedicated move",
		price: "From $880",
		description:
			"Lock in your ideal move day with a crew committed to keeping every milestone on schedule.",
		highlights: [
			"Receive constant updates across loading, transit and delivery stages",
			"Concierge packing, unpacking and care for fragile or specialty items",
			"Add storage, vehicle transport or extra crews on demand as plans evolve",
		],
		cta: "Grab your free quote",
		href: site.destinations.householdQuote,
	},
];
---

<section class="bg-white py-24 dark:bg-slate-900">
	<div class="mx-auto max-w-6xl px-6">
		<div class="motion-rise max-w-3xl">
			<p class="section-kicker">Moveroo plans</p>
			<h2
				class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
			>
				Two clear ways to structure the move, depending on how fixed your timing is.
			</h2>
			<p class="mt-6 text-base leading-relaxed text-slate-600 dark:text-slate-400">
				These examples show how Moveroo frames shared backloads and fully dedicated crews. The final
				quote still depends on route, inventory and extra services, but the difference in pace and
				control should be easy to understand at a glance.
			</p>
		</div>

		<div
			class="motion-rise motion-rise-delay-1 mt-14 overflow-hidden rounded-[2rem] border border-slate-200 bg-slate-50 shadow-[0_28px_80px_-48px_rgba(15,23,42,0.3)] dark:border-slate-800 dark:bg-slate-950/40 dark:shadow-black/40"
		>
			<div class="grid md:grid-cols-2">
				{
					plans.map((plan, index) => (
						<article
							class={`flex h-full flex-col gap-6 px-6 py-8 md:px-8 md:py-10 ${
								index === 0
									? "border-b border-slate-200 dark:border-slate-800 md:border-b-0 md:border-r"
									: "bg-white/70 dark:bg-slate-900/35"
							}`}
						>
							<div class="flex items-start justify-between gap-6">
								<div>
									<p class="text-xs font-semibold uppercase tracking-[0.26em] text-emerald-700 dark:text-emerald-400">
										{index === 0 ? "Flexible option" : "Priority option"}
									</p>
									<h3 class="mt-3 text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">
										{plan.name}
									</h3>
								</div>
								<p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-500 dark:text-slate-400">
									{plan.price}
								</p>
							</div>

							<p class="text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
								{plan.description}
							</p>

							<ul class="space-y-4 border-t border-slate-200 pt-6 text-sm text-slate-600 dark:border-slate-800 dark:text-slate-400">
								{plan.highlights.map((item) => (
									<li class="flex items-start gap-3">
										<span
											class={`mt-2 h-2.5 w-2.5 rounded-full ${
												index === 0 ? "bg-emerald-500" : "bg-emerald-700 dark:bg-emerald-400"
											}`}
											aria-hidden="true"
										/>
										<span>{item}</span>
									</li>
								))}
							</ul>

							<a
								class={`mt-auto inline-flex w-fit items-center justify-center rounded-full px-6 py-3 text-sm font-semibold transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 ${
									index === 0
										? "border border-emerald-700 text-emerald-800 hover:border-emerald-800 hover:bg-emerald-50 hover:text-emerald-950 focus-visible:outline-emerald-800 dark:border-emerald-400/60 dark:text-emerald-300 dark:hover:border-emerald-300 dark:hover:bg-emerald-500/10 dark:hover:text-emerald-200 dark:focus-visible:outline-emerald-300"
										: "bg-emerald-800 text-white shadow-lg shadow-emerald-800/30 hover:bg-emerald-900 focus-visible:outline-emerald-900 dark:bg-emerald-700 dark:shadow-emerald-700/30 dark:hover:bg-emerald-600 dark:focus-visible:outline-emerald-600"
								}`}
								href={plan.href}
								onclick={getTrackedOnClick(plan.href, site.analytics.trackedLinks)}
								rel="noopener noreferrer"
								target="_blank"
							>
								{plan.cta}
							</a>
						</article>
					))
				}
			</div>
		</div>
	</div>
</section>
