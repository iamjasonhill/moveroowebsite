---
interface Plan {
  name: string;
  price: string;
  description: string;
  highlights: string[];
  cta: string;
  href: string;
}

const plans: Plan[] = [
  {
    name: 'Backloading move',
    price: 'From $450',
    description:
      'Leverage returning trucks to reduce costs when your schedule has room for flexible pickup and delivery windows.',
    highlights: [
      'Lowest rates by sharing capacity across compatible routes',
      'Move windows coordinated with proactive SMS/email updates',
      'Ideal for apartments, partial loads and date-flexible relocations'
    ],
    cta: 'Grab your free quote',
    href: 'https://removalists.moveroo.com.au/quote/household'
  },
  {
    name: 'Dedicated move',
    price: 'From $880',
    description: 'Lock in your ideal move day with a crew committed to keeping every milestone on schedule.',
    highlights: [
      'Receive constant SMS/email updates across loading, transit and delivery stages',
      'Concierge packing, unpacking and care for fragile or specialty items',
      'Add storage, vehicle transport or extra crews on-demand as plans evolve'
    ],
    cta: 'Grab your free quote',
    href: 'https://removalists.moveroo.com.au/quote/household'
  }
];
---

<section class="bg-white py-24 dark:bg-slate-900">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.35em] text-emerald-700 dark:text-emerald-400">Moveroo plans</p>
      <h2 class="mt-6 text-3xl font-semibold text-slate-900 dark:text-white md:text-4xl">Flexible packages for stress-free relocations</h2>
      <p class="mx-auto mt-6 max-w-2xl text-base text-slate-600 dark:text-slate-400">
        These examples show how our quoting works for shared backloads and fully dedicated crews. Your tailored proposal details travel distance, inventory, timing and optional services so you know exactly what's included before you confirm.
      </p>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-2">
      {plans.map((plan, index) => (
        <article
          class={`relative flex h-full flex-col gap-6 rounded-2xl border p-8 shadow-lg transition hover:shadow-xl ${
            index === 1
              ? 'border-2 border-emerald-600/60 bg-emerald-50/50 shadow-emerald-200/40 dark:border-emerald-500/60 dark:bg-emerald-500/10 dark:shadow-emerald-500/10'
              : 'border border-slate-200 bg-white shadow-slate-200/40 dark:border-slate-800 dark:bg-slate-800/50 dark:shadow-black/20'
          }`}
        >
          <div class="flex items-center justify-between">
            <h3 class="text-xl font-semibold text-slate-900 dark:text-white">{plan.name}</h3>
            <span class={`text-sm font-semibold uppercase tracking-[0.35em] ${
              index === 1
                ? 'text-emerald-700 dark:text-emerald-400'
                : 'text-slate-600 dark:text-slate-400'
            }`}>{plan.price}</span>
          </div>
          <p class="text-sm text-slate-600 dark:text-slate-400">{plan.description}</p>
          <ul class="space-y-3 text-sm text-slate-600 dark:text-slate-400">
            {plan.highlights.map((item) => (
              <li class="flex items-start gap-3">
                <span class={`mt-1 h-2 w-2 rounded-full ${
                  index === 1
                    ? 'bg-emerald-600 dark:bg-emerald-400'
                    : 'bg-emerald-500 dark:bg-emerald-400'
                }`} aria-hidden="true"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <a
            class={`mt-auto inline-flex w-fit items-center justify-center rounded-full px-6 py-3 text-sm font-semibold transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 ${
              index === 1
                ? 'bg-emerald-700 text-white shadow-lg shadow-emerald-700/30 hover:bg-emerald-800 focus-visible:outline-emerald-800 dark:bg-emerald-600 dark:shadow-emerald-600/30 dark:hover:bg-emerald-500 dark:focus-visible:outline-emerald-500'
                : 'border border-emerald-500 text-emerald-700 hover:border-emerald-600 hover:text-emerald-900 focus-visible:outline-emerald-700 dark:border-emerald-500/50 dark:text-emerald-400 dark:hover:border-emerald-400 dark:hover:bg-emerald-500/10 dark:hover:text-emerald-300 dark:focus-visible:outline-emerald-400'
            }`}
            href={plan.href}
            rel="noopener noreferrer"
            target="_blank"
          >
            {plan.cta}
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
