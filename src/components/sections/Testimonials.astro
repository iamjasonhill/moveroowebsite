---
interface Testimonial {
	quote: string;
	name: string;
	role: string;
}

const testimonials: Testimonial[] = [
	{
		quote:
			"Our Gold Coast to Melbourne move included household goods and a car. Moveroo kept the dates clear and the handoffs simple the whole way through.",
		name: "Samantha P.",
		role: "Household and vehicle move",
	},
	{
		quote:
			"We had company vehicles heading to two states in the same week. Moveroo gave us one contact, clear pickup windows and straightforward updates.",
		name: "Lewis R.",
		role: "Fleet manager, national supplier",
	},
	{
		quote:
			"Our regional backload had tight timing and a few moving parts. Moveroo kept us updated and the job landed when they said it would.",
		name: "Gina T.",
		role: "Small business owner, regional move",
	},
];
---

<section
	class="relative overflow-hidden border-y border-slate-200 bg-slate-950 py-24 text-white dark:border-slate-800"
>
	<div
		class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(16,185,129,0.24),_transparent_30%),linear-gradient(180deg,_rgba(15,23,42,0.05),_rgba(15,23,42,0.85))]"
	>
	</div>
	<div class="relative mx-auto max-w-6xl px-6">
		<div class="grid gap-10 lg:grid-cols-[minmax(0,0.8fr)_minmax(0,1.2fr)] lg:items-start">
			<div class="motion-rise">
				<p class="section-kicker text-emerald-300">Testimonials</p>
				<h2 class="section-title mt-6 text-4xl font-semibold text-balance text-white md:text-5xl">
					What people remember is whether the move stayed under control.
				</h2>
				<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-300">
					Real stories from households, fleet managers and business owners who needed clear timing,
					clear updates and fewer moving parts to manage.
				</p>
			</div>

			<div
				class="motion-rise motion-rise-delay-1 overflow-hidden rounded-[2rem] border border-white/10 bg-white/5 backdrop-blur-sm"
			>
				{
					testimonials.map((testimonial, index) => (
						<article class="border-b border-white/10 px-6 py-7 last:border-b-0 md:px-8">
							<div class="flex gap-4">
								<span class="text-4xl leading-none text-emerald-300/80">“</span>
								<div>
									<p class="text-base leading-relaxed text-slate-100">{testimonial.quote}</p>
									<div class="mt-5 flex flex-col gap-1 text-sm">
										<p class="font-semibold uppercase tracking-[0.22em] text-emerald-200">
											{testimonial.name}
										</p>
										<p class="text-slate-300">{testimonial.role}</p>
									</div>
								</div>
							</div>
						</article>
					))
				}
			</div>
		</div>
	</div>
</section>
