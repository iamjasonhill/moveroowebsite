---
interface Testimonial {
  quote: string;
  name: string;
  role: string;
}

const testimonials: Testimonial[] = [
  {
    quote:
      'Moveroo handled our interstate move with zero fuss. Booking through their platform kept every date locked in and updated from pickup to delivery.',
    name: 'Samantha P.',
    role: 'Gold Coast to Melbourne relocation'
  },
  {
    quote:
      'Coordinating company car relocations used to be a chore. I can’t wait to manage everything from the revamped Moveroo dashboard.',
    name: 'Lewis R.',
    role: 'Fleet manager, national supplier'
  },
  {
    quote:
      'We’ve trusted Moveroo for regional backloads for years. Their team keeps you informed every step of the way.',
    name: 'Gina T.',
    role: 'Small business owner'
  }
];
---

<section class="border-y border-slate-200 bg-slate-50 py-24 dark:border-slate-800 dark:bg-slate-900">
  <div class="mx-auto max-w-6xl px-6">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-[0.35em] text-emerald-700 dark:text-emerald-400">Testimonials</p>
      <h2 class="mt-6 text-3xl font-semibold text-slate-900 dark:text-white md:text-4xl">What customers love about Moveroo</h2>
      <p class="mt-6 text-base text-slate-600 dark:text-slate-400">
        Real stories from households, fleet managers and business owners who rely on Moveroo every week.
      </p>
    </div>

    <div class="mt-14 grid gap-8 md:grid-cols-3">
      {testimonials.map((testimonial) => (
        <article class="flex flex-col gap-4 rounded-2xl border border-slate-200 bg-white p-8 shadow-lg shadow-slate-200/40 transition hover:shadow-xl dark:border-slate-800 dark:bg-slate-800/50 dark:shadow-black/20 dark:hover:border-slate-700">
          <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-400">"{testimonial.quote}"</p>
          <div class="mt-auto text-xs uppercase tracking-[0.35em] text-slate-500 dark:text-slate-500">
            <span>{testimonial.name}</span>
          </div>
          <p class="text-slate-600 dark:text-slate-400">{testimonial.role}</p>
        </article>
      ))}
    </div>
  </div>
</section>
