---
interface Feature {
  eyebrow: string;
  title: string;
  description: string;
}

const features: Feature[] = [
  {
    eyebrow: 'Local expertise',
    title: 'Moves tailored to metro and regional routes',
    description:
      'We align you with trusted carriers in every Australian state, ensuring the right vehicle, crew and schedule for your origin and destination.'
  },
  {
    eyebrow: 'Customer focus',
    title: 'Proactive support from enquiry to delivery',
    description:
      'Dedicated coordinators keep you updated with pickup windows, transit checkpoints and arrival notices so you always know what comes next.'
  },
  {
    eyebrow: 'Flexible services',
    title: 'Options for storage, packing and specialised care',
    description:
      'Add-ons cover packing assistance, secure storage and careful handling for antiques, instruments and other fragile belongings.'
  }
];
---

<section class="border-y border-slate-200 bg-slate-50 py-24 dark:border-slate-800 dark:bg-slate-900">
  <div class="mx-auto max-w-6xl px-6">
    <div class="md:grid md:grid-cols-[1.1fr_1fr] md:items-start md:gap-16">
      <header>
        <p class="text-sm font-semibold uppercase tracking-[0.35em] text-emerald-700 dark:text-emerald-400">Moveroo advantage</p>
        <h2 class="mt-6 text-3xl font-semibold text-slate-900 dark:text-white md:text-4xl">
          Personalised moves with the reliability of a national network
        </h2>
        <p class="mt-6 text-base leading-relaxed text-slate-600 dark:text-slate-400">
          Moveroo now connects households and businesses with vetted removalists, specialist carriers and support teams across Australia. Expect transparent quotes, dependable schedules and proactive coordination from first enquiry through delivery.
        </p>
      </header>

      <div class="mt-12 grid gap-8 md:mt-0">
        {features.map((feature) => (
          <article class="space-y-3 rounded-2xl border border-slate-200 bg-white p-8 shadow-lg shadow-slate-200/40 transition hover:shadow-xl dark:border-slate-800 dark:bg-slate-800/50 dark:shadow-black/20 dark:hover:border-slate-700">
            <p class="text-xs font-semibold uppercase tracking-[0.35em] text-emerald-700 dark:text-emerald-400">{feature.eyebrow}</p>
            <h3 class="text-xl font-semibold text-slate-900 dark:text-white">{feature.title}</h3>
            <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-400">{feature.description}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
