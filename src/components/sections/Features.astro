---
interface Feature {
	eyebrow: string;
	title: string;
	description: string;
}

const features: Feature[] = [
	{
		eyebrow: "Local expertise",
		title: "Moves tailored to metro and regional routes",
		description:
			"We align you with trusted carriers in every Australian state, ensuring the right vehicle, crew and schedule for your origin and destination.",
	},
	{
		eyebrow: "Customer focus",
		title: "Proactive support from enquiry to delivery",
		description:
			"Dedicated coordinators keep you updated with pickup windows, transit checkpoints and arrival notices so you always know what comes next.",
	},
	{
		eyebrow: "Flexible services",
		title: "Options for storage, packing and specialised care",
		description:
			"Add-ons cover packing assistance, secure storage and careful handling for antiques, instruments and other fragile belongings.",
	},
];
---

<section
	class="border-y border-slate-200 bg-slate-50 py-24 dark:border-slate-800 dark:bg-slate-900"
>
	<div class="mx-auto max-w-6xl px-6">
		<div
			class="grid gap-12 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)] lg:items-start lg:gap-16"
		>
			<header class="motion-rise lg:sticky lg:top-28">
				<p class="section-kicker">Moveroo advantage</p>
				<h2
					class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
				>
					A move system that stays calm when the logistics get complicated.
				</h2>
				<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
					Moveroo now connects households and businesses with vetted removalists, specialist
					carriers and support teams across Australia. The point is not more options on screen. It
					is a clearer path from enquiry to delivery.
				</p>
			</header>

			<div
				class="motion-rise motion-rise-delay-1 overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-[0_28px_80px_-48px_rgba(15,23,42,0.32)] dark:border-slate-800 dark:bg-slate-950/40 dark:shadow-black/40"
			>
				{
					features.map((feature, index) => (
						<article class="grid gap-5 border-b border-slate-200 px-6 py-7 last:border-b-0 dark:border-slate-800 md:grid-cols-[7rem_1fr] md:px-8">
							<div class="flex items-center gap-3 md:block">
								<p class="text-xs font-semibold uppercase tracking-[0.26em] text-emerald-700 dark:text-emerald-400">
									0{index + 1}
								</p>
								<p class="mt-0 text-xs uppercase tracking-[0.26em] text-slate-400 md:mt-3">
									{feature.eyebrow}
								</p>
							</div>
							<div>
								<h3 class="text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">
									{feature.title}
								</h3>
								<p class="mt-4 max-w-2xl text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
									{feature.description}
								</p>
							</div>
						</article>
					))
				}
			</div>
		</div>
	</div>
</section>
