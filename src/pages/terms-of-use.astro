---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Moveroo | Terms of Use">
	<section class="bg-slate-950 py-20">
		<div class="mx-auto max-w-3xl px-6">
			<h1 class="text-3xl font-semibold text-white">Terms of Use</h1>
			<p class="mt-6 text-sm text-slate-300">
				This page preserves the original Terms of Use from the legacy moveroo.com.au website. Full legal copy will be migrated once the refreshed wording has been approved by the business and legal teams.
			</p>
			<p class="mt-4 text-sm text-slate-300">
				Until then, reference the archived export or contact the Moveroo support team for any contractual clarifications.
			</p>
		</div>
	</section>
</Layout>
