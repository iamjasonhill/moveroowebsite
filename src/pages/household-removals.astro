---
import Layout from "../layouts/Layout.astro";
import QuoteCta from "../components/sections/QuoteCta.astro";
import { site } from "../config/site";

const publishedAt = new Date("2026-05-13T00:00:00+10:00");
const updatedAt = publishedAt;

const pageTitle = "Household Removals Australia | Moveroo";
const pageDescription =
	"Plan local, regional and interstate household removals with Moveroo, including access, inventory, packing, storage and timing support.";

const moveTypes = [
	{
		label: "Apartment moves",
		text: "Useful when lifts, loading bays, stairs, parking or building rules need to be included in the first brief.",
	},
	{
		label: "Family home moves",
		text: "Best when inventory, access, packing, timing and extra services all need to be understood before quoting.",
	},
	{
		label: "Regional and interstate moves",
		text: "Helpful when dates, route distance, delivery windows and backloading or dedicated pathways need comparison.",
	},
	{
		label: "Moves with added support",
		text: "Use the household path when storage, packing, unpacking, fragile items or a vehicle also need to be considered.",
	},
];

const planningDetails = [
	"Pickup and delivery suburbs",
	"Preferred dates and timing constraints",
	"Apartment, lift, stair, parking and access notes",
	"Inventory size, bulky items and fragile items",
	"Packing, unpacking or storage needs",
	"Whether a car or motorcycle also needs transport",
];

const serviceOptions = [
	{
		label: "Backloading-style pathways",
		text: "For date-flexible moves where shared capacity may be a suitable option for the route and inventory.",
	},
	{
		label: "Dedicated move pathways",
		text: "For moves where timing, access, volume or service expectations need a more fixed plan.",
	},
	{
		label: "Packing and storage coordination",
		text: "For jobs where boxes, fragile items, temporary storage or staged handoffs should be considered early.",
	},
];

const faqItems = [
	{
		question: "What household removals can Moveroo help coordinate?",
		answer:
			"Moveroo can help coordinate apartment moves, home moves, local moves, regional moves and interstate household relocations across Australia.",
	},
	{
		question: "Should I choose backloading or a dedicated move?",
		answer:
			"Backloading-style pathways can suit flexible dates and compatible routes. Dedicated pathways can suit fixed timing, larger inventories, access constraints or moves needing a clearer schedule.",
	},
	{
		question: "Can packing, storage or fragile items be included?",
		answer:
			"Yes. Include packing, unpacking, storage, fragile items, bulky items and access notes in the first brief so Moveroo can match the move to a suitable service pathway.",
	},
	{
		question: "What if my household move also includes a car?",
		answer:
			"Start with the household quote and include the vehicle details early. Moveroo can coordinate same-day pickup where availability and job details support it, but same-day delivery for both services should not be assumed.",
	},
	{
		question: "Does Moveroo do the physical move?",
		answer:
			"Moveroo coordinates the quote path, service mix and support flow. Vetted transport partners complete the physical move or transport service matched to the job.",
	},
];

const structuredData = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "WebPage",
			"@id": "https://moveroo.com.au/household-removals/",
			url: "https://moveroo.com.au/household-removals/",
			name: pageTitle,
			description: pageDescription,
			inLanguage: "en-AU",
			datePublished: publishedAt.toISOString(),
			dateModified: updatedAt.toISOString(),
			isPartOf: {
				"@id": "https://moveroo.com.au/#website",
			},
			about: {
				"@id": "https://moveroo.com.au/household-removals/#service",
			},
		},
		{
			"@type": "Service",
			"@id": "https://moveroo.com.au/household-removals/#service",
			name: "Household removals coordination",
			serviceType: "Household removals",
			description: pageDescription,
			provider: {
				"@id": "https://moveroo.com.au/#organization",
			},
			areaServed: {
				"@type": "Country",
				name: "Australia",
			},
		},
		{
			"@type": "FAQPage",
			"@id": "https://moveroo.com.au/household-removals/#faq",
			mainEntity: faqItems.map((faq) => ({
				"@type": "Question",
				name: faq.question,
				acceptedAnswer: {
					"@type": "Answer",
					text: faq.answer,
				},
			})),
		},
	],
};
---

<Layout
	title={pageTitle}
	description={pageDescription}
	canonical="https://moveroo.com.au/household-removals/"
	ogImage="https://moveroo.com.au/og-services.png"
>
	<Fragment slot="head">
		<meta property="article:published_time" content={publishedAt.toISOString()} />
		<meta property="article:modified_time" content={updatedAt.toISOString()} />
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
	</Fragment>

	<section class="relative overflow-hidden bg-slate-950 py-24 text-white md:py-32">
		<div
			class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(16,185,129,0.24),_transparent_30%),linear-gradient(135deg,_#052e2b_0%,_#0f172a_48%,_#111827_100%)]"
		>
		</div>
		<div class="route-grid absolute inset-0 opacity-25"></div>

		<div class="relative mx-auto max-w-6xl px-6">
			<div class="grid gap-14 lg:grid-cols-[minmax(0,1.04fr)_minmax(22rem,0.96fr)] lg:items-center">
				<div class="motion-rise">
					<p class="section-kicker text-emerald-300">Household removals</p>
					<h1
						class="section-title mt-6 max-w-3xl text-5xl font-semibold leading-[0.95] text-balance md:text-7xl"
					>
						Plan the household move before the moving parts multiply.
					</h1>
					<p class="mt-7 max-w-2xl text-lg leading-relaxed text-slate-300 md:text-xl">
						Moveroo helps coordinate apartment, home, regional and interstate household removals
						around the route, inventory, access, timing and extra support the job actually needs.
					</p>

					<div class="motion-rise motion-rise-delay-1 mt-10 flex flex-wrap gap-4">
						<a
							class="inline-flex items-center justify-center rounded-full bg-emerald-500 px-6 py-3 text-sm font-semibold text-slate-950 shadow-lg shadow-emerald-950/30 transition hover:bg-emerald-400 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-300"
							href={site.destinations.householdQuote}
							target="_blank"
							rel="noopener noreferrer"
						>
							Start a household quote
						</a>
						<a
							class="inline-flex items-center justify-center rounded-full border border-white/20 px-6 py-3 text-sm font-semibold text-white transition hover:border-emerald-300 hover:bg-white/5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-300"
							href="/services/"
						>
							Compare service paths
						</a>
					</div>
				</div>

				<div
					class="motion-rise motion-rise-delay-2 rounded-[2rem] border border-white/10 bg-white/8 p-6 shadow-[0_30px_80px_-40px_rgba(2,6,23,0.8)] backdrop-blur-sm md:p-8"
				>
					<p class="section-kicker text-emerald-300">First brief</p>
					<h2 class="mt-5 text-3xl font-semibold tracking-tight text-white">
						What to include before quoting
					</h2>
					<ul class="mt-6 grid gap-3 text-sm leading-relaxed text-slate-300">
						{
							planningDetails.map((item) => (
								<li class="flex items-start gap-3">
									<span class="mt-1.5 h-2.5 w-2.5 rounded-full bg-emerald-400" aria-hidden="true" />
									<span>{item}</span>
								</li>
							))
						}
					</ul>
				</div>
			</div>
		</div>
	</section>

	<section class="border-b border-slate-200 bg-white py-24 dark:border-slate-800 dark:bg-slate-900">
		<div class="mx-auto max-w-6xl px-6">
			<div
				class="grid gap-12 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start lg:gap-16"
			>
				<div class="motion-rise lg:sticky lg:top-28">
					<p class="section-kicker">Best Fit</p>
					<h2
						class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
					>
						Use the household lane when people, furniture and access are the main job.
					</h2>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
						Household moves need more than a pickup and delivery suburb. Inventory, access, route,
						timing and service extras all change the pathway.
					</p>
				</div>

				<div class="motion-rise motion-rise-delay-1 grid gap-5">
					{
						moveTypes.map((item) => (
							<article class="rounded-[1.75rem] border border-slate-200 bg-slate-50 px-6 py-6 shadow-sm dark:border-slate-800 dark:bg-slate-950/40">
								<h3 class="text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">
									{item.label}
								</h3>
								<p class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
									{item.text}
								</p>
							</article>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<section class="bg-slate-50 py-24 dark:bg-slate-950/40">
		<div class="mx-auto max-w-6xl px-6">
			<div class="motion-rise max-w-3xl">
				<p class="section-kicker">Service Pathways</p>
				<h2
					class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
				>
					Backloading-style, dedicated, or added support.
				</h2>
				<p class="mt-6 text-base leading-relaxed text-slate-600 dark:text-slate-400">
					Moveroo can help shape the quote around the route and requirements instead of forcing
					every move into one generic removals path.
				</p>
			</div>

			<div class="motion-rise motion-rise-delay-1 mt-10 grid gap-5 lg:grid-cols-3">
				{
					serviceOptions.map((item) => (
						<article class="rounded-[1.75rem] border border-slate-200 bg-white px-6 py-6 shadow-sm dark:border-slate-800 dark:bg-slate-900/75">
							<h3 class="text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">
								{item.label}
							</h3>
							<p class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
								{item.text}
							</p>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="border-y border-slate-200 bg-white py-24 dark:border-slate-800 dark:bg-slate-900">
		<div class="mx-auto max-w-6xl px-6">
			<div
				class="grid gap-12 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start lg:gap-16"
			>
				<div class="motion-rise lg:sticky lg:top-28">
					<p class="section-kicker">When The Move Has Extras</p>
					<h2
						class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
					>
						Household moves often bring another service with them.
					</h2>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
						If the move also includes a car, motorcycle, storage handoff or fragile item, include
						that in the household brief so the plan can account for it early.
					</p>
				</div>

				<div
					class="motion-rise motion-rise-delay-1 overflow-hidden rounded-[2rem] border border-slate-200 bg-slate-50 shadow-[0_28px_80px_-48px_rgba(15,23,42,0.24)] dark:border-slate-800 dark:bg-slate-950/35 dark:shadow-black/40"
				>
					<article class="border-b border-slate-200 px-6 py-7 dark:border-slate-800 md:px-8">
						<h3 class="text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">
							Household + vehicle relocation
						</h3>
						<p class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
							Moveroo can coordinate same-day pickup for household goods and a vehicle where
							provider availability and job details support it. Delivery timing is planned
							realistically for each service.
						</p>
						<a
							href="/household-vehicle-relocation/"
							class="site-text-action mt-5 gap-2 text-sm font-semibold text-emerald-700 transition hover:text-emerald-900 dark:text-emerald-400 dark:hover:text-emerald-300"
						>
							<span>Plan a combined move</span>
							<span aria-hidden="true">&rarr;</span>
						</a>
					</article>
					<article class="px-6 py-7 md:px-8">
						<h3 class="text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">
							Move protection and quote clarity
						</h3>
						<p class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
							The clearer the route, inventory and access notes are, the easier it is to match the
							move to a suitable pathway and explain what can affect the quote.
						</p>
						<a
							href="/how-moveroo-protects-your-move/"
							class="site-text-action mt-5 gap-2 text-sm font-semibold text-emerald-700 transition hover:text-emerald-900 dark:text-emerald-400 dark:hover:text-emerald-300"
						>
							<span>See how Moveroo protects your move</span>
							<span aria-hidden="true">&rarr;</span>
						</a>
					</article>
				</div>
			</div>
		</div>
	</section>

	<section class="bg-slate-50 py-24 dark:bg-slate-900" id="faq">
		<div class="mx-auto max-w-6xl px-6">
			<div
				class="grid gap-12 lg:grid-cols-[minmax(0,0.82fr)_minmax(0,1.18fr)] lg:items-start lg:gap-16"
			>
				<div class="motion-rise lg:sticky lg:top-28">
					<p class="section-kicker">FAQ</p>
					<h2
						class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
					>
						Household removals questions, answered before you start.
					</h2>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
						These answers help route the enquiry. The final quote depends on route, inventory,
						timing, access and provider fit.
					</p>
				</div>

				<div class="motion-rise motion-rise-delay-1 grid gap-4">
					{
						faqItems.map((faq) => (
							<details class="group rounded-[1.5rem] border border-slate-200 bg-white px-6 py-5 shadow-sm dark:border-slate-800 dark:bg-slate-950/55">
								<summary class="flex cursor-pointer list-none items-start justify-between gap-6">
									<h3 class="text-lg font-semibold leading-relaxed text-slate-900 dark:text-white">
										{faq.question}
									</h3>
									<span class="mt-1 text-2xl leading-none text-emerald-600 transition group-open:rotate-45 dark:text-emerald-400">
										+
									</span>
								</summary>
								<p class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
									{faq.answer}
								</p>
							</details>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<QuoteCta
		title="Ready to plan the household move?"
		subtitle="Share the route, inventory, access notes, timing and any extra support needs so Moveroo can shape the right quote pathway."
		ctaPrimaryLabel="Start a household quote"
		ctaPrimaryHref={site.destinations.householdQuote}
		ctaSecondaryLabel="Request a callback"
		ctaSecondaryHref={site.destinations.contactPage}
	/>
</Layout>
