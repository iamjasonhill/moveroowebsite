---
import Layout from "../layouts/Layout.astro";
import QuoteCta from "../components/sections/QuoteCta.astro";
import { site } from "../config/site";

const publishedAt = new Date("2026-05-24T00:00:00+10:00");
const updatedAt = publishedAt;

const pageTitle = "Interstate Removalists Australia | Moveroo";
const pageDescription =
	"Find an interstate removalist that fits your dates, access and move details. Moveroo helps compare interstate moving options across Australia.";

const firstBriefItems = [
	"Pickup and delivery suburbs",
	"Inventory and bulky items",
	"Stairs, lifts, parking and loading access",
	"Rental key handback or settlement dates",
	"Storage access or delayed delivery needs",
	"Whether a car or motorcycle also needs transport",
];

const optionCards = [
	{
		title: "Backload option",
		text: "Can work well when your dates have some room and your move can fit a truck already heading the right way.",
		href: "/backloading-removals/",
		cta: "See how backloading works",
	},
	{
		title: "Dedicated move",
		text: "Better suited when timing, access or service needs call for a more structured plan.",
	},
	{
		title: "Added support",
		text: "Helpful when packing, fragile items, storage, extra stops or building access need to be considered before booking.",
	},
];

const timingItems = [
	"Rental key handback",
	"Property settlement",
	"Storage access",
	"Building or loading dock rules",
	"Pickup and delivery windows",
	"Dates that will not work",
];

const quoteFactors = [
	"Route and access at both addresses",
	"Inventory, bulky items and fragile items",
	"Preferred dates and timing limits",
	"Backload option or dedicated move",
	"Packing, storage, extra stops or staged delivery",
	"Whether a vehicle also needs transport",
];

const relatedServices = [
	{
		title: "Household removals",
		text: "Still sorting out the whole move? Household removals covers access, packing, storage and timing.",
		href: "/household-removals/",
		cta: "Start with household removals",
	},
	{
		title: "Backloading removals",
		text: "If your dates can move a little, backloading may be worth checking.",
		href: "/backloading-removals/",
		cta: "Check backloading removals",
	},
	{
		title: "Removals and storage",
		text: "Helpful when settlement, lease or redelivery dates do not line up.",
		href: "/removals-and-storage/",
		cta: "Plan storage timing",
	},
	{
		title: "How Moveroo protects your move",
		text: "Before you book, check how deposits, cover questions and support are handled.",
		href: "/how-moveroo-protects-your-move/",
		cta: "Check before booking",
	},
];

const faqItems = [
	{
		question: "Does Moveroo do the interstate move?",
		answer:
			"Moveroo helps compare and coordinate suitable removalist options. The physical move is completed by the removalist matched to the job.",
	},
	{
		question: "Should I choose a backload option or a dedicated move?",
		answer:
			"A backload option can work when your dates can fit the truck's schedule. A dedicated move can make more sense when timing, access or service needs require a more structured plan.",
	},
	{
		question: "What dates should I tell Moveroo about?",
		answer:
			"Tell Moveroo about rental key handback, settlement, storage access, building rules, preferred windows and any dates that will not work.",
	},
	{
		question: "Can storage or packing be included?",
		answer:
			"Yes. Include storage, packing, fragile items, extra stops and access notes when you request the quote so the right option can be checked early.",
	},
	{
		question: "What if I also need to move a car?",
		answer:
			"Let Moveroo know early if the move also includes a car or motorcycle. The household move and vehicle transport can then be planned around the same dates where possible.",
	},
];

const structuredData = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "WebPage",
			"@id": "https://moveroo.com.au/interstate-removalists/",
			url: "https://moveroo.com.au/interstate-removalists/",
			name: pageTitle,
			description: pageDescription,
			inLanguage: "en-AU",
			datePublished: publishedAt.toISOString(),
			dateModified: updatedAt.toISOString(),
			isPartOf: {
				"@id": "https://moveroo.com.au/#website",
			},
			about: {
				"@id": "https://moveroo.com.au/interstate-removalists/#service",
			},
		},
		{
			"@type": "Service",
			"@id": "https://moveroo.com.au/interstate-removalists/#service",
			name: "Interstate removalists coordination",
			serviceType: "Interstate removals",
			description: pageDescription,
			provider: {
				"@id": "https://moveroo.com.au/#organization",
			},
			areaServed: {
				"@type": "Country",
				name: "Australia",
			},
		},
		{
			"@type": "FAQPage",
			"@id": "https://moveroo.com.au/interstate-removalists/#faq",
			mainEntity: faqItems.map((faq) => ({
				"@type": "Question",
				name: faq.question,
				acceptedAnswer: {
					"@type": "Answer",
					text: faq.answer,
				},
			})),
		},
	],
};
---

<Layout
	title={pageTitle}
	description={pageDescription}
	canonical="https://moveroo.com.au/interstate-removalists/"
	ogImage="https://moveroo.com.au/og-services.png"
>
	<Fragment slot="head">
		<meta property="article:published_time" content={publishedAt.toISOString()} />
		<meta property="article:modified_time" content={updatedAt.toISOString()} />
		<script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
	</Fragment>

	<section class="relative overflow-hidden bg-slate-950 py-24 text-white md:py-32">
		<div
			class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(16,185,129,0.24),_transparent_30%),linear-gradient(135deg,_#052e2b_0%,_#0f172a_48%,_#111827_100%)]"
		>
		</div>
		<div class="route-grid absolute inset-0 opacity-25"></div>

		<div class="relative mx-auto box-border w-full max-w-6xl px-6">
			<div class="grid gap-14 lg:grid-cols-[minmax(0,1.02fr)_minmax(22rem,0.98fr)] lg:items-center">
				<div class="motion-rise w-full min-w-0 max-w-full">
					<p class="section-kicker text-emerald-300">Interstate removalists</p>
					<h1
						class="section-title mt-6 max-w-4xl text-3xl font-semibold leading-[1.08] text-balance min-[420px]:text-4xl sm:text-5xl md:text-7xl"
					>
						Find an interstate removalist that fits your dates, access and move details.
					</h1>
					<p class="mt-7 max-w-2xl text-lg leading-relaxed text-slate-300 md:text-xl">
						Moveroo helps compare interstate removalist options around the details that matter:
						where you are moving, what needs to go, what access is like and which dates you need to
						work around.
					</p>

					<div
						class="motion-rise motion-rise-delay-1 mt-10 grid w-full gap-3 sm:flex sm:flex-wrap sm:gap-4"
					>
						<a
							class="inline-flex min-h-12 items-center justify-center rounded-full bg-emerald-500 px-6 py-3 text-center text-sm font-semibold text-slate-950 shadow-lg shadow-emerald-950/30 transition hover:bg-emerald-400 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-300 sm:min-h-0"
							href={site.destinations.householdQuote}
							target="_blank"
							rel="noopener noreferrer"
						>
							Start an interstate moving quote
						</a>
						<a
							class="inline-flex min-h-12 items-center justify-center rounded-full border border-white/20 px-6 py-3 text-center text-sm font-semibold text-white transition hover:border-emerald-300 hover:bg-white/5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-300 sm:min-h-0"
							href={site.destinations.contactPage}
						>
							Request a callback
						</a>
					</div>
				</div>

				<div
					class="motion-rise motion-rise-delay-2 w-full min-w-0 max-w-full rounded-[2rem] border border-white/10 bg-white/8 p-6 shadow-[0_30px_80px_-40px_rgba(2,6,23,0.8)] backdrop-blur-sm md:p-8"
				>
					<p class="section-kicker text-emerald-300">First brief</p>
					<h2 class="mt-5 text-3xl font-semibold tracking-tight text-white">
						Details worth sharing early
					</h2>
					<ul class="mt-6 grid gap-3 text-sm leading-relaxed text-slate-300">
						{
							firstBriefItems.map((item) => (
								<li class="flex items-start gap-3">
									<span class="mt-1.5 h-2.5 w-2.5 rounded-full bg-emerald-400" aria-hidden="true" />
									<span>{item}</span>
								</li>
							))
						}
					</ul>
				</div>
			</div>
		</div>
	</section>

	<section class="border-b border-slate-200 bg-white py-24 dark:border-slate-800 dark:bg-slate-900">
		<div class="mx-auto box-border w-full max-w-6xl px-6">
			<div
				class="grid gap-12 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start lg:gap-16"
			>
				<div class="motion-rise lg:sticky lg:top-28">
					<p class="section-kicker">Choosing The Option</p>
					<h2
						class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
					>
						The right interstate removalist option depends on the job.
					</h2>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
						Interstate moves can look simple on paper, then turn into a puzzle once access, dates,
						storage or inventory are added. Moveroo helps compare options before you book.
					</p>
				</div>

				<div class="motion-rise motion-rise-delay-1 grid gap-5">
					{
						optionCards.map((item) => (
							<article class="rounded-[1.75rem] border border-slate-200 bg-slate-50 px-6 py-6 shadow-sm dark:border-slate-800 dark:bg-slate-950/40">
								<h3 class="text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">
									{item.title}
								</h3>
								<p class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
									{item.text}
								</p>
								{item.href && (
									<a
										href={item.href}
										class="site-text-action mt-5 gap-2 text-sm font-semibold text-emerald-700 transition hover:text-emerald-900 dark:text-emerald-400 dark:hover:text-emerald-300"
									>
										<span>{item.cta}</span>
										<span aria-hidden="true">&rarr;</span>
									</a>
								)}
							</article>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<section class="bg-slate-50 py-24 dark:bg-slate-950/40">
		<div class="mx-auto box-border w-full max-w-6xl px-6">
			<div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(0,1fr)] lg:items-start">
				<div class="motion-rise">
					<p class="section-kicker">Dates That Need To Line Up</p>
					<h2
						class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
					>
						Rentals, settlements and storage dates can shape the move.
					</h2>
					<p class="mt-6 text-base leading-relaxed text-slate-600 dark:text-slate-400">
						If a truck schedule does not work around the dates you are locked into, it is not the
						right option. Tell Moveroo what the move needs to work around before you book.
					</p>
					<p class="mt-5 text-base leading-relaxed text-slate-600 dark:text-slate-400">
						If furniture needs to be held between pickup and redelivery, the{" "}
						<a
							href="/removals-and-storage/"
							class="font-semibold text-emerald-700 underline decoration-emerald-300 underline-offset-4 transition hover:text-emerald-900 dark:text-emerald-400 dark:decoration-emerald-600 dark:hover:text-emerald-300"
						>
							removals and storage page
						</a>
						{" "}covers what Moveroo needs to check.
					</p>
					<p class="mt-5 text-base leading-relaxed text-slate-600 dark:text-slate-400">
						Before you book, it is worth checking{" "}
						<a
							href="/how-moveroo-protects-your-move/"
							class="font-semibold text-emerald-700 underline decoration-emerald-300 underline-offset-4 transition hover:text-emerald-900 dark:text-emerald-400 dark:decoration-emerald-600 dark:hover:text-emerald-300"
						>
							how Moveroo handles deposits, cover questions and support
						</a>
						.
					</p>
				</div>

				<div class="motion-rise motion-rise-delay-1 grid gap-3">
					{
						timingItems.map((item) => (
							<div class="flex items-start gap-3 rounded-2xl border border-slate-200 bg-white px-5 py-4 text-sm font-semibold text-slate-700 shadow-sm dark:border-slate-800 dark:bg-slate-900/75 dark:text-slate-300">
								<span class="mt-1.5 h-2.5 w-2.5 rounded-full bg-emerald-500" aria-hidden="true" />
								<span>{item}</span>
							</div>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<section class="border-y border-slate-200 bg-white py-24 dark:border-slate-800 dark:bg-slate-900">
		<div class="mx-auto box-border w-full max-w-6xl px-6">
			<div
				class="grid gap-12 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start lg:gap-16"
			>
				<div class="motion-rise lg:sticky lg:top-28">
					<p class="section-kicker">Quote Details</p>
					<h2
						class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
					>
						What affects the quote.
					</h2>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
						We avoid guessing from the route alone. These details help Moveroo check interstate
						removalist options against the real job.
					</p>
				</div>

				<div class="motion-rise motion-rise-delay-1 grid gap-4">
					{
						quoteFactors.map((item) => (
							<article class="rounded-[1.5rem] border border-slate-200 bg-slate-50 px-6 py-5 shadow-sm dark:border-slate-800 dark:bg-slate-950/40">
								<p class="text-base font-semibold leading-relaxed text-slate-800 dark:text-slate-200">
									{item}
								</p>
							</article>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<section class="bg-slate-50 py-24 dark:bg-slate-950/40">
		<div class="mx-auto box-border w-full max-w-6xl px-6">
			<div
				class="grid gap-12 rounded-[2rem] border border-slate-200 bg-white px-6 py-8 shadow-sm dark:border-slate-800 dark:bg-slate-900/75 md:px-8 md:py-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start"
			>
				<div class="motion-rise">
					<p class="section-kicker">Moving A Vehicle Too?</p>
					<h2
						class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
					>
						Let us know if a car or motorcycle is part of the move.
					</h2>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
						Household goods and vehicle transport are usually handled by different provider types,
						but Moveroo can help plan the pickup timing around the same dates where possible.
					</p>
					<p class="mt-5 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
						If the vehicle is the main thing being moved, the{" "}
						<a
							href="/interstate-car-transport/"
							class="font-semibold text-emerald-700 underline decoration-emerald-300 underline-offset-4 transition hover:text-emerald-900 dark:text-emerald-400 dark:decoration-emerald-600 dark:hover:text-emerald-300"
						>
							interstate car transport page
						</a>
						{" "}is the better place to check carrier options.
					</p>
				</div>

				<div
					class="motion-rise motion-rise-delay-1 rounded-[1.75rem] border border-slate-200 bg-slate-50 p-6 dark:border-slate-800 dark:bg-slate-950/40 md:p-8"
				>
					<h3 class="text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">
						Household + vehicle relocation
					</h3>
					<p class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
						If the interstate move includes furniture, cartons and a vehicle, let us know early so
						the timing can be checked together.
					</p>
					<a
						href="/household-vehicle-relocation/"
						class="site-text-action mt-5 gap-2 text-sm font-semibold text-emerald-700 transition hover:text-emerald-900 dark:text-emerald-400 dark:hover:text-emerald-300"
					>
						<span>Plan a household and vehicle move</span>
						<span aria-hidden="true">&rarr;</span>
					</a>
				</div>
			</div>
		</div>
	</section>

	<section class="border-y border-slate-200 bg-white py-24 dark:border-slate-800 dark:bg-slate-900">
		<div class="mx-auto box-border w-full max-w-6xl px-6">
			<div class="motion-rise max-w-3xl">
				<p class="section-kicker">Related Services</p>
				<h2
					class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
				>
					Need to check something else?
				</h2>
				<p class="mt-6 text-base leading-relaxed text-slate-600 dark:text-slate-400">
					These are the most useful next steps if the move involves more than a straight interstate
					removal.
				</p>
			</div>

			<div class="motion-rise motion-rise-delay-1 mt-10 grid gap-5 md:grid-cols-3">
				{
					relatedServices.map((item) => (
						<article class="rounded-[1.75rem] border border-slate-200 bg-slate-50 p-6 shadow-sm dark:border-slate-800 dark:bg-slate-950/40">
							<h3 class="text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">
								{item.title}
							</h3>
							<p class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
								{item.text}
							</p>
							<a
								href={item.href}
								class="site-text-action mt-5 gap-2 text-sm font-semibold text-emerald-700 transition hover:text-emerald-900 dark:text-emerald-400 dark:hover:text-emerald-300"
							>
								<span>{item.cta}</span>
								<span aria-hidden="true">&rarr;</span>
							</a>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="bg-slate-50 py-24 dark:bg-slate-900" id="faq">
		<div class="mx-auto box-border w-full max-w-6xl px-6">
			<div
				class="grid gap-12 lg:grid-cols-[minmax(0,0.82fr)_minmax(0,1.18fr)] lg:items-start lg:gap-16"
			>
				<div class="motion-rise lg:sticky lg:top-28">
					<p class="section-kicker">FAQ</p>
					<h2
						class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
					>
						Interstate removalist questions, answered plainly.
					</h2>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
						These answers help set expectations before you choose an option or pay a deposit.
					</p>
				</div>

				<div class="motion-rise motion-rise-delay-1 grid gap-4">
					{
						faqItems.map((faq) => (
							<details class="group rounded-[1.5rem] border border-slate-200 bg-white px-6 py-5 shadow-sm dark:border-slate-800 dark:bg-slate-950/55">
								<summary class="flex cursor-pointer list-none items-start justify-between gap-6">
									<h3 class="text-lg font-semibold leading-relaxed text-slate-900 dark:text-white">
										{faq.question}
									</h3>
									<span class="mt-1 text-2xl leading-none text-emerald-600 transition group-open:rotate-45 dark:text-emerald-400">
										+
									</span>
								</summary>
								<p class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
									{faq.answer}
								</p>
							</details>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<QuoteCta
		title="Ready to check interstate moving options?"
		subtitle="Share the route, inventory, access notes and dates Moveroo needs to work around."
		ctaPrimaryLabel="Start an interstate moving quote"
		ctaPrimaryHref={site.destinations.householdQuote}
		ctaSecondaryLabel="Request a callback"
		ctaSecondaryHref={site.destinations.contactPage}
	/>
</Layout>
