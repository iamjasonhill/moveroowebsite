---
import Layout from "../layouts/Layout.astro";
import QuoteCta from "../components/sections/QuoteCta.astro";
import { site } from "../config/site";

const publishedAt = new Date("2026-05-25T00:00:00+10:00");
const updatedAt = publishedAt;

const pageTitle = "Interstate Car Transport Australia | Moveroo";
const pageDescription =
	"Moving a car interstate? Moveroo helps you compare door-to-door and depot options, transit times, personal-item rules and carrier requirements before you book.";

const quoteDetails = [
	"Pickup and delivery suburbs",
	"Vehicle make, model and type",
	"Whether it runs, rolls and steers",
	"Door-to-door or depot-to-depot options",
	"Whether personal items need to stay in the car",
	"Pickup access, low clearance, modifications or roof racks",
];

const comparisonFactors = [
	{
		title: "Price",
		text: "Depot-to-depot is cheaper than door-to-door within the same carrier's quote options. The cheapest overall option can still depend on which carrier is available for the route.",
	},
	{
		title: "Transit time",
		text: "Each option shows the latest transit time information available to Moveroo at the time. Sometimes the price difference is small, but one option may take noticeably longer.",
	},
	{
		title: "Carrier requirements",
		text: "Running condition, pickup access, personal items and vehicle type can all change which carrier options make sense.",
	},
];

const priceExamples = [
	{
		route: "Doreen VIC to Currambine WA",
		vehicle: "Hyundai Kona",
		door: "$2,438.41",
		depot: "$1,950.78",
		difference: "$487.63",
		transit: "10 days",
	},
	{
		route: "Ropes Crossing NSW to Wavell Heights QLD",
		vehicle: "Mazda MX-5",
		door: "$1,499.73",
		depot: "$1,012.11",
		difference: "$487.62",
		transit: "4 days",
	},
	{
		route: "Bondi NSW to Subiaco WA",
		vehicle: "Toyota Corolla",
		door: "$2,615.17",
		depot: "$2,127.55",
		difference: "$487.62",
		transit: "11 days",
	},
];

const supportCards = [
	{
		title: "Non-running cars",
		text: "If the vehicle does not run, roll or steer, include that in the quote request. The non-running car transport page explains what details matter before pricing.",
		href: "/non-running-car-transport/",
		cta: "Read the non-running guide",
	},
	{
		title: "Personal items",
		text: "If you want to leave items in the car, mention it in the quote request. Not every carrier allows it, so it is something to check before booking.",
	},
	{
		title: "Motorcycles",
		text: "Moving a motorcycle instead of a car? Include the make, model, pickup and delivery access, and any timing limits in the quote request.",
	},
];

const preparationItems = [
	"Make sure the pickup and delivery details are correct.",
	"Tell us if access is tight, steep, gated or hard for a truck.",
	"Include low clearance, roof racks, modifications or anything unusual.",
	"Keep the car available for the agreed pickup window.",
	"The carrier completes a vehicle inspection at pickup and delivery.",
];

const faqItems = [
	{
		question: "Is door-to-door car transport available?",
		answer:
			"Yes. Door-to-door is available. Depot-to-depot can still be worth checking because it is cheaper than door-to-door within the same carrier's quote options.",
	},
	{
		question: "Why is depot-to-depot cheaper?",
		answer:
			"Depot-to-depot removes the residential pickup and delivery work from that carrier's job. The cheapest overall quote can still depend on which carriers are available for the route.",
	},
	{
		question: "Can I leave personal items in the car?",
		answer:
			"If you want to leave items in the car, mention it in the quote request. Not every carrier allows it, so it is something to check before booking.",
	},
	{
		question: "Can Moveroo help with a non-running car?",
		answer:
			"Some carriers can move non-running vehicles, but the quote request needs to say whether the vehicle runs, rolls and steers so the loading requirements can be checked early.",
	},
	{
		question: "Will I get tracking?",
		answer:
			"Tracking depends on the carrier. At a minimum, you will receive a phone number and tracking code. Some carriers also provide a tracking link that updates when the vehicle reaches a depot or is scheduled onto a trip. You can also contact Moveroo to request a tracking update.",
	},
	{
		question: "What if the car move is part of a household move?",
		answer:
			"If the car move is part of a larger household move, let us know when you speak with Moveroo. The household move and vehicle transport may need different carriers, but the timing can still be planned together.",
	},
];

const structuredData = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "WebPage",
			"@id": "https://moveroo.com.au/interstate-car-transport/",
			url: "https://moveroo.com.au/interstate-car-transport/",
			name: pageTitle,
			description: pageDescription,
			inLanguage: "en-AU",
			datePublished: publishedAt.toISOString(),
			dateModified: updatedAt.toISOString(),
			isPartOf: {
				"@id": "https://moveroo.com.au/#website",
			},
			about: {
				"@id": "https://moveroo.com.au/interstate-car-transport/#service",
			},
		},
		{
			"@type": "Service",
			"@id": "https://moveroo.com.au/interstate-car-transport/#service",
			name: "Interstate car transport coordination",
			serviceType: "Interstate car transport",
			description: pageDescription,
			provider: {
				"@id": "https://moveroo.com.au/#organization",
			},
			areaServed: {
				"@type": "Country",
				name: "Australia",
			},
		},
		{
			"@type": "FAQPage",
			"@id": "https://moveroo.com.au/interstate-car-transport/#faq",
			mainEntity: faqItems.map((faq) => ({
				"@type": "Question",
				name: faq.question,
				acceptedAnswer: {
					"@type": "Answer",
					text: faq.answer,
				},
			})),
		},
	],
};
---

<Layout
	title={pageTitle}
	description={pageDescription}
	canonical="https://moveroo.com.au/interstate-car-transport/"
	ogImage="https://moveroo.com.au/og-moving-cars.png"
>
	<Fragment slot="head">
		<meta property="article:published_time" content={publishedAt.toISOString()} />
		<meta property="article:modified_time" content={updatedAt.toISOString()} />
		<script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
	</Fragment>

	<section class="relative overflow-hidden bg-slate-950 py-20 text-white md:py-32">
		<div
			class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(16,185,129,0.22),_transparent_30%),linear-gradient(135deg,_#041f1d_0%,_#0f172a_48%,_#111827_100%)]"
		>
		</div>
		<div class="route-grid absolute inset-0 opacity-25"></div>

		<div class="relative mx-auto box-border w-full max-w-6xl px-6">
			<div class="grid gap-14 lg:grid-cols-[minmax(0,1.02fr)_minmax(22rem,0.98fr)] lg:items-center">
				<div class="motion-rise w-full min-w-0 max-w-full">
					<p class="section-kicker text-emerald-300">Interstate car transport</p>
					<h1
						class="section-title mt-6 max-w-4xl text-4xl font-semibold leading-[1.02] text-balance md:text-7xl"
					>
						Move your car interstate with the right transport option.
					</h1>
					<p class="mt-7 max-w-2xl text-lg leading-relaxed text-slate-300 md:text-xl">
						Moveroo helps you compare carrier options for interstate car transport, including
						door-to-door and depot-to-depot pricing, transit times and the requirements that affect
						the quote.
					</p>

					<div class="motion-rise motion-rise-delay-1 mt-10 grid w-full gap-3 sm:flex sm:flex-wrap sm:gap-4">
						<a
							class="inline-flex min-h-12 items-center justify-center rounded-full bg-emerald-500 px-6 py-3 text-center text-sm font-semibold text-slate-950 shadow-lg shadow-emerald-950/30 transition hover:bg-emerald-400 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-300 sm:min-h-0"
							href={site.destinations.vehicleQuote}
							target="_blank"
							rel="noopener noreferrer"
						>
							Start a vehicle transport quote
						</a>
						<a
							class="inline-flex min-h-12 items-center justify-center rounded-full border border-white/20 px-6 py-3 text-center text-sm font-semibold text-white transition hover:border-emerald-300 hover:bg-white/5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-300 sm:min-h-0"
							href={site.destinations.contactPage}
						>
							Request a callback
						</a>
					</div>
				</div>

				<div
					class="motion-rise motion-rise-delay-2 w-full min-w-0 max-w-full rounded-[2rem] border border-white/10 bg-white/8 p-6 shadow-[0_30px_80px_-40px_rgba(2,6,23,0.8)] backdrop-blur-sm md:p-8"
				>
					<p class="section-kicker text-emerald-300">Quote request</p>
					<h2 class="mt-5 text-3xl font-semibold tracking-tight text-white">
						Details worth getting right
					</h2>
					<ul class="mt-6 grid gap-3 text-sm leading-relaxed text-slate-300">
						{
							quoteDetails.map((item) => (
								<li class="flex items-start gap-3">
									<span class="mt-1.5 h-2.5 w-2.5 rounded-full bg-emerald-400" aria-hidden="true" />
									<span>{item}</span>
								</li>
							))
						}
					</ul>
				</div>
			</div>
		</div>
	</section>

	<section class="border-b border-slate-200 bg-white py-24 dark:border-slate-800 dark:bg-slate-900">
		<div class="mx-auto box-border w-full max-w-6xl px-6">
			<div
				class="grid gap-12 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start lg:gap-16"
			>
				<div class="motion-rise lg:sticky lg:top-28">
					<p class="section-kicker">Details that change the quote</p>
					<h2
						class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
					>
						The quote should match the actual job.
					</h2>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
						A drivable sedan between two metro depots is not the same job as a non-running ute
						collected from a narrow street. The quote needs the right details so the carrier can
						price the actual job.
					</p>
				</div>

				<div class="motion-rise motion-rise-delay-1 grid gap-5">
					{
						supportCards.map((item) => (
							<article class="rounded-[1.75rem] border border-slate-200 bg-slate-50 px-6 py-6 shadow-sm dark:border-slate-800 dark:bg-slate-950/40">
								<h3 class="text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">
									{item.title}
								</h3>
								<p class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
									{item.text}
								</p>
								{item.href && (
									<a
										href={item.href}
										class="site-text-action mt-5 gap-2 text-sm font-semibold text-emerald-700 transition hover:text-emerald-900 dark:text-emerald-400 dark:hover:text-emerald-300"
									>
										<span>{item.cta}</span>
										<span aria-hidden="true">&rarr;</span>
									</a>
								)}
							</article>
						))
					}
					<article class="rounded-[1.75rem] border border-slate-200 bg-slate-50 px-6 py-6 shadow-sm dark:border-slate-800 dark:bg-slate-950/40">
						<h3 class="text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">
							Enclosed transport
						</h3>
						<p class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
							Enclosed transport may be available on some routes. Email us after submitting a
							standard quote to discuss.
						</p>
					</article>
				</div>
			</div>
		</div>
	</section>

	<section class="bg-slate-50 py-24 dark:bg-slate-950/40">
		<div class="mx-auto box-border w-full max-w-6xl px-6">
			<div class="motion-rise max-w-3xl">
				<p class="section-kicker">Carrier options</p>
				<h2
					class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
				>
					Compare the carrier options before you choose.
				</h2>
				<p class="mt-6 text-base leading-relaxed text-slate-600 dark:text-slate-400">
					Where more than one carrier option is available, compare the price, pickup and delivery
					type, transit time and requirements before choosing. A lower price is not always the better
					option if the transit time is much longer.
				</p>
			</div>

			<div class="motion-rise motion-rise-delay-1 mt-10 grid gap-5 md:grid-cols-3">
				{
					comparisonFactors.map((item) => (
						<article class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900/75">
							<h3 class="text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">
								{item.title}
							</h3>
							<p class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
								{item.text}
							</p>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="border-y border-slate-200 bg-white py-24 dark:border-slate-800 dark:bg-slate-900">
		<div class="mx-auto box-border w-full max-w-6xl px-6">
			<div class="motion-rise max-w-3xl">
				<p class="section-kicker">Door-to-door or depot-to-depot</p>
				<h2
					class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
				>
					Recent door-to-door and depot-to-depot examples.
				</h2>
				<p class="mt-6 text-base leading-relaxed text-slate-600 dark:text-slate-400">
					Depot-to-depot is cheaper than door-to-door within the same carrier's quote options. The
					cheapest overall quote can still depend on which carrier is available for the route.
				</p>
				<p class="mt-5 text-base leading-relaxed text-slate-600 dark:text-slate-400">
					These anonymised quote examples show how the pickup and delivery option can change the
					price. They are examples only, not a promise that the same difference will apply to every
					car move.
				</p>
				<p class="mt-5 text-base leading-relaxed text-slate-600 dark:text-slate-400">
					If you are mainly deciding between address pickup and depot handover, the{" "}
					<a
						href="/door-to-door-vs-depot-car-transport/"
						class="font-semibold text-emerald-700 underline decoration-emerald-300 underline-offset-4 transition hover:text-emerald-900 dark:text-emerald-400 dark:decoration-emerald-600 dark:hover:text-emerald-300"
					>
						door-to-door vs depot car transport page
					</a>
					{" "}explains what to check before choosing.
				</p>
			</div>

			<div class="motion-rise motion-rise-delay-1 mt-10 grid gap-4 md:hidden">
				{
					priceExamples.map((example) => (
						<article class="rounded-[1.5rem] border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-900/75">
							<h3 class="text-base font-semibold leading-snug text-slate-900 dark:text-white">
								{example.route}
							</h3>
							<p class="mt-1 text-sm text-slate-600 dark:text-slate-400">{example.vehicle}</p>
							<dl class="mt-5 grid gap-3 text-sm">
								<div class="flex items-start justify-between gap-4 border-t border-slate-200 pt-3 dark:border-slate-800">
									<dt class="text-slate-500 dark:text-slate-400">Door-to-door</dt>
									<dd class="font-semibold text-slate-900 dark:text-white">{example.door}</dd>
								</div>
								<div class="flex items-start justify-between gap-4 border-t border-slate-200 pt-3 dark:border-slate-800">
									<dt class="text-slate-500 dark:text-slate-400">Depot-to-depot</dt>
									<dd class="font-semibold text-slate-900 dark:text-white">{example.depot}</dd>
								</div>
								<div class="flex items-start justify-between gap-4 border-t border-slate-200 pt-3 dark:border-slate-800">
									<dt class="text-slate-500 dark:text-slate-400">Difference</dt>
									<dd class="font-semibold text-emerald-700 dark:text-emerald-400">
										{example.difference}
									</dd>
								</div>
								<div class="flex items-start justify-between gap-4 border-t border-slate-200 pt-3 dark:border-slate-800">
									<dt class="text-slate-500 dark:text-slate-400">Transit</dt>
									<dd class="font-semibold text-slate-900 dark:text-white">{example.transit}</dd>
								</div>
							</dl>
						</article>
					))
				}
			</div>

			<div
				class="motion-rise motion-rise-delay-1 mt-10 hidden overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm dark:border-slate-800 dark:bg-slate-900/75 md:block"
			>
				<div
					class="grid border-b border-slate-200 bg-slate-100 text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 dark:border-slate-800 dark:bg-slate-950/60 dark:text-slate-400 md:grid-cols-[minmax(0,1.15fr)_minmax(0,0.75fr)_repeat(4,minmax(0,0.62fr))]"
				>
					<div class="px-6 py-4">Route</div>
					<div class="border-t border-slate-200 px-6 py-4 dark:border-slate-800 md:border-l md:border-t-0">
						Vehicle
					</div>
					<div class="border-t border-slate-200 px-6 py-4 dark:border-slate-800 md:border-l md:border-t-0">
						Door-to-door
					</div>
					<div class="border-t border-slate-200 px-6 py-4 dark:border-slate-800 md:border-l md:border-t-0">
						Depot-to-depot
					</div>
					<div class="border-t border-slate-200 px-6 py-4 dark:border-slate-800 md:border-l md:border-t-0">
						Difference
					</div>
					<div class="border-t border-slate-200 px-6 py-4 dark:border-slate-800 md:border-l md:border-t-0">
						Transit
					</div>
				</div>
				{
					priceExamples.map((example) => (
						<div class="grid border-b border-slate-200 last:border-b-0 dark:border-slate-800 md:grid-cols-[minmax(0,1.15fr)_minmax(0,0.75fr)_repeat(4,minmax(0,0.62fr))]">
							<p class="px-6 py-5 text-sm font-semibold text-slate-900 dark:text-white">
								{example.route}
							</p>
							<p class="border-t border-slate-200 px-6 py-5 text-sm text-slate-600 dark:border-slate-800 dark:text-slate-400 md:border-l md:border-t-0">
								{example.vehicle}
							</p>
							<p class="border-t border-slate-200 px-6 py-5 text-sm text-slate-600 dark:border-slate-800 dark:text-slate-400 md:border-l md:border-t-0">
								{example.door}
							</p>
							<p class="border-t border-slate-200 px-6 py-5 text-sm text-slate-600 dark:border-slate-800 dark:text-slate-400 md:border-l md:border-t-0">
								{example.depot}
							</p>
							<p class="border-t border-slate-200 px-6 py-5 text-sm font-semibold text-emerald-700 dark:border-slate-800 dark:text-emerald-400 md:border-l md:border-t-0">
								{example.difference}
							</p>
							<p class="border-t border-slate-200 px-6 py-5 text-sm text-slate-600 dark:border-slate-800 dark:text-slate-400 md:border-l md:border-t-0">
								{example.transit}
							</p>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<section class="bg-slate-50 py-24 dark:bg-slate-950/40">
		<div class="mx-auto box-border w-full max-w-6xl px-6">
			<div class="grid gap-12 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start lg:gap-16">
				<div class="motion-rise lg:sticky lg:top-28">
					<p class="section-kicker">Before pickup</p>
					<h2
						class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
					>
						A few details are worth checking before the carrier arrives.
					</h2>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
						The carrier completes a vehicle inspection at pickup and delivery. The useful part for
						you is making sure the vehicle and access details are right in the quote request.
					</p>
				</div>

				<div class="motion-rise motion-rise-delay-1 grid gap-3">
					{
						preparationItems.map((item) => (
							<div class="flex items-start gap-3 rounded-2xl border border-slate-200 bg-white px-5 py-4 text-sm font-semibold text-slate-700 shadow-sm dark:border-slate-800 dark:bg-slate-900/75 dark:text-slate-300">
								<span class="mt-1.5 h-2.5 w-2.5 rounded-full bg-emerald-500" aria-hidden="true" />
								<span>{item}</span>
							</div>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<section class="border-y border-slate-200 bg-white py-24 dark:border-slate-800 dark:bg-slate-900">
		<div class="mx-auto box-border w-full max-w-6xl px-6">
			<div
				class="grid gap-12 rounded-[2rem] border border-slate-200 bg-slate-50 px-6 py-8 shadow-sm dark:border-slate-800 dark:bg-slate-950/40 md:px-8 md:py-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start"
			>
				<div class="motion-rise">
					<p class="section-kicker">Tracking and timing</p>
					<h2
						class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
					>
						Tracking depends on the carrier.
					</h2>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
						At a minimum, you will receive a phone number and tracking code. Some carriers also
						provide a tracking link that updates when the vehicle reaches a depot or is scheduled
						onto a trip.
					</p>
					<a
						href="/how-moveroo-protects-your-move/"
						class="site-text-action mt-5 gap-2 text-sm font-semibold text-emerald-700 transition hover:text-emerald-900 dark:text-emerald-400 dark:hover:text-emerald-300"
					>
						<span>See how Moveroo handles quotes, booking and support</span>
						<span aria-hidden="true">&rarr;</span>
					</a>
				</div>

				<div class="motion-rise motion-rise-delay-1 grid gap-5">
					<article class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900/75">
						<h3 class="text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">
							Quote responses vary
						</h3>
						<p class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
							Where carrier pricing is available automatically, quote options can come back quickly.
							If the vehicle or route needs a manual check, Moveroo will reply when the pricing is
							available.
						</p>
					</article>
					<article class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900/75">
						<h3 class="text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">
							You can ask Moveroo for an update
						</h3>
						<p class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
							If you would rather ask Moveroo for a tracking update, contact us and we can request
							one for you.
						</p>
					</article>
				</div>
			</div>
		</div>
	</section>

	<section class="bg-slate-50 py-24 dark:bg-slate-950/40">
		<div class="mx-auto box-border w-full max-w-6xl px-6">
			<div
				class="grid gap-12 rounded-[2rem] border border-slate-200 bg-white px-6 py-8 shadow-sm dark:border-slate-800 dark:bg-slate-900/75 md:px-8 md:py-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start"
			>
				<div class="motion-rise">
					<p class="section-kicker">Moving home too?</p>
					<h2
						class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
					>
						A car move can sit beside a household move.
					</h2>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
						If the car move is part of a larger household move, let us know when you speak with
						Moveroo. The household move and vehicle transport may need different carriers, but the
						timing can still be planned together.
					</p>
				</div>

				<div
					class="motion-rise motion-rise-delay-1 rounded-[1.75rem] border border-slate-200 bg-slate-50 p-6 dark:border-slate-800 dark:bg-slate-950/40 md:p-8"
				>
					<h3 class="text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">
						Household + vehicle relocation
					</h3>
					<p class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
						Use the household and vehicle page when you need to understand how the two parts can be
						coordinated around the same move.
					</p>
					<a
						href="/household-vehicle-relocation/"
						class="site-text-action mt-5 gap-2 text-sm font-semibold text-emerald-700 transition hover:text-emerald-900 dark:text-emerald-400 dark:hover:text-emerald-300"
					>
						<span>Plan a household and vehicle move</span>
						<span aria-hidden="true">&rarr;</span>
					</a>
				</div>
			</div>
		</div>
	</section>

	<section class="bg-white py-24 dark:bg-slate-900" id="faq">
		<div class="mx-auto box-border w-full max-w-6xl px-6">
			<div
				class="grid gap-12 lg:grid-cols-[minmax(0,0.82fr)_minmax(0,1.18fr)] lg:items-start lg:gap-16"
			>
				<div class="motion-rise lg:sticky lg:top-28">
					<p class="section-kicker">FAQ</p>
					<h2
						class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
					>
						Interstate car transport questions, answered plainly.
					</h2>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
						The right quote depends on the vehicle, route, access, timing and carrier requirements.
					</p>
				</div>

				<div class="motion-rise motion-rise-delay-1 grid gap-4">
					{
						faqItems.map((faq) => (
							<details class="group rounded-[1.5rem] border border-slate-200 bg-white px-6 py-5 shadow-sm dark:border-slate-800 dark:bg-slate-950/55">
								<summary class="flex cursor-pointer list-none items-start justify-between gap-6">
									<h3 class="text-lg font-semibold leading-relaxed text-slate-900 dark:text-white">
										{faq.question}
									</h3>
									<span class="mt-1 text-2xl leading-none text-emerald-600 transition group-open:rotate-45 dark:text-emerald-400">
										+
									</span>
								</summary>
								<p class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
									{faq.answer}
								</p>
							</details>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<QuoteCta
		title="Ready to check interstate car transport options?"
		subtitle="Share the pickup and delivery suburbs, vehicle details, running condition, timing and whether you want door-to-door or depot options checked."
		ctaPrimaryLabel="Start a vehicle transport quote"
		ctaPrimaryHref={site.destinations.vehicleQuote}
		ctaSecondaryLabel="Request a callback"
		ctaSecondaryHref={site.destinations.contactPage}
	/>
</Layout>
