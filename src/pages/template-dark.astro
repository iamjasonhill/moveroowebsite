---
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="Dark Mode Template - Moveroo"
	description="Template page showcasing the dark mode design system"
	canonical="https://moveroo.com.au/template-dark/"
	robots="noindex, nofollow"
>
	<div class="min-h-screen bg-slate-900">
		<!-- Hero Section -->
		<section
			class="relative overflow-hidden bg-gradient-to-br from-slate-900 via-slate-800 to-emerald-900/20 py-24"
		>
			<div class="pointer-events-none absolute inset-0">
				<div
					class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,_rgba(16,185,129,0.15),_transparent_55%)]"
					aria-hidden="true"
				>
				</div>
			</div>

			<div class="relative mx-auto max-w-6xl px-6">
				<div class="max-w-3xl">
					<p class="text-sm font-semibold uppercase tracking-[0.4em] text-emerald-400">
						Template Showcase
					</p>
					<h1 class="mt-6 text-5xl font-bold leading-tight text-white md:text-6xl">
						Dark Mode Design Template
					</h1>
					<p class="mt-6 text-lg leading-relaxed text-slate-300">
						This template showcases our refreshed dark mode design system, featuring modern
						aesthetics, improved spacing, and a clean visual hierarchy that matches our quote pages.
						Perfect for users who prefer a darker interface.
					</p>
					<div class="mt-10 flex flex-wrap gap-4">
						<a
							class="inline-flex items-center justify-center rounded-full bg-emerald-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-emerald-600/30 transition hover:bg-emerald-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-500"
							href="/template-light/"
						>
							View Light Mode Template
						</a>
						<a
							class="inline-flex items-center justify-center rounded-full border border-emerald-500/50 px-6 py-3 text-sm font-semibold text-emerald-400 transition hover:border-emerald-400 hover:bg-emerald-500/10 hover:text-emerald-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-400"
							href="/"
						>
							Back to Home
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- Features Section -->
		<section class="border-y border-slate-800 bg-slate-900 py-24">
			<div class="mx-auto max-w-6xl px-6">
				<div class="text-center">
					<p class="text-sm font-semibold uppercase tracking-[0.35em] text-emerald-400">
						Design Elements
					</p>
					<h2 class="mt-6 text-3xl font-semibold text-white md:text-4xl">
						Modern Components & Patterns
					</h2>
					<p class="mx-auto mt-6 max-w-2xl text-base text-slate-400">
						Our refreshed design system includes improved typography, better spacing, and components
						that work seamlessly in both light and dark modes.
					</p>
				</div>

				<div class="mt-16 grid gap-8 md:grid-cols-3">
					<article
						class="flex flex-col gap-4 rounded-2xl border border-slate-800 bg-slate-800/50 p-8 shadow-lg shadow-black/20 transition hover:border-slate-700 hover:shadow-xl"
					>
						<div class="flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-500/20">
							<svg
								class="h-6 w-6 text-emerald-400"
								fill="none"
								viewBox="0 0 24 24"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"
								></path>
							</svg>
						</div>
						<h3 class="text-xl font-semibold text-white">Clean Design</h3>
						<p class="text-sm leading-relaxed text-slate-400">
							Streamlined interfaces with improved visual hierarchy and better use of whitespace for
							enhanced readability in dark mode.
						</p>
					</article>

					<article
						class="flex flex-col gap-4 rounded-2xl border border-slate-800 bg-slate-800/50 p-8 shadow-lg shadow-black/20 transition hover:border-slate-700 hover:shadow-xl"
					>
						<div class="flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-500/20">
							<svg
								class="h-6 w-6 text-emerald-400"
								fill="none"
								viewBox="0 0 24 24"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"
								></path>
							</svg>
						</div>
						<h3 class="text-xl font-semibold text-white">Responsive Layout</h3>
						<p class="text-sm leading-relaxed text-slate-400">
							Mobile-first design approach ensuring optimal viewing experience across all device
							sizes and screen resolutions.
						</p>
					</article>

					<article
						class="flex flex-col gap-4 rounded-2xl border border-slate-800 bg-slate-800/50 p-8 shadow-lg shadow-black/20 transition hover:border-slate-700 hover:shadow-xl"
					>
						<div class="flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-500/20">
							<svg
								class="h-6 w-6 text-emerald-400"
								fill="none"
								viewBox="0 0 24 24"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"
								></path>
							</svg>
						</div>
						<h3 class="text-xl font-semibold text-white">Dark Mode Optimized</h3>
						<p class="text-sm leading-relaxed text-slate-400">
							Carefully selected color palettes optimized for dark mode with optimal contrast and
							reduced eye strain for extended viewing.
						</p>
					</article>
				</div>
			</div>
		</section>

		<!-- Pricing Cards Section -->
		<section class="bg-slate-900 py-24">
			<div class="mx-auto max-w-6xl px-6">
				<div class="text-center">
					<p class="text-sm font-semibold uppercase tracking-[0.35em] text-emerald-400">
						Pricing Examples
					</p>
					<h2 class="mt-6 text-3xl font-semibold text-white md:text-4xl">
						Flexible Service Options
					</h2>
				</div>

				<div class="mt-16 grid gap-8 md:grid-cols-2">
					<article
						class="relative flex h-full flex-col gap-6 rounded-2xl border border-slate-800 bg-slate-800/50 p-8 shadow-lg shadow-black/20"
					>
						<div class="flex items-center justify-between">
							<h3 class="text-xl font-semibold text-white">Standard Service</h3>
							<span class="text-sm font-semibold uppercase tracking-[0.35em] text-slate-400">
								From $450
							</span>
						</div>
						<p class="text-sm text-slate-400">
							Perfect for standard moves with flexible scheduling and shared transport options.
						</p>
						<ul class="space-y-3 text-sm text-slate-400">
							<li class="flex items-start gap-3">
								<span class="mt-1 h-2 w-2 rounded-full bg-emerald-500" aria-hidden="true"></span>
								<span>Flexible pickup and delivery windows</span>
							</li>
							<li class="flex items-start gap-3">
								<span class="mt-1 h-2 w-2 rounded-full bg-emerald-500" aria-hidden="true"></span>
								<span>Proactive SMS/email updates</span>
							</li>
							<li class="flex items-start gap-3">
								<span class="mt-1 h-2 w-2 rounded-full bg-emerald-500" aria-hidden="true"></span>
								<span>Ideal for apartments and partial loads</span>
							</li>
						</ul>
						<a
							class="mt-auto inline-flex w-fit items-center justify-center rounded-full border border-emerald-500/50 px-6 py-3 text-sm font-semibold text-emerald-400 transition hover:border-emerald-400 hover:bg-emerald-500/10 hover:text-emerald-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-400"
							href="https://quotes.moveroo.com.au/quote/household"
							rel="noopener noreferrer"
							target="_blank"
						>
							Get a Quote
						</a>
					</article>

					<article
						class="relative flex h-full flex-col gap-6 rounded-2xl border-2 border-emerald-500/60 bg-emerald-500/10 p-8 shadow-xl shadow-emerald-500/10"
					>
						<div class="flex items-center justify-between">
							<h3 class="text-xl font-semibold text-white">Premium Service</h3>
							<span class="text-sm font-semibold uppercase tracking-[0.35em] text-emerald-400">
								From $880
							</span>
						</div>
						<p class="text-sm text-slate-400">
							Dedicated service with locked-in dates and comprehensive support throughout your move.
						</p>
						<ul class="space-y-3 text-sm text-slate-400">
							<li class="flex items-start gap-3">
								<span class="mt-1 h-2 w-2 rounded-full bg-emerald-400" aria-hidden="true"></span>
								<span>Locked-in move dates</span>
							</li>
							<li class="flex items-start gap-3">
								<span class="mt-1 h-2 w-2 rounded-full bg-emerald-400" aria-hidden="true"></span>
								<span>Concierge packing and unpacking</span>
							</li>
							<li class="flex items-start gap-3">
								<span class="mt-1 h-2 w-2 rounded-full bg-emerald-400" aria-hidden="true"></span>
								<span>On-demand storage and extras</span>
							</li>
						</ul>
						<a
							class="mt-auto inline-flex w-fit items-center justify-center rounded-full bg-emerald-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-emerald-600/30 transition hover:bg-emerald-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-500"
							href="https://quotes.moveroo.com.au/quote/household"
							rel="noopener noreferrer"
							target="_blank"
						>
							Get a Quote
						</a>
					</article>
				</div>
			</div>
		</section>

		<!-- CTA Section -->
		<section class="bg-slate-900 py-20">
			<div
				class="mx-auto flex max-w-6xl flex-col gap-10 rounded-2xl border border-slate-800 bg-gradient-to-br from-slate-800/50 via-slate-900 to-emerald-900/20 px-6 py-12 text-center shadow-xl shadow-black/40 md:flex-row md:items-center md:text-left"
			>
				<div class="flex-1 space-y-4">
					<h2 class="text-3xl font-semibold text-white">Ready to Get Started?</h2>
					<p class="text-base text-slate-400">
						Experience our refreshed design and streamlined quote process. Get started with a free
						quote today.
					</p>
				</div>
				<div class="flex flex-1 flex-col gap-4 md:items-end">
					<a
						class="inline-flex items-center justify-center rounded-full bg-emerald-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-emerald-600/30 transition hover:bg-emerald-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-500"
						href="https://quotes.moveroo.com.au/quote/household"
						rel="noopener noreferrer"
						target="_blank"
					>
						Get a Free Quote
					</a>
					<a
						class="inline-flex items-center justify-center rounded-full border border-emerald-500/50 px-6 py-3 text-sm font-semibold text-emerald-400 transition hover:border-emerald-400 hover:bg-emerald-500/10 hover:text-emerald-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-400"
						href="https://quotes.moveroo.com.au/contact"
					>
						Contact Us
					</a>
				</div>
			</div>
		</section>
	</div>
</Layout>
