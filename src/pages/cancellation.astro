---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Moveroo | Cancel Your Move"
  description="Need to cancel your move? We understand plans change. Submit a cancellation request and our team will assist you promptly."
  canonical="https://moveroo.com.au/cancellation/"
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-emerald-50 via-emerald-100 to-white py-24">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.35em] text-emerald-600">
        Cancellation Request
      </p>
      <h1 class="mt-6 text-4xl font-semibold text-slate-900 md:text-5xl">
        Need to Cancel Your Move?
      </h1>
      <p class="mt-6 text-lg text-slate-600">
        We understand that plans change. Submit your cancellation request below and our team will process it as quickly as possible.
      </p>
    </div>
  </section>

  <!-- Information Section -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-8 md:grid-cols-3">
        <!-- Card 1 -->
        <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-lg shadow-slate-200/40">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-emerald-100">
            <svg class="h-6 w-6 text-emerald-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-slate-900">Quick Response</h3>
          <p class="mt-3 text-slate-600">
            Our team will review your cancellation request within 24 hours and contact you to confirm.
          </p>
        </div>

        <!-- Card 2 -->
        <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-lg shadow-slate-200/40">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-emerald-100">
            <svg class="h-6 w-6 text-emerald-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-slate-900">Reference Number</h3>
          <p class="mt-3 text-slate-600">
            Please have your booking reference number ready. You can find this in your booking confirmation email.
          </p>
        </div>

        <!-- Card 3 -->
        <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-lg shadow-slate-200/40">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-emerald-100">
            <svg class="h-6 w-6 text-emerald-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-slate-900">Email Confirmation</h3>
          <p class="mt-3 text-slate-600">
            You'll receive an email confirmation once your cancellation has been processed.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Cancellation Form Section -->
  <section class="bg-gradient-to-br from-slate-50 to-white py-20" id="cancellation-form">
    <div class="mx-auto max-w-3xl px-6">
      <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-xl shadow-slate-200/40 md:p-12">
        <h2 class="text-2xl font-semibold text-slate-900 md:text-3xl">
          Submit Cancellation Request
        </h2>
        <p class="mt-3 text-slate-600">
          Please fill out the form below with your booking details. All fields marked with * are required.
        </p>

        <form class="mt-8 space-y-6" method="POST" action="/api/cancellation" id="cancellationForm">
          <!-- Name Field -->
          <div>
            <label for="name" class="block text-sm font-semibold text-slate-900">
              Full Name <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-slate-900 placeholder-slate-400 transition focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20"
              placeholder="John Smith"
            />
          </div>

          <!-- Email Field -->
          <div>
            <label for="email" class="block text-sm font-semibold text-slate-900">
              Email Address <span class="text-red-500">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-slate-900 placeholder-slate-400 transition focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20"
              placeholder="john.smith@example.com"
            />
          </div>

          <!-- Phone Field -->
          <div>
            <label for="phone" class="block text-sm font-semibold text-slate-900">
              Phone Number <span class="text-red-500">*</span>
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-slate-900 placeholder-slate-400 transition focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20"
              placeholder="+61 4XX XXX XXX"
            />
          </div>

          <!-- Reference Number Field -->
          <div>
            <label for="reference" class="block text-sm font-semibold text-slate-900">
              Booking Reference Number
            </label>
            <input
              type="text"
              id="reference"
              name="bookingReference"
              class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-slate-900 placeholder-slate-400 transition focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20"
              placeholder="MV-123456"
            />
            <p class="mt-1 text-sm text-slate-500">
              Find this in your booking confirmation email
            </p>
          </div>

          <!-- Reason for Cancellation Field -->
          <div>
            <label for="reason" class="block text-sm font-semibold text-slate-900">
              Reason for Cancellation <span class="text-red-500">*</span>
            </label>
            <textarea
              id="reason"
              name="reason"
              rows="5"
              required
              class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-4 py-3 text-slate-900 placeholder-slate-400 transition focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20"
              placeholder="Please provide details about why you need to cancel your booking..."
            ></textarea>
          </div>

          <!-- Message Display -->
          <div id="form-message" class="hidden rounded-lg p-4 text-sm"></div>

          <!-- Submit Button -->
          <div class="pt-4">
            <button
              type="submit"
              id="submit-button"
              class="inline-flex w-full items-center justify-center rounded-full bg-emerald-700 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-emerald-700/30 transition hover:bg-emerald-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700 disabled:cursor-not-allowed disabled:opacity-50"
            >
              Submit Cancellation Request
            </button>
          </div>

          <!-- Help Text -->
          <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
            <p class="text-sm text-slate-600">
              <strong class="font-semibold text-slate-900">Need immediate assistance?</strong>
              Call us at <a href="tel:+61721432557" class="font-semibold text-emerald-700 hover:text-emerald-800">+61 7 2143 2557</a>
              or email <a href="mailto:removals@moveroo.com.au" class="font-semibold text-emerald-700 hover:text-emerald-800">removals@moveroo.com.au</a>
            </p>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- Cancellation Policy Section -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-4xl px-6">
      <h2 class="text-2xl font-semibold text-slate-900 md:text-3xl">
        Cancellation Policy
      </h2>
      <div class="mt-8 space-y-6 text-slate-600">
        <div class="rounded-3xl border border-slate-200 bg-white p-6">
          <h3 class="font-semibold text-slate-900">Before We Review Your Request</h3>
          <p class="mt-2">
            Please review our terms and conditions regarding cancellations. Fees may apply depending on how close to your scheduled move date the cancellation is requested.
          </p>
        </div>

        <div class="rounded-3xl border border-slate-200 bg-white p-6">
          <h3 class="font-semibold text-slate-900">What Happens Next?</h3>
          <ul class="mt-2 space-y-2">
            <li class="flex gap-2">
              <span class="text-emerald-600">•</span>
              <span>We'll review your cancellation request within 24 hours</span>
            </li>
            <li class="flex gap-2">
              <span class="text-emerald-600">•</span>
              <span>A team member will contact you via email or phone to confirm</span>
            </li>
            <li class="flex gap-2">
              <span class="text-emerald-600">•</span>
              <span>Any applicable refunds will be processed within 5-7 business days</span>
            </li>
            <li class="flex gap-2">
              <span class="text-emerald-600">•</span>
              <span>You'll receive a final confirmation email once the cancellation is complete</span>
            </li>
          </ul>
        </div>

        <div class="rounded-3xl border border-emerald-200 bg-emerald-50 p-6">
          <h3 class="font-semibold text-emerald-900">Still Have Questions?</h3>
          <p class="mt-2 text-emerald-800">
            Our customer service team is here to help. Visit our <a href="/contact/" class="font-semibold underline hover:text-emerald-700">contact page</a>
            or call us directly at <a href="tel:+61721432557" class="font-semibold underline hover:text-emerald-700">+61 7 2143 2557</a>.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('cancellationForm') as HTMLFormElement;
  const submitButton = document.getElementById('submit-button') as HTMLButtonElement;
  const messageDiv = document.getElementById('form-message') as HTMLDivElement;

  if (form && submitButton && messageDiv) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // Disable submit button
      submitButton.disabled = true;
      submitButton.textContent = 'Submitting...';
      
      // Hide previous messages
      messageDiv.classList.add('hidden');
      messageDiv.classList.remove('bg-emerald-50', 'text-emerald-700', 'border-emerald-200', 'bg-red-50', 'text-red-700', 'border-red-200');

      const formData = new FormData(form);
      const data = Object.fromEntries(formData);

      try {
        const response = await fetch('/api/cancellation', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(data),
        });

        const result = await response.json();

        if (response.ok) {
          messageDiv.classList.add('bg-emerald-50', 'text-emerald-700', 'border', 'border-emerald-200');
          messageDiv.textContent = result.message || 'Your cancellation request has been submitted successfully. We will process it shortly.';
          messageDiv.classList.remove('hidden');
          form.reset();
        } else {
          messageDiv.classList.add('bg-red-50', 'text-red-700', 'border', 'border-red-200');
          messageDiv.textContent = result.error || 'An error occurred. Please try again later.';
          messageDiv.classList.remove('hidden');
        }
      } catch (error) {
        messageDiv.classList.add('bg-red-50', 'text-red-700', 'border', 'border-red-200');
        messageDiv.textContent = 'An error occurred. Please try again later.';
        messageDiv.classList.remove('hidden');
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = 'Submit Cancellation Request';
      }
    });
  }
</script>
