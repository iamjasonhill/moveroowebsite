---
import Layout from "../layouts/Layout.astro";

const lastModified = new Date("2026-03-23T00:00:00.000Z");

const jumpLinks = [
	{ id: "request-form", label: "Submit request" },
	{ id: "policy", label: "Cancellation policy" },
	{ id: "support", label: "Need help?" },
];

const summarySignals = [
	"Cancellation request form",
	"24-hour review target",
	"Deposit and refund rules",
	"Direct phone and email support",
];
---

<Layout
	title="Cancel Your Move | Moveroo Cancellation Request Form"
	description="Need to cancel your move? We understand plans change. Submit a cancellation request and our team will assist you promptly. View our refund policy here."
	canonical="https://moveroo.com.au/cancellation/"
>
	<Fragment slot="head">
		<meta property="article:modified_time" content={lastModified.toISOString()} />
	</Fragment>

	<section class="relative overflow-hidden bg-slate-950 py-24 text-white md:py-28">
		<div
			class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(16,185,129,0.22),_transparent_26%),linear-gradient(135deg,_#052e2b_0%,_#0f172a_48%,_#0f172a_100%)]"
		>
		</div>
		<div class="route-grid absolute inset-0 opacity-25"></div>
		<div
			class="motion-drift absolute right-[-9rem] top-[-7rem] h-[20rem] w-[20rem] rounded-full bg-emerald-400/10 blur-3xl"
		>
		</div>

		<div class="mx-auto max-w-5xl px-6">
			<div class="relative grid gap-10 lg:grid-cols-[minmax(0,1fr)_18rem] lg:items-start">
				<div class="motion-rise">
					<p class="section-kicker text-emerald-300">Cancellation Request</p>
					<h1 class="section-title mt-6 text-4xl font-semibold text-white md:text-6xl">
						Cancel or update a move booking with a clearer support path
					</h1>
					<p class="mt-6 max-w-3xl text-base leading-relaxed text-slate-300 md:text-lg">
						If your plans have changed, use this page to submit a cancellation request, review the
						main refund rules and contact the Moveroo team for direct help.
					</p>
					<p class="mt-4 text-sm leading-relaxed text-slate-400">
						Last updated {
							lastModified.toLocaleDateString("en-AU", {
								day: "numeric",
								month: "long",
								year: "numeric",
							})
						}
					</p>

					<div class="motion-rise motion-rise-delay-1 mt-8 flex flex-wrap gap-3">
						{
							summarySignals.map((signal) => (
								<span class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-medium uppercase tracking-[0.22em] text-slate-200">
									{signal}
								</span>
							))
						}
					</div>
				</div>

				<nav
					aria-label="Cancellation page sections"
					class="motion-rise motion-rise-delay-2 rounded-[1.75rem] border border-white/10 bg-white/8 p-5 text-sm shadow-[0_30px_80px_-40px_rgba(2,6,23,0.8)] backdrop-blur-sm"
				>
					<p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">
						On this page
					</p>
					<ul class="mt-4 space-y-3">
						{
							jumpLinks.map((link) => (
								<li>
									<a href={`#${link.id}`} class="text-slate-200 transition hover:text-emerald-300">
										{link.label}
									</a>
								</li>
							))
						}
					</ul>
				</nav>
			</div>
		</div>
	</section>

	<section class="bg-slate-50 py-20 dark:bg-slate-950/40">
		<div class="mx-auto max-w-6xl px-6">
			<div class="grid gap-10 xl:grid-cols-[18rem_minmax(0,1fr)] xl:items-start">
				<aside class="space-y-6 xl:sticky xl:top-28" id="support">
					<div class="page-panel page-panel-soft p-6">
						<p class="section-kicker">What happens next</p>
						<ul class="mt-4 space-y-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
							<li>We review cancellation requests within 24 hours where possible.</li>
							<li>A team member confirms the outcome by email.</li>
							<li>Any approved refund is processed after the request is finalised.</li>
						</ul>
					</div>

					<div class="page-panel p-6">
						<p
							class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500 dark:text-slate-400"
						>
							Direct support
						</p>
						<div class="mt-4 space-y-3 text-sm">
							<p>
								Call <a
									href="tel:+61721432557"
									class="text-emerald-700 hover:text-emerald-800 dark:text-emerald-400 dark:hover:text-emerald-300"
									>+61 7 2143 2557</a
								>
							</p>
							<p>
								Email <a
									href="mailto:removals@moveroo.com.au"
									class="text-emerald-700 hover:text-emerald-800 dark:text-emerald-400 dark:hover:text-emerald-300"
									>removals@moveroo.com.au</a
								>
							</p>
							<p>
								Review the <a
									href="/terms-and-conditions-transport/"
									class="text-emerald-700 hover:text-emerald-800 dark:text-emerald-400 dark:hover:text-emerald-300"
									>transport terms</a
								>
								if you need the broader booking conditions.
							</p>
						</div>
					</div>
				</aside>

				<div class="space-y-8">
					<section class="page-panel p-6 md:p-8 lg:p-10" id="request-form">
						<p class="section-kicker">Submit request</p>
						<h2 class="section-title mt-5 text-3xl font-semibold text-slate-900 dark:text-white">
							Cancellation request form
						</h2>
						<p class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
							Please share the booking details below. Fields marked with <span class="text-red-500"
								>*</span
							> are required.
						</p>

						<form
							class="mt-8 space-y-6"
							method="POST"
							action="/api/cancellation/"
							id="cancellationForm"
						>
							<div>
								<label for="company" class="sr-only">Company</label>
								<input
									type="text"
									id="company"
									name="company"
									tabindex="-1"
									autocomplete="off"
									class="hidden"
									aria-hidden="true"
								/>
							</div>

							<div>
								<label
									for="name"
									class="block text-sm font-semibold text-slate-900 dark:text-white"
								>
									Full Name <span class="text-red-500">*</span>
								</label>
								<input
									type="text"
									id="name"
									name="name"
									required
									class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 placeholder-slate-400 transition focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20 dark:border-slate-700 dark:bg-slate-950 dark:text-white dark:placeholder-slate-500 dark:focus:border-emerald-500"
									placeholder="John Smith"
								/>
							</div>

							<div class="grid gap-6 md:grid-cols-2">
								<div>
									<label
										for="email"
										class="block text-sm font-semibold text-slate-900 dark:text-white"
									>
										Email Address <span class="text-red-500">*</span>
									</label>
									<input
										type="email"
										id="email"
										name="email"
										required
										class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 placeholder-slate-400 transition focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20 dark:border-slate-700 dark:bg-slate-950 dark:text-white dark:placeholder-slate-500 dark:focus:border-emerald-500"
										placeholder="john.smith@example.com"
									/>
								</div>

								<div>
									<label
										for="phone"
										class="block text-sm font-semibold text-slate-900 dark:text-white"
									>
										Phone Number <span class="text-red-500">*</span>
									</label>
									<input
										type="tel"
										id="phone"
										name="phone"
										required
										class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 placeholder-slate-400 transition focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20 dark:border-slate-700 dark:bg-slate-950 dark:text-white dark:placeholder-slate-500 dark:focus:border-emerald-500"
										placeholder="+61 4XX XXX XXX"
									/>
								</div>
							</div>

							<div>
								<label
									for="bookingReference"
									class="block text-sm font-semibold text-slate-900 dark:text-white"
								>
									Booking Reference Number
								</label>
								<input
									type="text"
									id="bookingReference"
									name="bookingReference"
									class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 placeholder-slate-400 transition focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20 dark:border-slate-700 dark:bg-slate-950 dark:text-white dark:placeholder-slate-500 dark:focus:border-emerald-500"
									placeholder="MV-123456"
								/>
								<p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
									If you have it, include the reference from your booking confirmation email.
								</p>
							</div>

							<div>
								<label
									for="reason"
									class="block text-sm font-semibold text-slate-900 dark:text-white"
								>
									Reason for Cancellation <span class="text-red-500">*</span>
								</label>
								<textarea
									id="reason"
									name="reason"
									rows="5"
									required
									class="mt-2 w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-slate-900 placeholder-slate-400 transition focus:border-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-600/20 dark:border-slate-700 dark:bg-slate-950 dark:text-white dark:placeholder-slate-500 dark:focus:border-emerald-500"
									placeholder="Please provide a short explanation so our team can review the request quickly."
								></textarea>
							</div>

							<div id="form-message" class="hidden rounded-2xl p-4 text-sm"></div>

							<div class="flex flex-col gap-4 pt-2 md:flex-row md:items-center md:justify-between">
								<button
									type="submit"
									id="submit-button"
									class="inline-flex w-full items-center justify-center rounded-full bg-emerald-600 px-6 py-3 text-sm font-semibold text-slate-950 shadow-lg shadow-emerald-950/20 transition hover:bg-emerald-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-400 disabled:cursor-not-allowed disabled:opacity-50 md:w-auto"
								>
									Submit Cancellation Request
								</button>

								<p class="text-sm leading-relaxed text-slate-500 dark:text-slate-400">
									If the matter is urgent, call the team instead of waiting for the form response.
								</p>
							</div>
						</form>
					</section>

					<section class="page-panel p-6 md:p-8" id="policy">
						<p class="section-kicker">Policy</p>
						<h2 class="section-title mt-5 text-3xl font-semibold text-slate-900 dark:text-white">
							Cancellation and refund guide
						</h2>

						<div class="mt-6 grid gap-4 md:grid-cols-2">
							<div
								class="rounded-2xl border border-slate-200 bg-slate-50 px-5 py-5 dark:border-slate-800 dark:bg-slate-950/40"
							>
								<p class="text-sm font-semibold text-slate-900 dark:text-white">
									Before we review your request
								</p>
								<p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
									Please review the timing of your cancellation carefully. Fees or deposit
									adjustments may apply depending on how close the request is to your scheduled
									move.
								</p>
							</div>

							<div
								class="rounded-2xl border border-slate-200 bg-slate-50 px-5 py-5 dark:border-slate-800 dark:bg-slate-950/40"
							>
								<p class="text-sm font-semibold text-slate-900 dark:text-white">
									What happens next
								</p>
								<ul
									class="mt-3 space-y-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400"
								>
									<li>We review the request and confirm the booking details.</li>
									<li>We contact you by email with the outcome.</li>
									<li>Any approved refund is processed after confirmation.</li>
								</ul>
							</div>

							<div
								class="rounded-2xl border border-slate-200 bg-slate-50 px-5 py-5 dark:border-slate-800 dark:bg-slate-950/40"
							>
								<p class="text-sm font-semibold text-slate-900 dark:text-white">Deposits</p>
								<p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
									Deposits are reviewed according to the timing of the request, operational costs
									already incurred and the booking conditions that applied when the move was
									confirmed.
								</p>
							</div>

							<div
								class="rounded-2xl border border-emerald-200 bg-emerald-50 px-5 py-5 dark:border-emerald-500/40 dark:bg-emerald-500/10"
							>
								<p class="text-sm font-semibold text-emerald-900 dark:text-emerald-300">
									Still have questions?
								</p>
								<p class="mt-3 text-sm leading-relaxed text-emerald-800 dark:text-emerald-200">
									Use the <a
										href="https://quotes.moveroo.com.au/contact"
										class="underline hover:text-emerald-700 dark:hover:text-emerald-100"
										>contact page</a
									>
									or call <a
										href="tel:+61721432557"
										class="underline hover:text-emerald-700 dark:hover:text-emerald-100"
										>+61 7 2143 2557</a
									>
									for direct assistance.
								</p>
							</div>
						</div>
					</section>
				</div>
			</div>
		</div>
	</section>

	<script>
		const form = document.getElementById("cancellationForm") as HTMLFormElement;
		const submitButton = document.getElementById("submit-button") as HTMLButtonElement;
		const messageDiv = document.getElementById("form-message") as HTMLDivElement;

		if (form && submitButton && messageDiv) {
			form.addEventListener("submit", async (e) => {
				e.preventDefault();

				submitButton.disabled = true;
				submitButton.textContent = "Submitting...";

				messageDiv.classList.add("hidden");
				messageDiv.classList.remove(
					"bg-emerald-50",
					"text-emerald-700",
					"border-emerald-200",
					"bg-red-50",
					"text-red-700",
					"border-red-200"
				);

				const formData = new FormData(form);
				const data = Object.fromEntries(formData);

				try {
					const response = await fetch("/api/cancellation/", {
						method: "POST",
						headers: {
							"Content-Type": "application/json",
						},
						body: JSON.stringify(data),
					});

					const result = await response.json();

					if (response.ok) {
						messageDiv.classList.add(
							"bg-emerald-50",
							"text-emerald-700",
							"border",
							"border-emerald-200"
						);
						messageDiv.textContent =
							result.message ||
							"Your cancellation request has been submitted successfully. We will process it shortly.";
						messageDiv.classList.remove("hidden");
						form.reset();
					} else {
						messageDiv.classList.add("bg-red-50", "text-red-700", "border", "border-red-200");
						messageDiv.textContent = result.error || "An error occurred. Please try again later.";
						messageDiv.classList.remove("hidden");
					}
				} catch {
					messageDiv.classList.add("bg-red-50", "text-red-700", "border", "border-red-200");
					messageDiv.textContent = "An error occurred. Please try again later.";
					messageDiv.classList.remove("hidden");
				} finally {
					submitButton.disabled = false;
					submitButton.textContent = "Submit Cancellation Request";
				}
			});
		}
	</script>
</Layout>
