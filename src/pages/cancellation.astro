---
import Layout from "../layouts/Layout.astro";
import { site } from "../config/site";

const lastModified = new Date("2026-07-24T00:00:00.000Z");

const policyItems = [
	{
		title: "48-hour cooling-off period",
		text: "Customers are entitled to a 48-hour cooling-off period from the time their payment is made. During this period, a deposit may be refunded if the customer chooses to cancel their move. After this period, the deposit is non-refundable if the customer cancels for reasons unrelated to any action, fault or failure by Moveroo.",
	},
	{
		title: "What happens next",
		text: "The team reviews the request, confirms the booking details and advises the outcome. Any approved refund is processed after confirmation.",
	},
	{
		title: "Deposits",
		text: "After the 48-hour cooling-off period, deposits are non-refundable where the customer cancels for reasons unrelated to any action, fault or failure by Moveroo.",
	},
	{
		title: "If collection cannot go ahead",
		text: "If collection cannot proceed as scheduled because Moveroo or one of its service providers is unavailable on the requested date, the customer will be offered either a full refund or the next available collection date.",
	},
	{
		title: "Postponing your move",
		text: "If you postpone a move that is less than seven days away, you will not be charged a cancellation fee for the original date. The original price cannot always be held for the new date, and any change is reviewed case by case.",
	},
];
---

<Layout
	title="Cancellation Policy and Support | Moveroo"
	description="Review Moveroo cancellation and refund guidance, then use the secure cancellation and refund details form to send your request."
	canonical="https://moveroo.com.au/cancellation/"
>
	<Fragment slot="head">
		<meta property="article:modified_time" content={lastModified.toISOString()} />
	</Fragment>

	<section class="relative overflow-hidden bg-slate-950 py-24 text-white md:py-28">
		<div
			class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(16,185,129,0.22),_transparent_26%),linear-gradient(135deg,_#052e2b_0%,_#0f172a_48%,_#0f172a_100%)]"
		>
		</div>
		<div class="route-grid absolute inset-0 opacity-25"></div>
		<div class="relative mx-auto max-w-5xl px-6">
			<p class="section-kicker text-emerald-300">Cancellation support</p>
			<h1 class="section-title mt-6 max-w-4xl text-4xl font-semibold text-white md:text-6xl">
				Cancel or update a move through the secure details form
			</h1>
			<p class="mt-6 max-w-3xl text-base leading-relaxed text-slate-300 md:text-lg">
				Review the main cancellation and refund rules below. When you are ready, send the booking
				and refund details through Moveroo's secure form so the team can review the request.
			</p>
			<div class="mt-8 flex flex-wrap gap-4">
				<a
					href={site.destinations.cancellationRefundDetails}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center justify-center rounded-full bg-emerald-500 px-6 py-3 text-sm font-semibold text-slate-950 transition hover:bg-emerald-400"
				>
					Open cancellation support
				</a>
				<a
					href="/terms-and-conditions-transport/"
					class="inline-flex items-center justify-center rounded-full border border-white/20 px-6 py-3 text-sm font-semibold text-white transition hover:border-emerald-300 hover:text-emerald-200"
				>
					Review transport terms
				</a>
			</div>
			<p class="mt-5 text-sm text-slate-400">
				Last updated {
					lastModified.toLocaleDateString("en-AU", {
						day: "numeric",
						month: "long",
						year: "numeric",
					})
				}
			</p>
		</div>
	</section>

	<section class="bg-slate-50 py-20 dark:bg-slate-950/40">
		<div class="mx-auto max-w-6xl px-6">
			<div class="grid gap-10 lg:grid-cols-[minmax(0,0.75fr)_minmax(0,1.25fr)]">
				<aside class="page-panel page-panel-soft h-fit p-6 lg:sticky lg:top-28">
					<p class="section-kicker">Before you send the request</p>
					<ul class="mt-5 space-y-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
						<li>Include the booking reference if it is available.</li>
						<li>Explain whether the move should be cancelled or postponed.</li>
						<li>Include any timing or refund details the team should check.</li>
					</ul>
					<a
						href={site.destinations.cancellationRefundDetails}
						target="_blank"
						rel="noopener noreferrer"
						class="mt-6 inline-flex items-center justify-center rounded-full bg-emerald-600 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-emerald-500"
					>
						Send the request securely
					</a>
				</aside>

				<div class="space-y-6">
					<div>
						<p class="section-kicker">Policy</p>
						<h2 class="section-title mt-5 text-3xl font-semibold text-slate-900 dark:text-white">
							Cancellation and refund guide
						</h2>
					</div>
					{
						policyItems.map((item) => (
							<article class="page-panel p-6 md:p-8">
								<h3 class="text-lg font-semibold text-slate-900 dark:text-white">{item.title}</h3>
								<p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
									{item.text}
								</p>
							</article>
						))
					}
				</div>
			</div>
		</div>
	</section>
</Layout>
