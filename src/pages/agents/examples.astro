---
const brand = "Moveroo Australia";
const breadcrumbItems = [
	{ name: "Home", url: "https://moveroo.com.au/" },
	{ name: "Agents", url: "https://moveroo.com.au/agents/" },
	{ name: "Examples", url: "https://moveroo.com.au/agents/examples/" },
];
const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: breadcrumbItems.map((item, index) => ({
		"@type": "ListItem",
		position: index + 1,
		name: item.name,
		item: item.url,
	})),
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{brand} Agent/API Examples</title>
		<meta
			name="description"
			content={`Example customer-consented API requests for Moveroo Australia quote agents.`}
		/>
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
		<style>
			body {
				margin: 0;
				font-family:
					Inter,
					ui-sans-serif,
					system-ui,
					-apple-system,
					BlinkMacSystemFont,
					"Segoe UI",
					sans-serif;
				color: #17202a;
				background: #f7f4ee;
			}
			main {
				max-width: 920px;
				margin: 0 auto;
				padding: 48px 20px 64px;
			}
			h1 {
				font-size: clamp(2rem, 5vw, 3.5rem);
				line-height: 1;
				margin: 0 0 18px;
			}
			p,
			li {
				line-height: 1.65;
			}
			a {
				color: #0b5cad;
				text-underline-offset: 3px;
			}
			pre {
				overflow-x: auto;
				background: #111827;
				color: #f9fafb;
				padding: 16px;
				border-radius: 8px;
			}
			code {
				font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
			}
			.breadcrumbs {
				margin: 0 0 28px;
				font-size: 0.95rem;
			}
			.breadcrumbs ol {
				display: flex;
				flex-wrap: wrap;
				gap: 0.65rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.breadcrumbs li {
				align-items: center;
				display: inline-flex;
				gap: 0.65rem;
			}
			.breadcrumbs li:not(:last-child)::after {
				color: #8a7d6c;
				content: "/";
			}
		</style>
	</head>
	<body>
		<main>
			<nav aria-label="Breadcrumb" class="breadcrumbs">
				<ol>
					<li><a href="/">Home</a></li>
					<li><a href="/agents/">Agents</a></li>
					<li><span aria-current="page">Examples</span></li>
				</ol>
			</nav>
			<h1>{brand} Agent/API Examples</h1>
			<p>
				These examples point agents to the canonical quote host at <a
					href="https://quotes.moveroo.com.au/">https://quotes.moveroo.com.au/</a
				>. Use the live OpenAPI schema and capability manifest before submitting production
				requests.
			</p>
			<h2>Household Quote</h2>
			<pre><code>curl -X POST https://quotes.moveroo.com.au/api/v1/household-quotes/assistant/submit \
  -H 'Content-Type: application/json' \
  -d '&#123;"customer_consent":&#123;"confirmed":true&#125;,"customer":&#123;"name":"Example Customer","email":"customer@example.com","phone":"0400000000"&#125;,"move":&#123;"pickup":&#123;"suburb":"Sydney","state":"NSW"&#125;,"delivery":&#123;"suburb":"Brisbane","state":"QLD"&#125;,"inventory":&#123;"method":"m3","cubic_meters":20&#125;&#125;&#125;'</code></pre>
			<h2>Vehicle Quote</h2>
			<pre><code>curl -X POST https://quotes.moveroo.com.au/api/v1/vehicle-quotes/assistant/submit \
  -H 'Content-Type: application/json' \
  -d '&#123;"customer_consent":&#123;"confirmed":true&#125;,"customer":&#123;"name":"Example Customer","email":"customer@example.com","phone":"0400000000"&#125;,"vehicle":&#123;"make":"Toyota","model":"Corolla","drivable":true&#125;,"route":&#123;"pickup":&#123;"suburb":"Melbourne","state":"VIC"&#125;,"delivery":&#123;"suburb":"Perth","state":"WA"&#125;&#125;&#125;'</code></pre>
			<h2>Callback Request</h2>
			<pre><code>curl -X POST https://quotes.moveroo.com.au/api/v1/callbacks/assistant/request \
  -H 'Content-Type: application/json' \
  -d '&#123;"customer_consent":&#123;"confirmed":true&#125;,"customer":&#123;"name":"Example Customer","email":"customer@example.com","phone":"0400000000"&#125;,"message":"Please call me about my move."&#125;'</code></pre>
		</main>
	</body>
</html>
