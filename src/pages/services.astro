---
import Layout from "../layouts/Layout.astro";

const lastModified = new Date("2026-01-10T00:00:00.000Z");

// FAQ data for schema markup
const faqItems = [
	{
		question: "What services does Moveroo offer?",
		answer:
			"Moveroo works with trusted carriers, removalists and logistics experts across Australia. We help with home moves, vehicle transport (cars, motorcycles, specialty vehicles), and custom transport plans for boats, caravans, trailers, and industrial machinery.",
	},
	{
		question: "How does the Moveroo moving process work?",
		answer:
			"Our process has three stages: Discovery (coordinators capture timelines, inventory, and requirements), Tailored Plan (we find the right partners and provide clear quotes), and Managed Delivery (status updates at each milestone with proactive support).",
	},
	{
		question: "How much does moving cost?",
		answer:
			"Moving costs vary based on distance, volume, and service type. We provide free quotes tailored to your specific needs. Contact us for a detailed estimate.",
	},
	{
		question: "How far in advance should I book?",
		answer:
			"We recommend booking 2-4 weeks in advance for best availability. However, we can often accommodate shorter timelines depending on your route and dates.",
	},
	{
		question: "Do you provide insurance coverage?",
		answer:
			"Yes, we coordinate insurance coverage for all moves. Our partners provide comprehensive insurance options to protect your belongings during transport.",
	},
	{
		question: "What areas do you service?",
		answer:
			"We service all of Australia, including major cities and regional areas. Our network of trusted carriers covers the entire country.",
	},
];

// HowTo schema for the 3-step process
const howToSteps = [
	{
		name: "Discovery",
		text: "Our coordinators gather timelines, inventory, access requirements and any special handling instructions.",
	},
	{
		name: "Tailored plan",
		text: "We find the right partners, vehicles and team members, then provide a clear quote and itinerary.",
	},
	{
		name: "Managed delivery",
		text: "We provide status updates at each milestone with proactive problem solving and post-move check-ins.",
	},
];

const structuredData = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "WebPage",
			"@id": "https://moveroo.com.au/services/",
			url: "https://moveroo.com.au/services/",
			name: "Moving & Transport Services Across Australia | Moveroo",
			description:
				"Comprehensive moving and transport services across Australia. Household removals, vehicle transport, and specialty freight coordinated by one trusted team.",
			dateModified: lastModified.toISOString(),
			author: {
				"@type": "Person",
				name: "Moveroo Editorial Team",
				url: "https://moveroo.com.au/",
			},
		},
		{
			"@type": "FAQPage",
			"@id": "https://moveroo.com.au/services/#faq",
			mainEntity: faqItems.map((faq) => ({
				"@type": "Question",
				name: faq.question,
				acceptedAnswer: {
					"@type": "Answer",
					text: faq.answer,
				},
			})),
		},
		{
			"@type": "HowTo",
			"@id": "https://moveroo.com.au/services/#howto",
			name: "How to plan your move with Moveroo",
			description: "A guided process from enquiry to delivery with Moveroo's moving services",
			step: howToSteps.map((step, index) => ({
				"@type": "HowToStep",
				position: index + 1,
				name: step.name,
				text: step.text,
			})),
		},
	],
};
---

<Layout
	title="Moving & Transport Services Across Australia | Moveroo"
	description="Comprehensive moving and transport services across Australia. Household removals, vehicle transport, and specialty freight coordinated by one trusted team."
	canonical="https://moveroo.com.au/services/"
>
	<Fragment slot="head">
		<meta property="article:modified_time" content={lastModified.toISOString()} />
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
	</Fragment>

	<section class="page-hero page-hero--brand">
		<div class="mx-auto max-w-4xl px-6 text-center">
			<p
				class="text-sm font-semibold uppercase tracking-[0.35em] text-emerald-700 dark:text-emerald-400"
			>
				Services
			</p>
			<h1 class="mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl">
				Comprehensive solutions for every move
			</h1>
			<p class="mt-6 text-lg text-slate-600 dark:text-slate-300">
				Moveroo coordinates trusted carriers, removalists and logistics specialists across
				Australia. Whether you’re relocating a family home, moving vehicles, or need a customised
				transport plan, we tailor the service mix, schedule and communications around your needs.
			</p>
			<p class="mt-4 text-sm text-slate-500 dark:text-slate-400">
				Published by{" "}
				<a
					href="https://moveroo.com.au/"
					class="font-semibold text-emerald-700 hover:text-emerald-800 dark:text-emerald-400 dark:hover:text-emerald-300"
				>
					Moveroo Editorial Team
				</a>
				{" "}on{" "}
				{
					lastModified.toLocaleDateString("en-AU", {
						year: "numeric",
						month: "long",
						day: "numeric",
					})
				}
			</p>
		</div>
	</section>

	<section class="bg-white py-24 dark:bg-slate-900">
		<div class="mx-auto max-w-6xl px-6">
			<div class="grid gap-8 md:grid-cols-3">
				<!-- Featured Card: Moving Cars -->
				<article
					class="relative overflow-hidden rounded-2xl bg-emerald-900 p-8 shadow-2xl shadow-emerald-900/20 dark:bg-emerald-950 dark:shadow-emerald-900/40 md:col-span-3 md:flex md:items-center md:gap-12 md:p-12"
				>
					<div
						class="absolute -right-20 -top-20 h-[400px] w-[400px] rounded-full bg-emerald-800/20 blur-3xl"
					>
					</div>
					<div
						class="absolute bottom-0 right-0 h-[300px] w-[300px] rounded-full bg-emerald-500/10 blur-3xl"
					>
					</div>

					<div class="relative flex-1 space-y-6">
						<div
							class="inline-flex items-center gap-2 rounded-full bg-emerald-800/50 px-3 py-1 text-xs font-medium text-emerald-200 ring-1 ring-inset ring-emerald-400/20"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								viewBox="0 0 20 20"
								fill="currentColor"
								class="h-4 w-4"
							>
								<path
									fill-rule="evenodd"
									d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z"
									clip-rule="evenodd"></path>
							</svg>
							New Integration
						</div>
						<h2 class="text-3xl font-bold text-white md:text-4xl">
							Moving Cars merges with Moveroo
						</h2>
						<p class="text-lg leading-relaxed text-emerald-100">
							Our vehicle transport partners now work under the Moveroo brand. We combine expert
							logistics with home moves so everything arrives together.
						</p>
						<ul class="space-y-3 text-emerald-100">
							<li class="flex items-start gap-3">
								<svg
									class="mt-1 h-5 w-5 flex-none text-emerald-400"
									viewBox="0 0 20 20"
									fill="currentColor"
									aria-hidden="true"
								>
									<path
										fill-rule="evenodd"
										d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z"
										clip-rule="evenodd"></path>
								</svg>
								<span
									>Unified booking for cars, motorcycles and household inventory across Australia.</span
								>
							</li>
							<li class="flex items-start gap-3">
								<svg
									class="mt-1 h-5 w-5 flex-none text-emerald-400"
									viewBox="0 0 20 20"
									fill="currentColor"
									aria-hidden="true"
								>
									<path
										fill-rule="evenodd"
										d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z"
										clip-rule="evenodd"></path>
								</svg>
								<span>Real-time updates with one coordination team managing every milestone.</span>
							</li>
						</ul>
						<div class="pt-4">
							<a
								class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-emerald-900 shadow-lg transition hover:bg-emerald-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
								href="/moving-cars/"
							>
								Learn about Moving Cars by Moveroo
							</a>
						</div>
					</div>
					<div class="hidden md:block md:w-1/3">
						<!-- Decorative Icon/Illustration area -->
						<svg class="h-full w-full text-emerald-800/40" viewBox="0 0 24 24" fill="currentColor">
							<path
								d="M19 13C19.5523 13 20 13.4477 20 14V16C20 16.5523 19.5523 17 19 17H5C4.44772 17 4 16.5523 4 16V14C4 13.4477 4.44772 13 5 13H19ZM18 2H6C4.34315 2 3 3.34315 3 5V11C3 11.5523 3.44772 12 4 12H20C20.5523 12 21 11.5523 21 11V5C21 3.34315 19.6569 2 18 2ZM7 15.5C7 15.7761 6.77614 16 6.5 16C6.22386 16 6 15.7761 6 15.5C6 15.2239 6.22386 15 6.5 15C6.77614 15 7 15.2239 7 15.5ZM18 15.5C18 15.7761 17.7761 16 17.5 16C17.2239 16 17 15.7761 17 15.5C17 15.2239 17.2239 15 17.5 15C17.7761 15 18 15.2239 18 15.5Z"
							></path>
						</svg>
					</div>
				</article>

				<!-- Service 1: Car & Bike -->
				<article
					class="flex flex-col gap-6 rounded-2xl border border-slate-200 bg-white p-8 shadow-lg shadow-slate-200/40 transition hover:shadow-xl hover:shadow-slate-200/60 dark:border-slate-800 dark:bg-slate-800/50 dark:shadow-black/20 dark:hover:border-slate-700"
				>
					<div
						class="flex h-12 w-12 items-center justify-center rounded-2xl bg-emerald-100 text-emerald-700 dark:bg-emerald-500/20 dark:text-emerald-400"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							viewBox="0 0 24 24"
							fill="currentColor"
							class="h-6 w-6"
						>
							<path
								d="M3.375 4.5C2.339 4.5 1.5 5.34 1.5 6.375V13.5h12V6.375c0-1.036-.84-1.875-1.875-1.875h-8.25zM13.5 15h-12v2.625c0 1.035.84 1.875 1.875 1.875h.375a3 3 0 116 0h3a.75.75 0 00.75-.75V15z"
							></path>
							<path
								d="M8.25 19.5a1.5 1.5 0 10-3 0 1.5 1.5 0 003 0zM15.75 6.75a.75.75 0 00-.75.75v11.25c0 .087.015.17.042.248a3 3 0 015.958.464c.853-.175 1.522-.935 1.464-1.821a.75.75 0 00-1.49.11 1.5 1.5 0 11-3 0c0-.966.784-1.75 1.75-1.75h.75V7.5a.75.75 0 00-.75-.75h-4.5z"
							></path>
						</svg>
					</div>
					<h2 class="text-xl font-bold text-slate-900 dark:text-white">
						What vehicle transport services do you offer?
					</h2>
					<p class="text-sm leading-relaxed text-slate-600 dark:text-slate-400">
						We transport vehicles from door to door. We handle cars, motorbikes, project builds and
						classic cars. We can move vehicles that run or don't run.
					</p>
					<ul class="space-y-3 text-sm text-slate-600 dark:text-slate-400">
						<li class="flex items-start gap-3">
							<span
								class="mt-1.5 h-1.5 w-1.5 rounded-full bg-emerald-500 dark:bg-emerald-400 flex-none"
							></span>
							<span>Nationwide carrier network</span>
						</li>
						<li class="flex items-start gap-3">
							<span
								class="mt-1.5 h-1.5 w-1.5 rounded-full bg-emerald-500 dark:bg-emerald-400 flex-none"
							></span>
							<span>Condition reporting & insurance</span>
						</li>
					</ul>
					<div class="mt-auto pt-4">
						<a
							class="inline-flex w-full items-center justify-center rounded-full border border-slate-200 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700 transition hover:border-emerald-500 hover:text-emerald-700 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-300 dark:hover:border-emerald-500 dark:hover:text-emerald-400"
							href="https://cars.moveroo.com.au"
							rel="noopener noreferrer"
							target="_blank"
						>
							Get a vehicle quote
						</a>
					</div>
				</article>

				<!-- Service 2: Furniture -->
				<article
					class="flex flex-col gap-6 rounded-2xl border border-slate-200 bg-white p-8 shadow-lg shadow-slate-200/40 transition hover:shadow-xl hover:shadow-slate-200/60 dark:border-slate-800 dark:bg-slate-800/50 dark:shadow-black/20 dark:hover:border-slate-700"
				>
					<div
						class="flex h-12 w-12 items-center justify-center rounded-2xl bg-emerald-100 text-emerald-700 dark:bg-emerald-500/20 dark:text-emerald-400"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							viewBox="0 0 24 24"
							fill="currentColor"
							class="h-6 w-6"
						>
							<path
								d="M19.006 3.705a.75.75 0 00-.512-1.41L6 6.838V3a.75.75 0 00-.75-.75h-1.5A.75.75 0 003 3v4.93l-1.006.365a.75.75 0 00.512 1.41l16.5-6z"
							></path>
							<path
								fill-rule="evenodd"
								d="M3.019 11.115L18 5.667V9.09l-14.981 5.447a.75.75 0 00.512 1.41l16.5-6a.75.75 0 00.512-1.41l-16.5-6a.75.75 0 00-.512 1.41l1.488.54V10.5a.75.75 0 00.512.615zM3 13.25a.75.75 0 01.75-.75h1.5a.75.75 0 01.75.75v6.75a.75.75 0 01-.75.75h-1.5a.75.75 0 01-.75-.75v-6.75z"
								clip-rule="evenodd"></path>
						</svg>
					</div>
					<h2 class="text-xl font-bold text-slate-900 dark:text-white">
						How do your furniture removal services work?
					</h2>
					<p class="text-sm leading-relaxed text-slate-600 dark:text-slate-400">
						We manage home moves from start to finish. Backloading routes help save money and offer
						flexible dates.
					</p>
					<ul class="space-y-3 text-sm text-slate-600 dark:text-slate-400">
						<li class="flex items-start gap-3">
							<span
								class="mt-1.5 h-1.5 w-1.5 rounded-full bg-emerald-500 dark:bg-emerald-400 flex-none"
							></span>
							<span>Experienced removalist crews</span>
						</li>
						<li class="flex items-start gap-3">
							<span
								class="mt-1.5 h-1.5 w-1.5 rounded-full bg-emerald-500 dark:bg-emerald-400 flex-none"
							></span>
							<span>Inventory planning & staging</span>
						</li>
					</ul>
					<div class="mt-auto pt-4">
						<a
							class="inline-flex w-full items-center justify-center rounded-full border border-slate-200 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700 transition hover:border-emerald-500 hover:text-emerald-700 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-300 dark:hover:border-emerald-500 dark:hover:text-emerald-400"
							href="https://removalists.moveroo.com.au/quote/household"
							rel="noopener noreferrer"
							target="_blank"
						>
							Get a furniture quote
						</a>
					</div>
				</article>

				<!-- Service 3: Specialty -->
				<article
					class="flex flex-col gap-6 rounded-2xl border border-slate-200 bg-white p-8 shadow-lg shadow-slate-200/40 transition hover:shadow-xl hover:shadow-slate-200/60 dark:border-slate-800 dark:bg-slate-800/50 dark:shadow-black/20 dark:hover:border-slate-700"
				>
					<div
						class="flex h-12 w-12 items-center justify-center rounded-2xl bg-emerald-100 text-emerald-700 dark:bg-emerald-500/20 dark:text-emerald-400"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							viewBox="0 0 24 24"
							fill="currentColor"
							class="h-6 w-6"
						>
							<path
								fill-rule="evenodd"
								d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zM12.75 6a.75.75 0 00-1.5 0v6c0 .414.336.75.75.75h4.5a.75.75 0 000-1.5h-3.75V6z"
								clip-rule="evenodd"></path>
						</svg>
					</div>
					<h2 class="text-xl font-bold text-slate-900 dark:text-white">
						What specialty transport options are available?
					</h2>
					<p class="text-sm leading-relaxed text-slate-600 dark:text-slate-400">
						We transport boats, caravans, trailers, industrial machinery and unique items. We handle
						special requirements and permits.
					</p>
					<ul class="space-y-3 text-sm text-slate-600 dark:text-slate-400">
						<li class="flex items-start gap-3">
							<span
								class="mt-1.5 h-1.5 w-1.5 rounded-full bg-emerald-500 dark:bg-emerald-400 flex-none"
							></span>
							<span>Specialist towing & float solutions</span>
						</li>
						<li class="flex items-start gap-3">
							<span
								class="mt-1.5 h-1.5 w-1.5 rounded-full bg-emerald-500 dark:bg-emerald-400 flex-none"
							></span>
							<span>Route planning & escorts</span>
						</li>
					</ul>
					<div class="mt-auto pt-4">
						<a
							class="inline-flex w-full items-center justify-center rounded-full border border-slate-200 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700 transition hover:border-emerald-500 hover:text-emerald-700 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-300 dark:hover:border-emerald-500 dark:hover:text-emerald-400"
							href="https://cars.moveroo.com.au/quote-types"
							rel="noopener noreferrer"
							target="_blank"
						>
							Get a specialty quote
						</a>
					</div>
				</article>
			</div>
		</div>
	</section>

	<section
		class="border-y border-slate-200 bg-emerald-50/60 py-24 dark:border-slate-800 dark:bg-emerald-900/10"
	>
		<div class="mx-auto max-w-6xl px-6">
			<div class="md:grid md:grid-cols-[1.25fr_1fr] md:items-center md:gap-16">
				<div>
					<h2 class="text-3xl font-semibold text-slate-900 dark:text-white">
						How does the Moveroo moving process work?
					</h2>
					<p class="mt-6 text-base leading-relaxed text-slate-600 dark:text-slate-400">
						Every move is different. We use our experience and local knowledge to create a plan that
						fits your schedule.
					</p>
				</div>
				<ol class="mt-10 space-y-6 text-sm text-slate-600 dark:text-slate-400 md:mt-0">
					<li
						class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-800/50"
					>
						<p
							class="text-xs font-semibold uppercase tracking-[0.35em] text-emerald-700 dark:text-emerald-400"
						>
							1. Discovery
						</p>
						<p class="mt-3 text-slate-700 dark:text-slate-300">
							Our coordinators gather timelines, inventory, access requirements and any special
							handling instructions.
						</p>
					</li>
					<li
						class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-800/50"
					>
						<p
							class="text-xs font-semibold uppercase tracking-[0.35em] text-emerald-700 dark:text-emerald-400"
						>
							2. Tailored plan
						</p>
						<p class="mt-3 text-slate-700 dark:text-slate-300">
							We find the right partners, vehicles and team members, then provide a clear quote and
							itinerary.
						</p>
					</li>
					<li
						class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-800/50"
					>
						<p
							class="text-xs font-semibold uppercase tracking-[0.35em] text-emerald-700 dark:text-emerald-400"
						>
							3. Managed delivery
						</p>
						<p class="mt-3 text-slate-700 dark:text-slate-300">
							We provide status updates at each milestone with proactive problem solving and
							post-move check-ins.
						</p>
					</li>
				</ol>
			</div>
		</div>
	</section>

	<section class="bg-white py-20 dark:bg-slate-900">
		<div
			class="mx-auto flex max-w-6xl flex-col gap-10 rounded-2xl border border-slate-200 bg-gradient-to-br from-slate-50 via-white to-slate-100 px-6 py-12 text-center shadow-xl shadow-slate-200/60 dark:border-slate-800 dark:from-slate-800/50 dark:via-slate-900 dark:to-slate-800 dark:shadow-black/40 md:flex-row md:items-center md:text-left"
		>
			<div class="flex-1">
				<h2 class="text-3xl font-semibold text-slate-900 dark:text-white">
					Ready to plan your move?
				</h2>
				<p class="mt-4 text-sm text-slate-600 dark:text-slate-400">
					Share the basics and we’ll align the right service mix, provide timelines and coordinate
					the next steps with you.
				</p>
			</div>
			<div class="flex flex-1 flex-col gap-4 md:items-end">
				<a
					class="inline-flex items-center justify-center rounded-full bg-emerald-700 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-emerald-700/30 transition hover:bg-emerald-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-800 dark:bg-emerald-600 dark:shadow-emerald-600/30 dark:hover:bg-emerald-500 dark:focus-visible:outline-emerald-500"
					href="/contact/#contact-form"
				>
					Request a callback
