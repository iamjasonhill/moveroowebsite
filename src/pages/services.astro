---
import Layout from "../layouts/Layout.astro";
import QuoteCta from "../components/sections/QuoteCta.astro";
import { site } from "../config/site";

const lastModified = new Date("2026-01-10T00:00:00.000Z");

const serviceTracks = [
	{
		id: "household",
		eyebrow: "01 Household moves",
		title: "Household moves first",
		description:
			"Moveroo's primary service lane is household move coordination: local, regional and interstate moves where inventory, access, timing and the right removalist pathway all matter.",
		bestFor: [
			"Apartments, homes and interstate relocations",
			"Moves where access, loading, inventory or timing need planning",
			"Jobs that may also need packing, storage or fragile-item support",
		],
		usuallyIncludes: [
			"Apartments, family homes and interstate relocations",
			"Backloading or dedicated move pathways",
			"Inventory planning, loading access, packing and timeline support",
		],
		notFor: "Single-vehicle-only bookings where no household inventory or moving crew is involved.",
		ctaLabel: "Explore household removals",
		href: "/household-removals/",
		external: false,
		analyticsLane: "household",
	},
	{
		id: "vehicles",
		eyebrow: "02 Vehicle transport",
		title: "Vehicle transport second",
		description:
			"Moveroo's vehicle transport lane is for cars, motorcycles and multi-vehicle work, with support for wider relocation planning when the vehicle is part of a bigger move.",
		bestFor: [
			"Cars, motorcycles and non-running vehicles",
			"Dealer, auction and relocation movements",
			"Moves where vehicles need to stay aligned with household timelines",
		],
		usuallyIncludes: [
			"Door-to-door transport for running and non-running vehicles",
			"Dealer, auction, relocation and fleet movement support",
			"Condition reporting, service notes and national carrier coordination",
		],
		notFor:
			"Full household removals with furniture, cartons and loading crews as the main requirement.",
		ctaLabel: "Request a vehicle quote",
		href: site.destinations.vehicleQuote,
		external: true,
		analyticsLane: "vehicle",
	},
	{
		id: "combined",
		eyebrow: "03 Combined relocation",
		title: "Household + vehicle together",
		description:
			"When a household move also includes vehicle transport, Moveroo can coordinate the pickup timing and support path across both services without promising one provider or same-day delivery.",
		bestFor: [
			"Household moves where a car or motorcycle also needs transport",
			"Moves where pickup timing needs to line up across two service types",
			"Customers who want one brief and clearer handoffs",
		],
		usuallyIncludes: [
			"Household quote first, with vehicle details included early",
			"Same-day pickup coordination where availability supports it",
			"Separate household and vehicle providers kept under one plan",
		],
		notFor:
			"Vehicle-only moves with no household goods, or moves where same-day delivery is required for both services.",
		ctaLabel: "Plan a combined move",
		href: "/household-vehicle-relocation/",
		external: false,
		analyticsLane: "combined",
	},
];

const jumpLinks = [
	{
		label: "Household",
		href: "#household",
		analyticsLane: "household",
	},
	{
		label: "Vehicles",
		href: "#vehicles",
		analyticsLane: "vehicle",
	},
	{
		label: "Combined",
		href: "#combined",
		analyticsLane: "combined",
	},
	{
		label: "Process",
		href: "#process",
	},
	{
		label: "FAQ",
		href: "#faq",
	},
];

const chooserNotes = [
	{
		label: "Start with the main moving job",
		text: "Choose the lane that best matches the main part of the move first. We can add the rest after that.",
	},
	{
		label: "Use household if people and furniture are involved",
		text: "If the move needs removalists, loading access, packing help or inventory planning, start with the household path.",
	},
	{
		label: "Use vehicles if the transport item is the vehicle itself",
		text: "If the main job is moving a car, motorcycle or fleet vehicle, the vehicle path is the clearer place to start.",
	},
	{
		label: "Use specialty when access or freight complexity is the real issue",
		text: "If storage, fragile handling or unusual equipment are driving the job, start with the closest household or vehicle lane and include the extra requirement in the first brief.",
	},
];

const faqItems = [
	{
		question: "What services does Moveroo offer?",
		answer:
			"Moveroo coordinates household moves first, vehicle transport second, and combined household plus vehicle relocations when both services need to be planned together. Extra needs such as packing, storage or fragile handling can be included where the provider fit supports them.",
	},
	{
		question: "How does the Moveroo moving process work?",
		answer:
			"Our process has three stages: Discovery, where we gather the route, timing and move details; Tailored plan, where we match the right partners and prepare the quote; and Managed delivery, where we keep the move on track with updates along the way.",
	},
	{
		question: "How much does moving cost?",
		answer:
			"Moving costs vary based on distance, volume and service type. We provide free quotes tailored to your route, timing and service mix, so the final price reflects the actual job rather than a generic estimate.",
	},
	{
		question: "How far in advance should I book?",
		answer:
			"We recommend booking 2-4 weeks in advance for best availability. Shorter timelines can often still be accommodated, especially when route flexibility or staged planning is possible.",
	},
	{
		question: "How are cover questions handled?",
		answer:
			"Cover details depend on the service mix and the partners matched to your job. We can share the available information before booking so you can review what applies to your move or vehicle transport.",
	},
	{
		question: "Can Moveroo coordinate a household move and vehicle pickup on the same day?",
		answer:
			"Moveroo can coordinate same-day pickup for the household move and vehicle transport when provider availability, route and access details support it. Same-day delivery for both services should not be assumed.",
	},
	{
		question: "What areas do you service?",
		answer:
			"We service all of Australia, including major cities and regional areas. Our partner network supports local, regional and interstate transport nationwide.",
	},
];

const howToSteps = [
	{
		name: "Discovery",
		text: "We gather the route, timing, inventory, access needs and any special handling requirements.",
	},
	{
		name: "Tailored plan",
		text: "We line up the right partners and service mix, then send a clear quote and plan.",
	},
	{
		name: "Managed delivery",
		text: "We keep the move on track with updates at each stage and support if anything changes.",
	},
];

const structuredData = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "CollectionPage",
			"@id": "https://moveroo.com.au/services/",
			url: "https://moveroo.com.au/services/",
			name: "Moving & Transport Services Across Australia | Moveroo",
			description:
				"Household moves, vehicle transport and combined household plus vehicle relocations coordinated across Australia by Moveroo.",
			dateModified: lastModified.toISOString(),
			isPartOf: {
				"@id": "https://moveroo.com.au/#website",
			},
			about: {
				"@id": "https://moveroo.com.au/services/#service-catalog",
			},
		},
		{
			"@type": "Service",
			"@id": "https://moveroo.com.au/services/#service-catalog",
			name: "Moving and transport services across Australia",
			serviceType: "Moving and transport coordination",
			provider: {
				"@id": "https://moveroo.com.au/#organization",
			},
			areaServed: {
				"@type": "Country",
				name: "Australia",
			},
			hasOfferCatalog: {
				"@type": "OfferCatalog",
				name: "Moveroo service tracks",
				itemListElement: serviceTracks.map((track) => ({
					"@type": "Offer",
					name: track.title,
					url: track.external ? track.href : `https://moveroo.com.au${track.href}`,
					itemOffered: {
						"@type": "Service",
						name: track.title,
						description: track.description,
					},
				})),
			},
		},
		{
			"@type": "FAQPage",
			"@id": "https://moveroo.com.au/services/#faq",
			mainEntity: faqItems.map((faq) => ({
				"@type": "Question",
				name: faq.question,
				acceptedAnswer: {
					"@type": "Answer",
					text: faq.answer,
				},
			})),
		},
		{
			"@type": "HowTo",
			"@id": "https://moveroo.com.au/services/#howto",
			name: "How to plan your move with Moveroo",
			description: "A guided process from enquiry to delivery with Moveroo's moving services",
			totalTime: "P1D",
			step: howToSteps.map((step, index) => ({
				"@type": "HowToStep",
				position: index + 1,
				name: step.name,
				text: step.text,
			})),
		},
	],
};
---

<Layout
	title="Moving & Transport Services Across Australia | Moveroo"
	description="Household moves, vehicle transport and combined household plus vehicle relocations coordinated across Australia by Moveroo."
	canonical="https://moveroo.com.au/services/"
	ogImage="https://moveroo.com.au/og-services.png"
>
	<Fragment slot="head">
		<meta property="article:modified_time" content={lastModified.toISOString()} />
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
	</Fragment>

	<section class="relative overflow-hidden bg-slate-950 py-24 text-white md:py-32">
		<div
			class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(16,185,129,0.26),_transparent_30%),linear-gradient(135deg,_#052e2b_0%,_#0f172a_46%,_#0f172a_100%)]"
		>
		</div>
		<div class="route-grid absolute inset-0 opacity-30"></div>
		<div
			class="motion-drift absolute right-[-10rem] top-[-8rem] h-[22rem] w-[22rem] rounded-full bg-emerald-300/10 blur-3xl"
		>
		</div>
		<div
			class="absolute bottom-[-10rem] left-[-10rem] h-[24rem] w-[24rem] rounded-full bg-emerald-500/10 blur-3xl"
		>
		</div>

		<div class="relative mx-auto max-w-6xl px-6">
			<div class="grid gap-14 lg:grid-cols-[minmax(0,1.04fr)_minmax(22rem,0.96fr)] lg:items-center">
				<div class="motion-rise">
					<p class="section-kicker">Services</p>
					<h1
						class="section-title mt-6 max-w-3xl text-5xl font-semibold leading-[0.95] text-balance md:text-7xl"
					>
						Choose the service path that fits your move.
					</h1>
					<p class="mt-7 max-w-2xl text-lg leading-relaxed text-slate-300 md:text-xl">
						Start with the lane that best matches the main job: household moves first, vehicle
						transport second, or a combined household and vehicle plan when both need to move.
					</p>

					<div class="motion-rise motion-rise-delay-1 mt-10 flex flex-wrap gap-4">
						<a
							class="inline-flex items-center justify-center rounded-full bg-emerald-500 px-6 py-3 text-sm font-semibold text-slate-950 shadow-lg shadow-emerald-950/30 transition hover:bg-emerald-400 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-300"
							href="https://quotes.moveroo.com.au/quote/household"
							target="_blank"
							rel="noopener noreferrer"
						>
							Request a moving quote
						</a>
						<a
							class="inline-flex items-center justify-center rounded-full border border-white/20 px-6 py-3 text-sm font-semibold text-white transition hover:border-emerald-300 hover:bg-white/5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-300"
							href={site.destinations.contactPage}
						>
							Request a callback
						</a>
					</div>

					<div class="motion-rise motion-rise-delay-2 mt-12 max-w-2xl">
						<p class="text-xs font-semibold uppercase tracking-[0.26em] text-slate-400">
							Best used for
						</p>
						<p class="mt-3 text-sm leading-relaxed text-slate-300 md:text-base">
							Interstate relocations, apartment and home moves, vehicle handoffs, storage links and
							jobs where you need a clear place to start.
						</p>
					</div>
				</div>

				<div class="motion-rise motion-rise-delay-2">
					<div
						class="overflow-hidden rounded-[2rem] border border-white/10 bg-white/6 shadow-[0_30px_80px_-40px_rgba(15,23,42,0.9)] backdrop-blur-sm"
					>
						<div class="border-b border-white/10 px-6 py-5 md:px-8">
							<div class="flex items-center justify-between gap-4">
								<div>
									<p class="section-kicker text-emerald-300">Quick routing guide</p>
									<p class="mt-2 text-sm text-slate-300">
										Choose the closest lane, then start with that quote path.
									</p>
								</div>
								<div class="text-right">
									<p class="text-xs uppercase tracking-[0.26em] text-slate-400">Routing</p>
									<p class="mt-1 text-lg font-semibold text-white">3 main lanes</p>
								</div>
							</div>
						</div>

						<div class="route-grid px-6 py-6 md:px-8 md:py-8">
							<div class="grid gap-5">
								{
									serviceTracks.map((track, index) => (
										<article class="grid gap-3 border-b border-white/10 pb-5 last:border-b-0 last:pb-0 lg:grid-cols-[8rem_1fr] lg:items-start">
											<div class="flex items-center gap-3 lg:block">
												<span class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-emerald-400/40 bg-emerald-400/10 text-sm font-semibold text-emerald-200">
													0{index + 1}
												</span>
												<p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400 lg:mt-3">
													{track.eyebrow.replace(/^\d+\s/, "")}
												</p>
											</div>
											<div class="lg:pt-1">
												<p class="text-base font-semibold leading-relaxed text-slate-100">
													{track.title}
												</p>
												<p class="mt-2 text-sm leading-relaxed text-slate-300">
													{track.bestFor[0]}
												</p>
											</div>
										</article>
									))
								}
							</div>
						</div>

						<div
							class="grid gap-6 border-t border-white/10 bg-slate-950/30 px-6 py-5 sm:grid-cols-2 md:px-8"
						>
							<div>
								<p class="text-xs uppercase tracking-[0.22em] text-slate-400">Coverage</p>
								<p class="mt-2 text-xl font-semibold text-white">Australia-wide</p>
							</div>
							<div>
								<p class="text-xs uppercase tracking-[0.22em] text-slate-400">Support model</p>
								<p class="mt-2 text-xl font-semibold text-white">One coordination team</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="border-b border-slate-200 bg-white py-8 dark:border-slate-800 dark:bg-slate-900">
		<div class="mx-auto max-w-6xl px-6">
			<nav class="motion-rise flex flex-wrap gap-3" aria-label="Service page sections">
				{
					jumpLinks.map((link) => (
						<a
							href={link.href}
							data-mm-event={link.analyticsLane ? "service_lane_click" : undefined}
							data-mm-lane={link.analyticsLane}
							data-mm-surface={link.analyticsLane ? "services_jump_nav" : undefined}
							class="inline-flex items-center justify-center rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-600 transition hover:border-emerald-300 hover:bg-emerald-50 hover:text-emerald-800 dark:border-slate-800 dark:bg-slate-950/50 dark:text-slate-300 dark:hover:border-emerald-500/40 dark:hover:bg-emerald-500/10 dark:hover:text-emerald-300"
						>
							{link.label}
						</a>
					))
				}
			</nav>
		</div>
	</section>

	<section class="border-b border-slate-200 bg-white py-24 dark:border-slate-800 dark:bg-slate-900">
		<div class="mx-auto max-w-6xl px-6">
			<div
				class="grid gap-12 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start lg:gap-16"
			>
				<div class="motion-rise lg:sticky lg:top-28">
					<p class="section-kicker">Service Tracks</p>
					<h2
						class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
					>
						Pick the lane that matches the main moving requirement.
					</h2>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
						If more than one lane applies, start with the one that best describes the main job. We
						can add the rest once the route is clear.
					</p>
					<div
						class="mt-8 rounded-[1.5rem] border border-emerald-200 bg-emerald-50 px-5 py-5 dark:border-emerald-500/30 dark:bg-emerald-500/10"
					>
						<p
							class="text-xs font-semibold uppercase tracking-[0.24em] text-emerald-700 dark:text-emerald-300"
						>
							Household + vehicle
						</p>
						<p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-300">
							If the home move also includes a car or motorcycle, use the combined move guide before
							choosing a quote path. Same-day pickup can often be coordinated; same-day delivery
							should not be assumed.
						</p>
						<a
							href="/household-vehicle-relocation/"
							data-mm-event="service_lane_click"
							data-mm-lane="combined"
							data-mm-surface="services_combined_callout"
							class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-emerald-700 transition hover:text-emerald-900 dark:text-emerald-300 dark:hover:text-emerald-200"
						>
							<span>Plan a combined move</span>
							<span aria-hidden="true">&rarr;</span>
						</a>
					</div>
					<a
						href="/how-moveroo-protects-your-move/"
						class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-emerald-700 transition hover:text-emerald-900 dark:text-emerald-400 dark:hover:text-emerald-300"
					>
						<span>Review the protection pathway</span>
						<span aria-hidden="true">→</span>
					</a>
				</div>

				<div class="motion-rise motion-rise-delay-1 grid gap-6">
					{
						serviceTracks.map((track) => (
							<article
								id={track.id}
								class="scroll-mt-32 overflow-hidden rounded-[2rem] border border-slate-200 bg-slate-50 shadow-[0_28px_80px_-48px_rgba(15,23,42,0.24)] dark:border-slate-800 dark:bg-slate-950/40 dark:shadow-black/40"
							>
								<div class="grid gap-6 px-6 py-7 md:px-8 md:py-8 lg:grid-cols-[8rem_1fr]">
									<p class="text-xs font-semibold uppercase tracking-[0.28em] text-emerald-700 dark:text-emerald-400">
										{track.eyebrow}
									</p>
									<div>
										<h3 class="text-3xl font-semibold tracking-tight text-slate-900 dark:text-white">
											{track.title}
										</h3>
										<p class="mt-5 max-w-2xl text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
											{track.description}
										</p>
										<div class="mt-8 grid gap-4 md:grid-cols-2">
											<div class="rounded-[1.5rem] border border-slate-200 bg-white px-5 py-5 dark:border-slate-800 dark:bg-slate-900/70">
												<p class="text-xs font-semibold uppercase tracking-[0.24em] text-emerald-700 dark:text-emerald-400">
													Best for
												</p>
												<ul class="mt-4 grid gap-3 text-sm text-slate-600 dark:text-slate-400">
													{track.bestFor.map((item) => (
														<li class="flex items-start gap-3">
															<span
																class="mt-1.5 h-2.5 w-2.5 rounded-full bg-emerald-500 dark:bg-emerald-400"
																aria-hidden="true"
															/>
															<span>{item}</span>
														</li>
													))}
												</ul>
											</div>
											<div class="rounded-[1.5rem] border border-slate-200 bg-white px-5 py-5 dark:border-slate-800 dark:bg-slate-900/70">
												<p class="text-xs font-semibold uppercase tracking-[0.24em] text-emerald-700 dark:text-emerald-400">
													Usually includes
												</p>
												<ul class="mt-4 grid gap-3 text-sm text-slate-600 dark:text-slate-400">
													{track.usuallyIncludes.map((item) => (
														<li class="flex items-start gap-3">
															<span
																class="mt-1.5 h-2.5 w-2.5 rounded-full bg-emerald-500 dark:bg-emerald-400"
																aria-hidden="true"
															/>
															<span>{item}</span>
														</li>
													))}
												</ul>
											</div>
										</div>
										<div class="mt-5 rounded-[1.5rem] border border-dashed border-slate-300 bg-white/70 px-5 py-4 dark:border-slate-700 dark:bg-slate-900/55">
											<p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500 dark:text-slate-400">
												Less suited for
											</p>
											<p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
												{track.notFor}
											</p>
										</div>
										<a
											class="mt-7 inline-flex items-center gap-2 text-sm font-semibold text-emerald-700 transition hover:text-emerald-900 dark:text-emerald-400 dark:hover:text-emerald-300"
											href={track.href}
											data-mm-event="service_lane_click"
											data-mm-lane={track.analyticsLane}
											data-mm-surface="services_track_cards"
											target={track.external ? "_blank" : undefined}
											rel={track.external ? "noopener noreferrer" : undefined}
										>
											<span>{track.ctaLabel}</span>
											<span aria-hidden="true">→</span>
										</a>
									</div>
								</div>
							</article>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<section class="bg-slate-50 py-24 dark:bg-slate-950/40" id="process">
		<div class="mx-auto max-w-6xl px-6">
			<div
				class="grid gap-12 rounded-[2rem] border border-slate-200 bg-white px-6 py-8 shadow-[0_28px_80px_-48px_rgba(15,23,42,0.28)] dark:border-slate-800 dark:bg-slate-900/75 md:px-8 md:py-10 xl:grid-cols-[minmax(0,0.84fr)_minmax(0,1.16fr)] xl:items-start"
			>
				<div class="motion-rise xl:sticky xl:top-28">
					<p class="section-kicker">After You Choose</p>
					<h2
						class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
					>
						The next steps stay simple, even when the move gets more complex.
					</h2>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
						Once you enter the right lane, we gather the move brief, match the right partners and
						keep the next steps clear.
					</p>
				</div>

				<div class="motion-rise motion-rise-delay-1 grid gap-6">
					{
						howToSteps.map((step, index) => (
							<article class="route-grid rounded-[1.75rem] border border-slate-200 bg-slate-50/80 px-6 py-6 dark:border-slate-800 dark:bg-slate-950/45">
								<div class="grid gap-4 md:grid-cols-[5rem_1fr] md:items-start">
									<p class="text-sm font-semibold uppercase tracking-[0.28em] text-emerald-700 dark:text-emerald-400">
										0{index + 1}
									</p>
									<div>
										<h3 class="text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">
											{step.name}
										</h3>
										<p class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
											{step.text}
										</p>
									</div>
								</div>
							</article>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<section class="border-y border-slate-200 bg-white py-24 dark:border-slate-800 dark:bg-slate-900">
		<div class="mx-auto max-w-6xl px-6">
			<div
				class="grid gap-12 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)] lg:items-start lg:gap-16"
			>
				<div class="motion-rise">
					<p class="section-kicker">Chooser Notes</p>
					<h2
						class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
					>
						Use these rules if the right lane is not obvious at first glance.
					</h2>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
						The goal is to make the first decision easier, not make the move feel more complicated.
					</p>
				</div>

				<div
					class="motion-rise motion-rise-delay-1 overflow-hidden rounded-[2rem] border border-slate-200 bg-slate-50 shadow-[0_28px_80px_-48px_rgba(15,23,42,0.24)] dark:border-slate-800 dark:bg-slate-950/35 dark:shadow-black/40"
				>
					{
						chooserNotes.map((item) => (
							<article class="grid gap-4 border-b border-slate-200 px-6 py-7 last:border-b-0 dark:border-slate-800 md:grid-cols-[12rem_1fr] md:px-8">
								<p class="text-sm font-semibold uppercase tracking-[0.22em] text-emerald-700 dark:text-emerald-400">
									{item.label}
								</p>
								<p class="text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
									{item.text}
								</p>
							</article>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<section class="bg-slate-50 py-24 dark:bg-slate-900" id="faq">
		<div class="mx-auto max-w-6xl px-6">
			<div
				class="grid gap-12 lg:grid-cols-[minmax(0,0.82fr)_minmax(0,1.18fr)] lg:items-start lg:gap-16"
			>
				<div class="motion-rise lg:sticky lg:top-28">
					<p class="section-kicker">FAQ</p>
					<h2
						class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
					>
						Service routing and quote questions, answered up front.
					</h2>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
						If the move spans household goods, vehicles and specialty logistics, these are the
						questions people usually ask before booking.
					</p>

					<div class="page-panel page-panel-soft mt-8 p-6 md:p-7">
						<p
							class="text-xs font-semibold uppercase tracking-[0.24em] text-emerald-700 dark:text-emerald-400"
						>
							Need a tailored answer?
						</p>
						<p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
							Use the callback form if the job includes household goods, vehicle transport, storage
							or freight that needs to stay under one plan.
						</p>
						<a
							href={site.destinations.contactPage}
							class="mt-5 inline-flex items-center justify-center rounded-full border border-emerald-500 px-5 py-2.5 text-sm font-semibold text-emerald-700 transition hover:border-emerald-600 hover:bg-emerald-50 hover:text-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700 dark:border-emerald-500/50 dark:text-emerald-400 dark:hover:border-emerald-400 dark:hover:bg-emerald-500/10 dark:hover:text-emerald-300 dark:focus-visible:outline-emerald-400"
						>
							Request a callback
						</a>
					</div>
				</div>

				<div
					class="motion-rise motion-rise-delay-1 overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-[0_28px_80px_-48px_rgba(15,23,42,0.28)] dark:border-slate-800 dark:bg-slate-950/45 dark:shadow-black/40"
				>
					{
						faqItems.map((faq, index) => (
							<details
								class="group border-b border-slate-200 px-6 py-6 last:border-b-0 dark:border-slate-800 md:px-8"
								open={index === 0}
							>
								<summary class="flex cursor-pointer items-start justify-between gap-5 list-none">
									<div class="pr-2">
										<p class="text-xs font-semibold uppercase tracking-[0.24em] text-emerald-700 dark:text-emerald-400">
											0{index + 1}
										</p>
										<h3 class="mt-3 text-xl font-semibold tracking-tight text-slate-900 dark:text-white md:text-2xl">
											{faq.question}
										</h3>
									</div>
									<span class="mt-1 inline-flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full border border-slate-200 bg-slate-50 text-slate-600 transition group-open:rotate-180 group-open:border-emerald-200 group-open:bg-emerald-50 group-open:text-emerald-700 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300 dark:group-open:border-emerald-500/40 dark:group-open:bg-emerald-500/10 dark:group-open:text-emerald-300">
										<svg
											class="h-5 w-5"
											fill="none"
											viewBox="0 0 24 24"
											stroke="currentColor"
											stroke-width="2"
										>
											<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
										</svg>
									</span>
								</summary>
								<p class="mt-5 max-w-3xl text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
									{faq.answer}
								</p>
							</details>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<QuoteCta
		title="Ready to start with the household move?"
		subtitle="Share the main household move first, then include any vehicle, storage, packing or fragile-item details in the same brief."
		ctaPrimaryLabel="Start a household quote"
		ctaPrimaryHref="https://quotes.moveroo.com.au/quote/household"
		ctaSecondaryLabel="Request a callback"
		ctaSecondaryHref={site.destinations.contactPage}
	/>
</Layout>
