---
import Layout from "../layouts/Layout.astro";
import QuoteCta from "../components/sections/QuoteCta.astro";
import Hero from "../components/sections/Hero.astro";
import Features from "../components/sections/Features.astro";
import Pricing from "../components/sections/Pricing.astro";
import Testimonials from "../components/sections/Testimonials.astro";
import FAQ from "../components/sections/FAQ.astro";

const publishedAt = new Date("2024-01-22T03:43:43+10:00");

// FAQ data for schema markup
const faqItems = [
	{
		question: "How do I get a moving quote from Moveroo?",
		answer: "Simply visit our quote page and enter your move details including pickup and delivery locations, move date, and inventory size. We'll connect you with multiple verified removalists who will provide competitive quotes within 24 hours."
	},
	{
		question: "What areas does Moveroo service in Australia?",
		answer: "Moveroo services all major cities and regional areas across Australia, including Sydney, Melbourne, Brisbane, Perth, Adelaide, Hobart, Darwin, and Canberra. We handle both local moves and interstate relocations."
	},
	{
		question: "Are the removalists on Moveroo verified and insured?",
		answer: "Yes, all removalists on our platform are thoroughly vetted for reliability, professionalism, and proper insurance coverage. We only partner with licensed operators who meet our strict quality standards."
	},
	{
		question: "How much does it cost to move house in Australia?",
		answer: "Moving costs vary based on distance, volume of items, and additional services required. Local moves typically start from $300-$500, while interstate moves can range from $1,500 to $5,000+. Get a free quote for an accurate estimate tailored to your specific move."
	},
	{
		question: "Can Moveroo help with vehicle transport?",
		answer: "Absolutely! We offer comprehensive vehicle transport services across Australia. Whether you're moving interstate, buying a car from another city, or need enclosed transport for a classic vehicle, we connect you with trusted car carriers."
	},
	{
		question: "How far in advance should I book my move?",
		answer: "We recommend booking at least 2-4 weeks in advance for local moves and 4-6 weeks for interstate relocations. During peak periods (end of month, holidays), booking earlier ensures better availability and pricing."
	}
];
const buildTime = new Date();
const publishedIso = publishedAt.toISOString();
const updatedIso = buildTime.toISOString();
const structuredData = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "Organization",
			"@id": "https://moveroo.com.au/#organization",
			name: "Moveroo Australia",
			url: "https://moveroo.com.au/",
			logo: {
				"@type": "ImageObject",
				"@id": "https://moveroo.com.au/#logo",
				url: "https://moveroo.com.au/og-image.png",
				contentUrl: "https://moveroo.com.au/og-image.png",
				caption: "Moveroo Australia",
			},
			contactPoint: [
				{
					"@type": "ContactPoint",
					telephone: "+61 7 2143 2557",
					contactType: "customer support",
					areaServed: "AU",
					availableLanguage: "English",
				},
			],
			sameAs: [
				"https://twitter.com/MoverooAU",
			],
		},
		{
			"@type": "WebSite",
			"@id": "https://moveroo.com.au/#website",
			url: "https://moveroo.com.au/",
			name: "Moveroo Australia",
			description: "Trusted moving and vehicle transport services across Australia",
			publisher: {
				"@id": "https://moveroo.com.au/#organization",
			},
			inLanguage: "en-AU",
			potentialAction: {
				"@type": "SearchAction",
				target: "https://moveroo.com.au/?s={search_term_string}",
				"query-input": "required name=search_term_string",
			},
		},
		{
			"@type": "LocalBusiness",
			"@id": "https://moveroo.com.au/#localbusiness",
			name: "Moveroo Australia",
			image: "https://moveroo.com.au/og-image.png",
			url: "https://moveroo.com.au/",
			telephone: "+61 7 2143 2557",
			priceRange: "$$",
			address: {
				"@type": "PostalAddress",
				addressCountry: "AU",
			},
			geo: {
				"@type": "GeoCoordinates",
				latitude: -27.4698,
				longitude: 153.0251,
			},
			areaServed: {
				"@type": "Country",
				name: "Australia",
			},
			aggregateRating: {
				"@type": "AggregateRating",
				ratingValue: "4.8",
				reviewCount: "150",
				bestRating: "5",
				worstRating: "1",
			},
		},
		{
			"@type": "Service",
			"@id": "https://moveroo.com.au/#service",
			name: "Moving Services",
			serviceType: "Moving Services",
			provider: {
				"@id": "https://moveroo.com.au/#organization",
			},
			areaServed: {
				"@type": "Country",
				name: "Australia",
			},
			hasOfferCatalog: {
				"@type": "OfferCatalog",
				name: "Moving Services",
				itemListElement: [
					{
						"@type": "Offer",
						itemOffered: {
							"@type": "Service",
							name: "Household Removals",
							description: "Professional home moving services across Australia",
						},
					},
					{
						"@type": "Offer",
						itemOffered: {
							"@type": "Service",
							name: "Vehicle Transport",
							description: "Safe and reliable vehicle transport nationwide",
						},
					},
				],
			},
		},
		{
			"@type": "BreadcrumbList",
			"@id": "https://moveroo.com.au/#breadcrumb",
			itemListElement: [
				{
					"@type": "ListItem",
					position: 1,
					name: "Home",
					item: "https://moveroo.com.au/",
				},
			],
		},
		{
			"@type": "FAQPage",
			"@id": "https://moveroo.com.au/#faq",
			mainEntity: faqItems.map(faq => ({
				"@type": "Question",
				name: faq.question,
				acceptedAnswer: {
					"@type": "Answer",
					text: faq.answer,
				},
			})),
		},
	],
};
---

<Layout
	title="Moveroo | Trusted Moving & Transport Services Australia"
	description="Welcome to Moveroo, where we redefine the moving experience with dependable transport solutions for homes, vehicles and specialty freight across Australia."
	canonical="https://moveroo.com.au/"
	ogImage="https://moveroo.com.au/og-image.png"
	includeBaseSchema={false}
>
	<Fragment slot="head">
		<meta property="og:updated_time" content={updatedIso} />
		<meta property="article:published_time" content={publishedIso} />
		<meta property="article:modified_time" content={updatedIso} />
		<meta name="twitter:label1" content="Written by" />
		<meta name="twitter:data1" content="Moveroo Australia" />
		<meta name="twitter:label2" content="Time to read" />
		<meta name="twitter:data2" content="1 minute" />
		<script
			type="application/ld+json"
			set:html={JSON.stringify(structuredData)}
		/>
	</Fragment>
	<Hero />
	<Features />
	<Pricing />
	<Testimonials />
	<FAQ />
	<QuoteCta
		title="Ready to secure the right removalists?"
		subtitle="Share your move details and we’ll line up tailored quotes, dates and specialist services to suit your plans."
		ctaPrimaryLabel="Grab your free quote today"
		ctaPrimaryHref="https://removalists.moveroo.com.au/quote/household"
		ctaSecondaryLabel="Book your move"
		ctaSecondaryHref="https://removalists.moveroo.com.au/booking/create"
	/>
</Layout>
