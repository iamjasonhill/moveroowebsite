---
import Layout from "../layouts/Layout.astro";
import QuoteCta from "../components/sections/QuoteCta.astro";
import Hero from "../components/sections/Hero.astro";
import Features from "../components/sections/Features.astro";
import Pricing from "../components/sections/Pricing.astro";
import Testimonials from "../components/sections/Testimonials.astro";
import FAQ from "../components/sections/FAQ.astro";
import { faqs as homepageFaqs } from "../data/faqs";
import { site } from "../config/site";

const homepageTracks = [
	{
		eyebrow: "01 Household relocations",
		title: "Home moves planned around access, timing and inventory.",
		description:
			"From apartments and family homes to interstate relocations, Moveroo helps keep the quote path and planning clear from the start.",
		href: site.destinations.householdQuote,
		linkLabel: "Request a household quote",
	},
	{
		eyebrow: "02 Vehicle transport",
		title: "Vehicle transport handled with the same calm handoff.",
		description:
			"Use Moveroo when the move includes vehicle transport, dealership transfers, auction purchases or a single car heading interstate.",
		href: site.destinations.vehicleQuote,
		linkLabel: "Request a vehicle quote",
	},
	{
		eyebrow: "03 Added complexity",
		title: "Storage, specialist freight and fragile items kept in the same plan.",
		description:
			"When a move needs packing help, storage, bulky freight or careful handling, Moveroo keeps those extras in the same plan.",
		href: "/services/",
		linkLabel: "See supported services",
	},
];

const homepageFlow = [
	{
		step: "01",
		title: "Share the move brief once",
		description:
			"Tell us the route, timing, inventory and any extra requirements so we can match the right partners without repeated back-and-forth.",
	},
	{
		step: "02",
		title: "We line up the right transport mix",
		description:
			"Household crews, vehicle carriers, storage partners and special handling are lined up around one plan instead of separate jobs.",
	},
	{
		step: "03",
		title: "You get one clearer path to delivery",
		description:
			"From quote through booking and updates, Moveroo keeps the next step clear so the move feels planned instead of improvised.",
	},
];

const homepageSignals = [
	"Households and apartments",
	"Cars and motorcycles",
	"Regional and interstate routes",
	"Storage and specialty handling",
];

const publishedAt = new Date("2024-01-22T03:43:43+10:00");

const buildTime = new Date();
const publishedIso = publishedAt.toISOString();
const updatedIso = buildTime.toISOString();
const structuredData = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "Organization",
			"@id": "https://moveroo.com.au/#organization",
			name: "Moveroo Australia",
			url: "https://moveroo.com.au/",
			logo: {
				"@type": "ImageObject",
				"@id": "https://moveroo.com.au/#logo",
				url: "https://moveroo.com.au/og-image.png",
				contentUrl: "https://moveroo.com.au/og-image.png",
				caption: "Moveroo Australia",
			},
			contactPoint: [
				{
					"@type": "ContactPoint",
					telephone: "+61 7 2143 2557",
					contactType: "customer support",
					areaServed: "AU",
					availableLanguage: "English",
				},
			],
			sameAs: ["https://twitter.com/MoverooAU"],
		},
		{
			"@type": "WebSite",
			"@id": "https://moveroo.com.au/#website",
			url: "https://moveroo.com.au/",
			name: "Moveroo Australia",
			description: "Trusted moving and vehicle transport services across Australia",
			publisher: {
				"@id": "https://moveroo.com.au/#organization",
			},
			inLanguage: "en-AU",
		},
		{
			"@type": "WebPage",
			"@id": "https://moveroo.com.au/",
			url: "https://moveroo.com.au/",
			name: "Moveroo | Trusted Moving & Transport Services Australia",
			description:
				"Moveroo helps coordinate household moves, vehicle transport and specialty freight across Australia.",
			isPartOf: {
				"@id": "https://moveroo.com.au/#website",
			},
			about: {
				"@id": "https://moveroo.com.au/#organization",
			},
			inLanguage: "en-AU",
			datePublished: publishedIso,
			dateModified: updatedIso,
		},
		{
			"@type": "Service",
			"@id": "https://moveroo.com.au/#service",
			name: "Moving Services",
			serviceType: "Moving Services",
			provider: {
				"@id": "https://moveroo.com.au/#organization",
			},
			areaServed: {
				"@type": "Country",
				name: "Australia",
			},
			hasOfferCatalog: {
				"@type": "OfferCatalog",
				name: "Moving Services",
				itemListElement: [
					{
						"@type": "Offer",
						itemOffered: {
							"@type": "Service",
							name: "Household Removals",
							description: "Professional home moving services across Australia",
						},
					},
					{
						"@type": "Offer",
						itemOffered: {
							"@type": "Service",
							name: "Vehicle Transport",
							description: "Safe and reliable vehicle transport nationwide",
						},
					},
					{
						"@type": "Offer",
						itemOffered: {
							"@type": "Service",
							name: "Specialty Freight Coordination",
							description: "Support for storage, oversized freight and fragile items",
						},
					},
				],
			},
		},
		{
			"@type": "BreadcrumbList",
			"@id": "https://moveroo.com.au/#breadcrumb",
			itemListElement: [
				{
					"@type": "ListItem",
					position: 1,
					name: "Home",
					item: "https://moveroo.com.au/",
				},
			],
		},
		{
			"@type": "FAQPage",
			"@id": "https://moveroo.com.au/#faq",
			mainEntity: homepageFaqs.map((faq) => ({
				"@type": "Question",
				name: faq.question,
				acceptedAnswer: {
					"@type": "Answer",
					text: faq.answer,
				},
			})),
		},
	],
};
---

<Layout
	title="Moveroo | Trusted Moving & Transport Services Australia"
	description="Moveroo helps coordinate household moves, vehicle transport and specialty freight across Australia."
	canonical="https://moveroo.com.au/"
	ogImage="https://moveroo.com.au/og-home.png"
	includeBaseSchema={false}
>
	<Fragment slot="head">
		<meta property="og:updated_time" content={updatedIso} />
		<meta property="article:published_time" content={publishedIso} />
		<meta property="article:modified_time" content={updatedIso} />
		<meta name="twitter:label1" content="Written by" />
		<meta name="twitter:data1" content="Moveroo Australia" />
		<meta name="twitter:label2" content="Time to read" />
		<meta name="twitter:data2" content="1 minute" />
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
	</Fragment>
	<Hero />

	<section
		class="relative overflow-hidden border-b border-slate-200 bg-white py-24 dark:border-slate-800 dark:bg-slate-900"
	>
		<div
			class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-emerald-400/60 to-transparent"
			aria-hidden="true"
		>
		</div>
		<div
			class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(16,185,129,0.08),_transparent_34%)]"
			aria-hidden="true"
		>
		</div>
		<div class="relative mx-auto max-w-6xl px-6">
			<div class="grid gap-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start">
				<div class="motion-rise">
					<p class="section-kicker">What Moveroo Coordinates</p>
					<h2
						class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
					>
						Most Australian moves do not fit one neat category.
					</h2>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
						Real jobs often include a deadline, tricky access, a vehicle, storage or some other
						moving part. Moveroo works best when those details sit under one clear plan instead of
						being split across separate providers.
					</p>
					<a
						href="/how-moveroo-protects-your-move/"
						class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-emerald-700 transition hover:text-emerald-900 dark:text-emerald-400 dark:hover:text-emerald-300"
					>
						<span>See how Moveroo protects your move</span>
						<span aria-hidden="true">â†’</span>
					</a>
					<div class="mt-8 flex flex-wrap gap-3">
						{
							homepageSignals.map((signal) => (
								<span class="site-footer-signal text-sm font-semibold text-slate-700 dark:text-slate-300">
									{signal}
								</span>
							))
						}
					</div>
				</div>

				<div
					class="motion-rise motion-rise-delay-1 overflow-hidden rounded-[2rem] border border-slate-200 bg-slate-50 shadow-[0_28px_80px_-48px_rgba(15,23,42,0.22)] dark:border-slate-800 dark:bg-slate-950/35 dark:shadow-black/40"
				>
					{
						homepageTracks.map((track) => (
							<article class="grid gap-4 border-b border-slate-200 px-6 py-7 last:border-b-0 dark:border-slate-800 md:grid-cols-[8.25rem_1fr] md:px-8">
								<p class="text-xs font-semibold uppercase tracking-[0.24em] text-emerald-700 dark:text-emerald-400">
									{track.eyebrow}
								</p>
								<div>
									<h3 class="text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">
										{track.title}
									</h3>
									<p class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
										{track.description}
									</p>
									<a
										href={track.href}
										class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-emerald-700 transition hover:text-emerald-900 dark:text-emerald-400 dark:hover:text-emerald-300"
										target={track.href.startsWith("http") ? "_blank" : undefined}
										rel={track.href.startsWith("http") ? "noopener noreferrer" : undefined}
									>
										<span>{track.linkLabel}</span>
										<span aria-hidden="true">→</span>
									</a>
								</div>
							</article>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<Features />
	<Pricing />

	<section
		class="overflow-hidden border-y border-slate-200 bg-slate-50 py-24 dark:border-slate-800 dark:bg-slate-950/40"
	>
		<div class="mx-auto max-w-6xl px-6">
			<div
				class="grid gap-12 rounded-[2rem] border border-slate-200 bg-white px-6 py-8 shadow-[0_28px_80px_-48px_rgba(15,23,42,0.28)] dark:border-slate-800 dark:bg-slate-900/75 md:px-8 md:py-10 xl:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)] xl:items-start"
			>
				<div class="motion-rise xl:sticky xl:top-28">
					<p class="section-kicker">How Moveroo Works</p>
					<h2
						class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
					>
						A move runs better when each handoff is clear from the start.
					</h2>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
						The route, quote, service mix and support plan should line up clearly enough that you
						always know what happens next.
					</p>
				</div>

				<div class="motion-rise motion-rise-delay-1 grid gap-6">
					{
						homepageFlow.map((item) => (
							<article class="route-grid rounded-[1.75rem] border border-slate-200 bg-slate-50/80 px-6 py-6 dark:border-slate-800 dark:bg-slate-950/45">
								<div class="grid gap-4 md:grid-cols-[5rem_1fr] md:items-start">
									<p class="text-sm font-semibold uppercase tracking-[0.28em] text-emerald-700 dark:text-emerald-400">
										{item.step}
									</p>
									<div>
										<h3 class="text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">
											{item.title}
										</h3>
										<p class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
											{item.description}
										</p>
									</div>
								</div>
							</article>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<Testimonials />
	<FAQ />
	<QuoteCta
		title="Ready to plan your move?"
		subtitle="Share your move details and we’ll line up the right quotes, dates and extra services for the job."
		ctaPrimaryLabel="Start your quote"
		ctaPrimaryHref="https://quotes.moveroo.com.au/quote/household"
		ctaSecondaryLabel="Request a callback"
		ctaSecondaryHref="https://quotes.moveroo.com.au/contact"
	/>
</Layout>
