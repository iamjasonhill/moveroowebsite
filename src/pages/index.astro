---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/sections/Hero.astro';
import Features from '../components/sections/Features.astro';
import Pricing from '../components/sections/Pricing.astro';
import Testimonials from '../components/sections/Testimonials.astro';
---

<Layout title="Moveroo | Trusted Local & Interstate Movers">
	<Hero />
	<Features />
	<Pricing />
	<Testimonials />
	<section class="bg-white py-20">
		<div class="mx-auto max-w-6xl px-6">
			<h2 class="text-2xl font-semibold text-slate-900">Coming next</h2>
			<ol class="mt-6 space-y-4 text-sm text-slate-600">
				<li>Prepare refreshed copy and imagery mapped to each Fortify-inspired section.</li>
				<li>Integrate enquiry forms and booking CTAs so visitors can request quotes immediately.</li>
				<li>Publish service detail pages aligned with legacy URLs to maintain SEO continuity.</li>
			</ol>
		</div>
	</section>
</Layout>
