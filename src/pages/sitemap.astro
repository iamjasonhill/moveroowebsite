---
import Layout from "../layouts/Layout.astro";
import { site } from "../config/site";

const groups = [
	{
		title: "Core pages",
		links: [
			{ href: "/", label: "Home" },
			{ href: "/services/", label: "Services" },
			{ href: "/household-removals/", label: "Household removals" },
			{ href: "/interstate-removalists/", label: "Interstate removalists" },
			{ href: "/removals-and-storage/", label: "Removals and storage" },
			{ href: "/backloading-removals/", label: "Backloading removals" },
			{
				href: "/household-vehicle-relocation/",
				label: "Combined household + vehicle relocation",
			},
			{ href: "/interstate-car-transport/", label: "Interstate car transport" },
			{
				href: "/door-to-door-vs-depot-car-transport/",
				label: "Door-to-door vs depot car transport",
			},
			{ href: "/non-running-car-transport/", label: "Non-running car transport" },
			{ href: "/moving-cars/", label: "Moving Cars" },
			{ href: "/how-moveroo-protects-your-move/", label: "How Moveroo protects your move" },
			{ href: "/providers/", label: "Become a Moveroo provider" },
		],
	},
	{
		title: "Provider pathways",
		links: [
			{ href: "/providers/", label: "Become a Moveroo provider" },
			{ href: site.destinations.providerApply, label: "Provider application" },
			{ href: site.destinations.providerPaymentTerms, label: "Provider payment terms" },
			{ href: site.destinations.providerLogin, label: "Provider login" },
		],
	},
	{
		title: "Quote pathways",
		links: [
			{ href: site.destinations.householdQuote, label: "Household moving quote" },
			{ href: site.destinations.vehicleQuote, label: "Vehicle transport quote" },
			{ href: site.destinations.contactPage, label: "Contact team" },
		],
	},
	{
		title: "Legal pages",
		links: [
			{ href: "/privacy-policy/", label: "Privacy policy" },
			{ href: "/terms-of-use/", label: "Terms of use" },
			{ href: "/terms-and-conditions-transport/", label: "Transport terms" },
			{ href: "/cancellation/", label: "Cancellation policy" },
		],
	},
];
---

<Layout
	title="HTML Sitemap | Moveroo"
	description="Human-readable sitemap for Moveroo covering the main service, quote, contact, and legal pages."
	canonical="https://moveroo.com.au/sitemap/"
>
	<section class="mx-auto max-w-6xl px-4 py-16 md:px-6">
		<p class="site-wordmark-kicker">HTML sitemap</p>
		<h1
			class="mt-4 text-4xl font-semibold tracking-[-0.05em] text-slate-900 dark:text-white md:text-6xl"
		>
			Moveroo sitemap
		</h1>
		<p class="mt-4 max-w-3xl text-lg leading-8 text-slate-600 dark:text-slate-400">
			A simple directory of the main Moveroo pages, quote destinations, and legal references.
		</p>
		<div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
			{
				groups.map((group) => (
					<section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-950/60">
						<h2 class="text-xl font-semibold text-slate-900 dark:text-white">{group.title}</h2>
						<ul class="mt-4 space-y-2 text-slate-700 dark:text-slate-300">
							{group.links.map((link) => (
								<li>
									<a class="site-footer-link" href={link.href}>
										{link.label}
									</a>
								</li>
							))}
						</ul>
					</section>
				))
			}
		</div>
	</section>
</Layout>
