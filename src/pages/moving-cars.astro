---
import Layout from "../layouts/Layout.astro";
import QuoteCta from "../components/sections/QuoteCta.astro";
import { site } from "../config/site";

const publishedAt = new Date("2024-10-01T03:00:00+10:00");
const updatedAt = new Date();

const transportSignals = [
	"Cars and motorcycles",
	"Running and non-running vehicles",
	"Dealer, auction and fleet moves",
	"Australia-wide carrier coordination",
];

const transportBenefits = [
	{
		eyebrow: "01 Vehicle-first planning",
		title: "Vehicle jobs start in a dedicated quote flow.",
		description:
			"If the main item being moved is a car, motorcycle or fleet vehicle, you start with the vehicle form instead of a general moving quote.",
	},
	{
		eyebrow: "02 Better coordination",
		title: "Extra services can be added around the same move.",
		description:
			"If the job also needs removalists, storage or freight, Moveroo can coordinate those around the vehicle booking.",
	},
	{
		eyebrow: "03 Clearer support",
		title: "One team keeps the plan clear.",
		description:
			"You get clearer handoffs between quoting, booking and delivery, without chasing separate providers for each part of the move.",
	},
];

const transportUseCases = [
	{
		label: "Private car transport",
		text: "For customers moving a car, motorcycle, classic, project vehicle or second family vehicle across Australia.",
	},
	{
		label: "Non-running vehicles",
		text: "Useful when the vehicle cannot be driven onto standard transport and the quote needs to account for loading requirements.",
	},
	{
		label: "Buying or selling remotely",
		text: "Helpful for auction, dealership and private-sale handoffs where timing and condition updates matter.",
	},
	{
		label: "Fleet or multi-vehicle work",
		text: "Supports business, dealership and project work where more than one vehicle needs moving at once.",
	},
	{
		label: "Complex move mix",
		text: "Best when the vehicle move is one part of a larger job involving freight, storage or household goods.",
	},
];

const quoteFactors = [
	{
		label: "Vehicle condition",
		text: "Whether the vehicle runs, rolls and steers affects the carrier options and loading requirements.",
	},
	{
		label: "Pickup and delivery access",
		text: "Street access, depot handoffs, regional distance and timing windows all shape what is realistic.",
	},
	{
		label: "Vehicle type and dimensions",
		text: "Cars, motorcycles, classics, modified vehicles and fleet units can need different handling notes.",
	},
	{
		label: "Wider move requirements",
		text: "If household goods, storage or freight are involved too, include them early so Moveroo can coordinate the broader plan.",
	},
];

const faqItems = [
	{
		question: "What vehicle transport services can Moveroo help coordinate?",
		answer:
			"Moveroo can help coordinate car transport, motorcycle transport, non-running vehicle moves, auction or dealer handoffs, fleet or multi-vehicle work, and vehicle transport that forms part of a wider household move.",
	},
	{
		question: "What happened to Moving Cars?",
		answer:
			"Moving Cars is now part of Moveroo. The vehicle service continues under Moveroo, with one team handling vehicle transport and wider move support when needed.",
	},
	{
		question: "Why did Moving Cars merge with Moveroo?",
		answer:
			"The move brings vehicle transport into the wider Moveroo service map. If you need more than vehicle transport, you can now arrange it through one team instead of starting again with separate providers.",
	},
	{
		question: "What's in it for Moving Cars customers?",
		answer:
			"You still get specialist vehicle transport, now with simpler support if the move also includes storage, household items or other logistics.",
	},
	{
		question: "Will the booking experience change?",
		answer:
			"The quote request is still vehicle-first, but the wider Moveroo system gives you clearer updates, easier handoffs and one place to ask for extra support.",
	},
	{
		question: "What's next for Moving Cars customers?",
		answer:
			"Use the vehicle quote form for new jobs. If the move includes more than the vehicle, Moveroo can help coordinate the wider plan as well.",
	},
	{
		question: "What details should I include for a vehicle transport quote?",
		answer:
			"Include the pickup and delivery suburbs, preferred timing, vehicle make and model, whether it runs, access notes, and whether the transport is connected to a household move, storage handoff or freight job.",
	},
];

const structuredData = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "WebPage",
			"@id": "https://moveroo.com.au/moving-cars/",
			name: "Moving Cars Australia | Car Transport by Moveroo",
			description:
				"Move cars, motorcycles, non-running vehicles and fleet units across Australia with Moveroo's vehicle-first transport lane.",
			url: "https://moveroo.com.au/moving-cars/",
			inLanguage: "en-AU",
			isPartOf: {
				"@type": "WebSite",
				name: "Moveroo Australia",
				url: "https://moveroo.com.au/",
			},
			datePublished: publishedAt.toISOString(),
			dateModified: updatedAt.toISOString(),
			about: {
				"@id": "https://moveroo.com.au/moving-cars/#vehicle-service",
			},
		},
		{
			"@type": "Service",
			"@id": "https://moveroo.com.au/moving-cars/#vehicle-service",
			name: "Vehicle transport across Australia",
			serviceType: "Vehicle transport",
			description:
				"Vehicle-first transport support for cars, motorcycles, non-running vehicles, auction or dealer handoffs and multi-vehicle moves across Australia.",
			provider: {
				"@id": "https://moveroo.com.au/#organization",
			},
			areaServed: {
				"@type": "Country",
				name: "Australia",
			},
		},
		{
			"@type": "FAQPage",
			"@id": "https://moveroo.com.au/moving-cars/#faq",
			mainEntity: faqItems.map((faq) => ({
				"@type": "Question",
				name: faq.question,
				acceptedAnswer: {
					"@type": "Answer",
					text: faq.answer,
				},
			})),
		},
	],
};
---

<Layout
	title="Moving Cars Australia | Car Transport by Moveroo"
	description="Move cars, motorcycles, non-running vehicles and fleet units across Australia with Moveroo's vehicle-first transport lane."
	canonical="https://moveroo.com.au/moving-cars/"
	ogImage="https://moveroo.com.au/og-moving-cars.png"
>
	<Fragment slot="head">
		<meta property="og:updated_time" content={updatedAt.toISOString()} />
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
	</Fragment>

	<section class="relative overflow-hidden bg-slate-950 py-24 text-white md:py-32">
		<div
			class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(16,185,129,0.2),_transparent_28%),linear-gradient(135deg,_#041f1d_0%,_#0f172a_46%,_#111827_100%)]"
		>
		</div>
		<div class="route-grid absolute inset-0 opacity-20"></div>
		<div
			class="motion-drift absolute right-[-11rem] top-[-8rem] h-[24rem] w-[24rem] rounded-full bg-emerald-400/10 blur-3xl"
		>
		</div>
		<div
			class="absolute bottom-[-10rem] left-[-8rem] h-[20rem] w-[20rem] rounded-full bg-emerald-500/10 blur-3xl"
		>
		</div>

		<div class="relative mx-auto max-w-6xl px-6">
			<div class="grid gap-14 lg:grid-cols-[minmax(0,1.02fr)_minmax(22rem,0.98fr)] lg:items-center">
				<div class="motion-rise">
					<p class="section-kicker text-emerald-300">Moving Cars by Moveroo</p>
					<h1
						class="section-title mt-6 max-w-3xl text-5xl font-semibold leading-[0.95] text-balance md:text-7xl"
					>
						Move cars Australia-wide with Moveroo's dedicated transport lane.
					</h1>
					<p class="mt-7 max-w-2xl text-lg leading-relaxed text-slate-300 md:text-xl">
						If the main job is moving a car, motorcycle or multiple vehicles, start here for a
						vehicle-first quote. Moveroo can also coordinate non-running vehicles, auction or dealer
						handoffs, fleet work and vehicle transport that sits beside a household move.
					</p>
					<a
						href="/interstate-car-transport/"
						class="site-text-action mt-6 gap-2 text-sm font-semibold text-emerald-300 transition hover:text-emerald-200"
					>
						<span>Compare interstate car transport options</span>
						<span aria-hidden="true">&rarr;</span>
					</a>
					<a
						href="/how-moveroo-protects-your-move/"
						class="site-text-action mt-6 gap-2 text-sm font-semibold text-emerald-300 transition hover:text-emerald-200"
					>
						<span>See how support and escalation works</span>
						<span aria-hidden="true">→</span>
					</a>

					<div class="motion-rise motion-rise-delay-1 mt-10 flex flex-wrap gap-4">
						<a
							class="inline-flex items-center justify-center rounded-full bg-emerald-500 px-6 py-3 text-sm font-semibold text-slate-950 shadow-lg shadow-emerald-950/30 transition hover:bg-emerald-400 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-300"
							href={site.destinations.vehicleQuote}
							rel="noopener noreferrer"
							target="_blank"
						>
							Start a vehicle transport quote
						</a>
						<a
							class="inline-flex items-center justify-center rounded-full border border-white/20 px-6 py-3 text-sm font-semibold text-white transition hover:border-emerald-300 hover:bg-white/5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-300"
							href="/services/"
						>
							See the wider service map
						</a>
					</div>

					<div class="motion-rise motion-rise-delay-2 mt-12 flex flex-wrap gap-3">
						{
							transportSignals.map((signal) => (
								<span class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-medium uppercase tracking-[0.22em] text-slate-200">
									{signal}
								</span>
							))
						}
					</div>
				</div>

				<div class="motion-rise motion-rise-delay-2">
					<div
						class="overflow-hidden rounded-[2rem] border border-white/10 bg-white/6 shadow-[0_30px_80px_-40px_rgba(2,6,23,0.85)] backdrop-blur-sm"
					>
						<div class="border-b border-white/10 px-6 py-5 md:px-8">
							<div class="flex items-center justify-between gap-4">
								<div>
									<p class="section-kicker text-emerald-300">Transport lane</p>
									<p class="mt-2 text-sm text-slate-300">
										How vehicle jobs now fit inside the wider Moveroo service map.
									</p>
								</div>
								<div class="text-right">
									<p class="text-xs uppercase tracking-[0.26em] text-slate-400">Coverage</p>
									<p class="mt-1 text-lg font-semibold text-white">Australia-wide</p>
								</div>
							</div>
						</div>

						<div class="route-grid px-6 py-6 md:px-8 md:py-8">
							<div class="grid gap-5">
								{
									transportBenefits.map((item, index) => (
										<article class="grid gap-3 border-b border-white/10 pb-5 last:border-b-0 last:pb-0 lg:grid-cols-[8rem_1fr] lg:items-start">
											<div class="flex items-center gap-3 lg:block">
												<span class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-emerald-400/40 bg-emerald-400/10 text-sm font-semibold text-emerald-200">
													0{index + 1}
												</span>
												<p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400 lg:mt-3">
													{item.eyebrow.replace(/^\d+\s/, "")}
												</p>
											</div>
											<div class="lg:pt-1">
												<p class="text-base font-semibold leading-relaxed text-slate-100">
													{item.title}
												</p>
												<p class="mt-2 text-sm leading-relaxed text-slate-300">
													{item.description}
												</p>
											</div>
										</article>
									))
								}
							</div>
						</div>

						<div
							class="grid gap-6 border-t border-white/10 bg-slate-950/30 px-6 py-5 sm:grid-cols-2 md:px-8"
						>
							<div>
								<p class="text-xs uppercase tracking-[0.22em] text-slate-400">Best for</p>
								<p class="mt-2 text-xl font-semibold text-white">Dedicated vehicle moves</p>
							</div>
							<div>
								<p class="text-xs uppercase tracking-[0.22em] text-slate-400">Also supports</p>
								<p class="mt-2 text-xl font-semibold text-white">Combined relocation planning</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="border-b border-slate-200 bg-white py-24 dark:border-slate-800 dark:bg-slate-900">
		<div class="mx-auto max-w-6xl px-6">
			<div
				class="grid gap-12 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)] lg:items-start lg:gap-16"
			>
				<div class="motion-rise">
					<p class="section-kicker">When To Use It</p>
					<h2
						class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
					>
						Start here when the vehicle is the main part of the move.
					</h2>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
						Use this quote form for car, motorcycle, non-running and multi-vehicle moves. If the job also
						includes household goods, storage or freight, include those details early so Moveroo can
						coordinate the wider plan.
					</p>
				</div>

				<div
					class="motion-rise motion-rise-delay-1 overflow-hidden rounded-[2rem] border border-slate-200 bg-slate-50 shadow-[0_28px_80px_-48px_rgba(15,23,42,0.24)] dark:border-slate-800 dark:bg-slate-950/35 dark:shadow-black/40"
				>
					{
						transportUseCases.map((item) => (
							<article class="grid gap-4 border-b border-slate-200 px-6 py-7 last:border-b-0 dark:border-slate-800 md:grid-cols-[12rem_1fr] md:px-8">
								<p class="text-sm font-semibold uppercase tracking-[0.22em] text-emerald-700 dark:text-emerald-400">
									{item.label}
								</p>
								<p class="text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
									{item.text}
								</p>
							</article>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<section class="border-b border-slate-200 bg-white py-24 dark:border-slate-800 dark:bg-slate-900">
		<div class="mx-auto max-w-6xl px-6">
			<div
				class="grid gap-12 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start lg:gap-16"
			>
				<div class="motion-rise lg:sticky lg:top-28">
					<p class="section-kicker">Quote Factors</p>
					<h2
						class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
					>
						The right vehicle quote starts with the details carriers need.
					</h2>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
						Vehicle transport changes quickly when the car does not run, access is tight or the
						vehicle needs to line up with a larger relocation.
					</p>
				</div>

				<div class="motion-rise motion-rise-delay-1 grid gap-5">
					{
						quoteFactors.map((item) => (
							<article class="rounded-[1.75rem] border border-slate-200 bg-slate-50 px-6 py-6 shadow-sm dark:border-slate-800 dark:bg-slate-950/40">
								<h3 class="text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">
									{item.label}
								</h3>
								<p class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
									{item.text}
								</p>
							</article>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<section class="bg-slate-50 py-24 dark:bg-slate-950/40">
		<div class="mx-auto max-w-6xl px-6">
			<div
				class="grid gap-12 rounded-[2rem] border border-slate-200 bg-white px-6 py-8 shadow-[0_28px_80px_-48px_rgba(15,23,42,0.28)] dark:border-slate-800 dark:bg-slate-900/75 md:px-8 md:py-10 xl:grid-cols-[minmax(0,0.84fr)_minmax(0,1.16fr)] xl:items-start"
			>
				<div class="motion-rise xl:sticky xl:top-28">
					<p class="section-kicker">What Changed</p>
					<h2
						class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
					>
						The vehicle service stays the same. The support around it is wider now.
					</h2>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
						You still start with a vehicle quote. The difference is that Moveroo can now coordinate
						extra services around the same move when needed.
					</p>
				</div>

				<div class="motion-rise motion-rise-delay-1 grid gap-6">
					<article
						class="route-grid rounded-[1.75rem] border border-slate-200 bg-slate-50/80 px-6 py-6 dark:border-slate-800 dark:bg-slate-950/45"
					>
						<div class="grid gap-4 md:grid-cols-[5rem_1fr] md:items-start">
							<p
								class="text-sm font-semibold uppercase tracking-[0.28em] text-emerald-700 dark:text-emerald-400"
							>
								01
							</p>
							<div>
								<h3 class="text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">
									Vehicle quotes still start in the right place
								</h3>
								<p
									class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base"
								>
									If you are moving a car, motorcycle or several vehicles, begin with the vehicle
									quote form rather than a household quote.
								</p>
							</div>
						</div>
					</article>

					<article
						class="route-grid rounded-[1.75rem] border border-slate-200 bg-slate-50/80 px-6 py-6 dark:border-slate-800 dark:bg-slate-950/45"
					>
						<div class="grid gap-4 md:grid-cols-[5rem_1fr] md:items-start">
							<p
								class="text-sm font-semibold uppercase tracking-[0.28em] text-emerald-700 dark:text-emerald-400"
							>
								02
							</p>
							<div>
								<h3 class="text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">
									The plan can grow without starting again
								</h3>
								<p
									class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base"
								>
									If the move later needs storage, removalists or freight, those services can be
									added around the same job.
								</p>
							</div>
						</div>
					</article>

					<article
						class="route-grid rounded-[1.75rem] border border-slate-200 bg-slate-50/80 px-6 py-6 dark:border-slate-800 dark:bg-slate-950/45"
					>
						<div class="grid gap-4 md:grid-cols-[5rem_1fr] md:items-start">
							<p
								class="text-sm font-semibold uppercase tracking-[0.28em] text-emerald-700 dark:text-emerald-400"
							>
								03
							</p>
							<div>
								<h3 class="text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">
									One team can keep the move in view
								</h3>
								<p
									class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base"
								>
									That means fewer handoffs, less repeated briefing and clearer updates when timing
									matters.
								</p>
							</div>
						</div>
					</article>
				</div>
			</div>
		</div>
	</section>

	<section class="bg-white py-24 dark:bg-slate-900" id="faq">
		<div class="mx-auto max-w-6xl px-6">
			<div
				class="grid gap-12 lg:grid-cols-[minmax(0,0.82fr)_minmax(0,1.18fr)] lg:items-start lg:gap-16"
			>
				<div class="motion-rise lg:sticky lg:top-28">
					<p class="section-kicker">FAQ</p>
					<h2
						class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
					>
						Common questions from Moving Cars customers.
					</h2>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
						If you know the Moving Cars brand already, these are the main questions about what
						changed and what stayed the same.
					</p>

					<div class="page-panel page-panel-soft mt-8 p-6 md:p-7">
						<p
							class="text-xs font-semibold uppercase tracking-[0.24em] text-emerald-700 dark:text-emerald-400"
						>
							Need a vehicle transport quote?
						</p>
						<p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
							Start with the dedicated vehicle form if the car or motorcycle is the main item being
							moved.
						</p>
						<a
							href={site.destinations.vehicleQuote}
							target="_blank"
							rel="noopener noreferrer"
							class="site-pill-action mt-5 inline-flex items-center justify-center rounded-full border border-emerald-500 px-5 py-2.5 text-sm font-semibold text-emerald-700 transition hover:border-emerald-600 hover:bg-emerald-50 hover:text-emerald-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-700 dark:border-emerald-500/50 dark:text-emerald-400 dark:hover:border-emerald-400 dark:hover:bg-emerald-500/10 dark:hover:text-emerald-300 dark:focus-visible:outline-emerald-400"
						>
							Start a vehicle quote
						</a>
					</div>
				</div>

				<div
					class="motion-rise motion-rise-delay-1 overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-[0_28px_80px_-48px_rgba(15,23,42,0.28)] dark:border-slate-800 dark:bg-slate-950/45 dark:shadow-black/40"
				>
					{
						faqItems.map((faq, index) => (
							<details
								class="group border-b border-slate-200 px-6 py-6 last:border-b-0 dark:border-slate-800 md:px-8"
								open={index === 0}
							>
								<summary class="flex cursor-pointer items-start justify-between gap-5 list-none">
									<div class="pr-2">
										<p class="text-xs font-semibold uppercase tracking-[0.24em] text-emerald-700 dark:text-emerald-400">
											0{index + 1}
										</p>
										<h3 class="mt-3 text-xl font-semibold tracking-tight text-slate-900 dark:text-white md:text-2xl">
											{faq.question}
										</h3>
									</div>
