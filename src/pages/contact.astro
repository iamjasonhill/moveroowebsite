---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Moveroo | Contact"
	description="Talk with Moveroo to plan your next relocation. Request a callback, book a consultation or reach our support team directly."
	canonical="https://moveroo.com.au/contact/"
>
	<section class="bg-gradient-to-br from-emerald-50 via-emerald-100 to-white py-24">
		<div class="mx-auto max-w-3xl px-6 text-center md:text-left">
			<p class="text-sm font-semibold uppercase tracking-[0.35em] text-emerald-600">Contact</p>
			<h1 class="mt-6 text-4xl font-semibold text-slate-900 md:text-5xl">Let’s organise the right team for your move</h1>
			<p class="mt-6 text-lg text-slate-600">
				Share your move details and we’ll connect you with carefully vetted removalists, vehicle carriers and storage partners suited to your schedule and budget.
			</p>
		</div>
	</section>

	<section class="bg-white py-20" id="contact-form">
		<div class="mx-auto grid max-w-6xl gap-12 px-6 md:grid-cols-[1.1fr_1fr]">
			<div class="space-y-8">
				<h2 class="text-2xl font-semibold text-slate-900">Request a callback</h2>
				<p class="text-base text-slate-600">
					Complete our Setmore booking form to choose a convenient time for a move specialist to call you back. We’ll confirm your brief, line up the right partners and supply tailored pricing options.
				</p>
				<a
					class="inline-flex w-full items-center justify-center rounded-full bg-emerald-700 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-emerald-700/30 transition hover:bg-emerald-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-800"
					href="https://moveroo.setmore.com/beta"
					rel="noopener"
					target="_blank"
				>
					Book a callback appointment
				</a>
				<div class="rounded-3xl border border-slate-200 bg-emerald-50/60 p-6 text-sm text-slate-600">
					<p class="font-semibold text-emerald-700">What to prepare</p>
					<ul class="mt-3 space-y-2">
						<li>Origin and destination, including access considerations.</li>
						<li>Move date preferences and any flexibility.</li>
						<li>Inventory notes (rooms, vehicles, bulky or fragile items).</li>
						<li>Additional services like packing, storage or express delivery.</li>
					</ul>
				</div>
			</div>
			<div class="space-y-8">
				<h2 class="text-2xl font-semibold text-slate-900">Other ways to reach us</h2>
				<div class="space-y-4 text-sm text-slate-600">
					<div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
						<p class="font-semibold text-slate-900">Call</p>
						<p class="mt-1">+61 7 2143 2557</p>
					</div>
					<div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
						<p class="font-semibold text-slate-900">Email</p>
						<p class="mt-1">
							<a class="text-emerald-600 hover:text-emerald-700" href="mailto:removals@moveroo.com.au">removals@moveroo.com.au</a>
						</p>
					</div>
					<div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
						<p class="font-semibold text-slate-900">Moving quote portal</p>
						<p class="mt-1 text-slate-600">Easily review your quote, confirm a booking, or update your details anytime.</p>
						<a class="mt-3 inline-flex w-full items-center justify-center rounded-full border border-emerald-200 px-5 py-2 text-sm font-semibold text-emerald-700 transition hover:border-emerald-300 hover:bg-emerald-50 hover:text-emerald-900" href="https://removalists.moveroo.com.au" rel="noopener" target="_blank">
							Visit portal
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>
