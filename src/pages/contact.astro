---
import Layout from "../layouts/Layout.astro";

const lastModified = new Date("2026-03-23T00:00:00.000Z");

const contactSignals = [
	"Callback booking",
	"Direct phone and email",
	"Household and vehicle routes",
	"One-business-day response target",
];

const contactLanes = [
	{
		eyebrow: "01 Callback booking",
		title: "Choose a time and let a coordinator call you back.",
		description:
			"Best when you want to talk through the route, timing, inventory and service mix before deciding on the right quote path.",
		ctaLabel: "Book a callback appointment",
		href: "https://moveroo.setmore.com/beta",
		external: true,
	},
	{
		eyebrow: "02 Direct contact",
		title: "Call or email the team when the request is urgent.",
		description:
			"Best when you already know what you need, want to confirm booking details, or need a faster support path than a scheduled callback.",
		ctaLabel: "Call +61 7 2143 2557",
		href: "tel:+61721432557",
		external: false,
	},
];

const preparationNotes = [
	"Pickup and delivery locations, including access notes",
	"Move timing, preferred dates and any flexibility",
	"Vehicles, rooms, bulky items or fragile inventory",
	"Storage, packing or specialist handling requirements",
];

const contactRoutes = [
	{
		label: "Household moves",
		text: "Use the callback or moving quote path when the job includes furniture, cartons, access planning or interstate relocation support.",
	},
	{
		label: "Vehicle transport",
		text: "Use the dedicated vehicle route when the car, motorcycle or fleet movement is the main item being moved.",
	},
	{
		label: "Combined move planning",
		text: "Talk to the team when the booking spans vehicles, household inventory, storage or specialist freight and needs one joined-up plan.",
	},
];

const nextSteps = [
	{
		step: "01",
		title: "We review the move brief",
		description:
			"A coordinator looks at the route, timing, access and inventory so we can point you toward the right service lane.",
	},
	{
		step: "02",
		title: "We match the right support path",
		description:
			"That might be a household quote, the vehicle transport route, or a combined plan if the move spans more than one category.",
	},
	{
		step: "03",
		title: "You get a clearer next step",
		description:
			"Expect a response within one business day, with direct guidance on what to book next and who will handle it.",
	},
];

const structuredData = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "ContactPage",
			"@id": "https://moveroo.com.au/contact/",
			url: "https://moveroo.com.au/contact/",
			name: "Contact Moveroo | Get Help Planning Your Australian Move",
			description:
				"Talk with Moveroo to plan your next relocation. Request a callback, book a consultation or reach our friendly support team directly by phone or email.",
			dateModified: lastModified.toISOString(),
			isPartOf: {
				"@id": "https://moveroo.com.au/#website",
			},
			about: {
				"@id": "https://moveroo.com.au/#organization",
			},
		},
		{
			"@type": "ContactPoint",
			"@id": "https://moveroo.com.au/contact/#primary-contact",
			telephone: "+61 7 2143 2557",
			email: "removals@moveroo.com.au",
			contactType: "customer support",
			areaServed: "AU",
			availableLanguage: "English",
		},
	],
};
---

<Layout
	title="Contact Moveroo | Get Help Planning Your Australian Move"
	description="Talk with Moveroo to plan your next relocation. Request a callback, book a consultation or reach our friendly support team directly by phone or email."
	canonical="https://moveroo.com.au/contact/"
	ogImage="https://moveroo.com.au/og-contact.png"
>
	<Fragment slot="head">
		<meta property="article:modified_time" content={lastModified.toISOString()} />
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
	</Fragment>

	<section class="relative overflow-hidden bg-slate-950 py-24 text-white md:py-32">
		<div
			class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(16,185,129,0.22),_transparent_28%),linear-gradient(135deg,_#052e2b_0%,_#0f172a_46%,_#111827_100%)]"
		>
		</div>
		<div class="route-grid absolute inset-0 opacity-20"></div>
		<div
			class="motion-drift absolute right-[-11rem] top-[-8rem] h-[24rem] w-[24rem] rounded-full bg-emerald-400/10 blur-3xl"
		>
		</div>
		<div
			class="absolute bottom-[-10rem] left-[-8rem] h-[20rem] w-[20rem] rounded-full bg-emerald-500/10 blur-3xl"
		>
		</div>

		<div class="relative mx-auto max-w-6xl px-6">
			<div class="grid gap-14 lg:grid-cols-[minmax(0,1.02fr)_minmax(22rem,0.98fr)] lg:items-center">
				<div class="motion-rise">
					<p class="section-kicker text-emerald-300">Contact</p>
					<h1
						class="section-title mt-6 max-w-3xl text-5xl font-semibold leading-[0.95] text-balance md:text-7xl"
					>
						Choose the fastest path into the right Moveroo move lane.
					</h1>
					<p class="mt-7 max-w-2xl text-lg leading-relaxed text-slate-300 md:text-xl">
						Use this page when you want a callback, need urgent booking support, or want help
						working out whether the next step should be a household quote, a vehicle transport quote
						or a combined plan.
					</p>

					<div class="motion-rise motion-rise-delay-1 mt-10 flex flex-wrap gap-4">
						<a
							class="inline-flex items-center justify-center rounded-full bg-emerald-500 px-6 py-3 text-sm font-semibold text-slate-950 shadow-lg shadow-emerald-950/30 transition hover:bg-emerald-400 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-300"
							href="https://moveroo.setmore.com/beta"
							target="_blank"
							rel="noopener noreferrer"
						>
							Book a callback
						</a>
						<a
							class="inline-flex items-center justify-center rounded-full border border-white/20 px-6 py-3 text-sm font-semibold text-white transition hover:border-emerald-300 hover:bg-white/5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-300"
							href="tel:+61721432557"
						>
							Call 07 2143 2557
						</a>
					</div>

					<div class="motion-rise motion-rise-delay-2 mt-12 flex flex-wrap gap-3">
						{
							contactSignals.map((signal) => (
								<span class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-medium uppercase tracking-[0.22em] text-slate-200">
									{signal}
								</span>
							))
						}
					</div>
				</div>

				<div class="motion-rise motion-rise-delay-2">
					<div
						class="overflow-hidden rounded-[2rem] border border-white/10 bg-white/6 shadow-[0_30px_80px_-40px_rgba(2,6,23,0.85)] backdrop-blur-sm"
					>
						<div class="border-b border-white/10 px-6 py-5 md:px-8">
							<div class="flex items-center justify-between gap-4">
								<div>
									<p class="section-kicker text-emerald-300">Contact routes</p>
									<p class="mt-2 text-sm text-slate-300">
										How to choose the best first step before you book.
									</p>
								</div>
								<div class="text-right">
									<p class="text-xs uppercase tracking-[0.26em] text-slate-400">Response</p>
									<p class="mt-1 text-lg font-semibold text-white">1 business day</p>
								</div>
							</div>
						</div>

						<div class="route-grid px-6 py-6 md:px-8 md:py-8">
							<div class="grid gap-5">
								{
									contactLanes.map((lane, index) => (
										<article class="grid gap-3 border-b border-white/10 pb-5 last:border-b-0 last:pb-0 lg:grid-cols-[8rem_1fr] lg:items-start">
											<div class="flex items-center gap-3 lg:block">
												<span class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-emerald-400/40 bg-emerald-400/10 text-sm font-semibold text-emerald-200">
													0{index + 1}
												</span>
												<p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400 lg:mt-3">
													{lane.eyebrow.replace(/^\d+\s/, "")}
												</p>
											</div>
											<div class="lg:pt-1">
												<p class="text-base font-semibold leading-relaxed text-slate-100">
													{lane.title}
												</p>
												<p class="mt-2 text-sm leading-relaxed text-slate-300">
													{lane.description}
												</p>
												<a
													class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-emerald-300 transition hover:text-emerald-200"
													href={lane.href}
													target={lane.external ? "_blank" : undefined}
													rel={lane.external ? "noopener noreferrer" : undefined}
												>
													<span>{lane.ctaLabel}</span>
													<span aria-hidden="true">→</span>
												</a>
											</div>
										</article>
									))
								}
							</div>
						</div>

						<div
							class="grid gap-6 border-t border-white/10 bg-slate-950/30 px-6 py-5 sm:grid-cols-2 md:px-8"
						>
							<div>
								<p class="text-xs uppercase tracking-[0.22em] text-slate-400">Email</p>
								<p class="mt-2 text-xl font-semibold text-white">removals@moveroo.com.au</p>
							</div>
							<div>
								<p class="text-xs uppercase tracking-[0.22em] text-slate-400">Coverage</p>
								<p class="mt-2 text-xl font-semibold text-white">Australia-wide support</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section
		class="border-b border-slate-200 bg-white py-24 dark:border-slate-800 dark:bg-slate-900"
		id="contact-form"
	>
		<div class="mx-auto max-w-6xl px-6">
			<div
				class="grid gap-12 lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)] lg:items-start lg:gap-16"
			>
				<div class="motion-rise">
					<p class="section-kicker">Before You Book</p>
					<h2
						class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
					>
						Bring the key move details so the first call does real work.
					</h2>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
						If you have these details ready, the coordinator can point you toward the right quote
						path much faster.
					</p>
				</div>

				<div
					class="motion-rise motion-rise-delay-1 overflow-hidden rounded-[2rem] border border-slate-200 bg-slate-50 shadow-[0_28px_80px_-48px_rgba(15,23,42,0.24)] dark:border-slate-800 dark:bg-slate-950/35 dark:shadow-black/40"
				>
					{
						preparationNotes.map((item) => (
							<article class="flex items-start gap-4 border-b border-slate-200 px-6 py-6 last:border-b-0 dark:border-slate-800 md:px-8">
								<span
									class="mt-1.5 h-2.5 w-2.5 rounded-full bg-emerald-500 dark:bg-emerald-400"
									aria-hidden="true"
								/>
								<p class="text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
									{item}
								</p>
							</article>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<section class="bg-slate-50 py-24 dark:bg-slate-950/40">
		<div class="mx-auto max-w-6xl px-6">
			<div
				class="grid gap-12 rounded-[2rem] border border-slate-200 bg-white px-6 py-8 shadow-[0_28px_80px_-48px_rgba(15,23,42,0.28)] dark:border-slate-800 dark:bg-slate-900/75 md:px-8 md:py-10 xl:grid-cols-[minmax(0,0.84fr)_minmax(0,1.16fr)] xl:items-start"
			>
				<div class="motion-rise xl:sticky xl:top-28">
					<p class="section-kicker">Route Guide</p>
					<h2
						class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
					>
						Use the contact team when the route is not obvious yet.
					</h2>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
						These are the most common paths people need help sorting out before they start booking.
					</p>
				</div>

				<div class="motion-rise motion-rise-delay-1 grid gap-6">
					{
						contactRoutes.map((item) => (
							<article class="route-grid rounded-[1.75rem] border border-slate-200 bg-slate-50/80 px-6 py-6 dark:border-slate-800 dark:bg-slate-950/45">
								<div class="grid gap-4 md:grid-cols-[12rem_1fr] md:items-start">
									<p class="text-sm font-semibold uppercase tracking-[0.22em] text-emerald-700 dark:text-emerald-400">
										{item.label}
									</p>
									<p class="text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
										{item.text}
									</p>
								</div>
							</article>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<section class="border-t border-slate-200 bg-white py-24 dark:border-slate-800 dark:bg-slate-900">
		<div class="mx-auto max-w-6xl px-6">
			<div
				class="grid gap-12 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start lg:gap-16"
			>
				<div class="motion-rise">
					<p class="section-kicker">After Contact</p>
					<h2
						class="section-title mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl"
					>
						What happens after you reach out.
					</h2>
					<p class="mt-6 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
						The goal is to remove uncertainty fast: understand the move, match the right lane, and
						tell you the clearest next step.
					</p>
				</div>

				<div class="motion-rise motion-rise-delay-1 grid gap-6">
					{
						nextSteps.map((item) => (
							<article class="overflow-hidden rounded-[2rem] border border-slate-200 bg-slate-50 shadow-[0_28px_80px_-48px_rgba(15,23,42,0.24)] dark:border-slate-800 dark:bg-slate-950/40 dark:shadow-black/40">
								<div class="grid gap-6 px-6 py-7 md:px-8 md:py-8 lg:grid-cols-[6rem_1fr]">
									<p class="text-sm font-semibold uppercase tracking-[0.28em] text-emerald-700 dark:text-emerald-400">
										{item.step}
									</p>
									<div>
										<h3 class="text-3xl font-semibold tracking-tight text-slate-900 dark:text-white">
											{item.title}
										</h3>
										<p class="mt-5 max-w-2xl text-sm leading-relaxed text-slate-600 dark:text-slate-400 md:text-base">
											{item.description}
										</p>
									</div>
								</div>
							</article>
						))
					}
				</div>
			</div>
		</div>
	</section>
</Layout>
