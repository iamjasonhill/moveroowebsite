---
import Layout from "../layouts/Layout.astro";
import { site } from "../config/site";

const title = "Contact Moveroo | Moving Support Australia";
const description =
	"Contact Moveroo for help coordinating household moves, vehicle transport and specialty freight across Australia.";
const canonical = "https://moveroo.com.au/contact/";

const contactOptions = [
	{
		label: "Request a callback",
		description: "Send your details through the secure workspace and a coordinator will follow up.",
		href: site.destinations.contactWorkspace,
		cta: "Request a callback",
		external: true,
	},
	{
		label: "Start a household quote",
		description: "Share your route, timing, inventory and access notes for a moving quote.",
		href: site.destinations.householdQuote,
		cta: "Start your quote",
		external: true,
	},
	{
		label: "Call the team",
		description: "Speak with Moveroo during business hours for move planning questions.",
		href: "tel:+61721432557",
		cta: "Call 07 2143 2557",
		external: false,
	},
];

const structuredData = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "ContactPage",
			"@id": `${canonical}#webpage`,
			url: canonical,
			name: title,
			description,
			isPartOf: {
				"@id": "https://moveroo.com.au/#website",
			},
			about: {
				"@id": "https://moveroo.com.au/#organization",
			},
			inLanguage: "en-AU",
		},
	],
};
---

<Layout title={title} description={description} canonical={canonical}>
	<Fragment slot="head">
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
	</Fragment>

	<section class="bg-slate-950 py-20 text-white md:py-28">
		<div class="mx-auto max-w-6xl px-6">
			<div class="max-w-3xl">
				<p class="section-kicker text-emerald-300">Moveroo contact</p>
				<h1 class="section-title mt-6 text-5xl font-semibold md:text-7xl">
					Talk to Moveroo about your move.
				</h1>
				<p class="mt-7 max-w-2xl text-lg leading-relaxed text-slate-300 md:text-xl">
					Use this page for callback requests, quote questions and coordination support for
					household moves, vehicle transport and specialty freight across Australia.
				</p>
			</div>
		</div>
	</section>

	<section class="bg-white py-20 dark:bg-slate-900">
		<div class="mx-auto grid max-w-6xl gap-8 px-6 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
			<div>
				<p class="section-kicker">Best next step</p>
				<h2 class="section-title mt-5 text-4xl font-semibold text-slate-900 dark:text-white">
					Send the move brief once, then let the team line up the right path.
				</h2>
				<p class="mt-5 text-base leading-relaxed text-slate-600 dark:text-slate-400">
					Include pickup and delivery suburbs, timing, access details, inventory notes and whether
					the move includes a vehicle, storage or specialist handling.
				</p>
				<div class="mt-8 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
					<p class="font-semibold text-slate-900 dark:text-white">Email</p>
					<a class="site-footer-link mt-1 inline-flex" href="mailto:removals@moveroo.com.au">
						removals@moveroo.com.au
					</a>
					<p class="mt-6 font-semibold text-slate-900 dark:text-white">Phone</p>
					<a class="site-footer-link mt-1 inline-flex" href="tel:+61721432557"> +61 7 2143 2557 </a>
					<p class="mt-6 font-semibold text-slate-900 dark:text-white">Response window</p>
					<p class="mt-1">Typically within one business day.</p>
				</div>
			</div>

			<div class="grid gap-5">
				{
					contactOptions.map((option) => (
						<article class="rounded-[1.5rem] border border-slate-200 bg-slate-50 p-6 dark:border-slate-800 dark:bg-slate-950/45">
							<h3 class="text-2xl font-semibold text-slate-900 dark:text-white">{option.label}</h3>
							<p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
								{option.description}
							</p>
							<a
								class="mt-5 inline-flex items-center justify-center rounded-full bg-emerald-600 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-emerald-500"
								href={option.href}
								target={option.external ? "_blank" : undefined}
								rel={option.external ? "noopener noreferrer" : undefined}
							>
								{option.cta}
							</a>
						</article>
					))
				}
			</div>
		</div>
	</section>
</Layout>
