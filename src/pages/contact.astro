---
import Layout from "../layouts/Layout.astro";

const lastModified = new Date("2026-01-10T00:00:00.000Z");

// FAQ data for schema markup
const faqItems = [
	{
		question: "How can I request a callback?",
		answer:
			"Complete our Setmore booking form to choose a convenient time for a move specialist to call you back. We'll confirm your brief, line up the right partners and supply tailored pricing options.",
	},
	{
		question: "What are other ways to reach us?",
		answer:
			"You can reach us by phone at +61 7 2143 2557, email at removals@moveroo.com.au, or through our moving quote portal. We respond within one business day.",
	},
	{
		question: "What happens after you contact us?",
		answer:
			"A dedicated move coordinator reviews your requirements and matches you with vetted partners from our nationwide network. Expect a response within one business day. For callback bookings, your coordinator will phone at your chosen time to discuss logistics, answer questions and provide transparent pricing.",
	},
];

const structuredData = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "WebPage",
			"@id": "https://moveroo.com.au/contact/",
			url: "https://moveroo.com.au/contact/",
			name: "Contact Moveroo | Get Help Planning Your Australian Move",
			description:
				"Talk with Moveroo to plan your next relocation. Request a callback, book a consultation or reach our friendly support team directly by phone or email.",
			dateModified: lastModified.toISOString(),
			author: {
				"@type": "Person",
				name: "Moveroo Editorial Team",
				url: "https://moveroo.com.au/",
			},
		},
		{
			"@type": "FAQPage",
			"@id": "https://moveroo.com.au/contact/#faq",
			mainEntity: faqItems.map((faq) => ({
				"@type": "Question",
				name: faq.question,
				acceptedAnswer: {
					"@type": "Answer",
					text: faq.answer,
				},
			})),
		},
	],
};
---

<Layout
	title="Contact Moveroo | Get Help Planning Your Australian Move"
	description="Talk with Moveroo to plan your next relocation. Request a callback, book a consultation or reach our friendly support team directly by phone or email."
	canonical="https://moveroo.com.au/contact/"
>
	<Fragment slot="head">
		<meta property="article:modified_time" content={lastModified.toISOString()} />
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
	</Fragment>

	<section class="page-hero page-hero--brand">
		<div class="mx-auto max-w-3xl px-6 text-center md:text-left">
			<p
				class="text-sm font-semibold uppercase tracking-[0.35em] text-emerald-700 dark:text-emerald-400"
			>
				Contact
			</p>
			<h1 class="mt-6 text-4xl font-semibold text-slate-900 dark:text-white md:text-5xl">
				Let's organise the right team for your move
			</h1>
			<p class="mt-6 text-lg text-slate-600 dark:text-slate-300">
				Share your move details and we’ll connect you with carefully vetted removalists, vehicle
				carriers and storage partners suited to your schedule and budget.
			</p>
		</div>
	</section>

	<section class="bg-white py-20 dark:bg-slate-900" id="contact-form">
		<div class="mx-auto grid max-w-6xl gap-12 px-6 md:grid-cols-[1.1fr_1fr]">
			<div class="space-y-8">
				<h2 class="text-2xl font-semibold text-slate-900 dark:text-white">
					How can I request a callback?
				</h2>
				<p class="text-base text-slate-600 dark:text-slate-400">
					Complete our Setmore booking form to choose a convenient time for a move specialist to
					call you back. We’ll confirm your brief, line up the right partners and supply tailored
					pricing options.
				</p>
				<a
					class="inline-flex w-full items-center justify-center rounded-full bg-emerald-700 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-emerald-700/30 transition hover:bg-emerald-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-800 dark:bg-emerald-600 dark:shadow-emerald-600/30 dark:hover:bg-emerald-500 dark:focus-visible:outline-emerald-500"
					href="https://moveroo.setmore.com/beta"
					rel="noopener noreferrer"
					target="_blank"
				>
					Book a callback appointment
				</a>
				<div
					class="rounded-2xl border border-slate-200 bg-emerald-50/60 p-6 text-sm text-slate-600 dark:border-slate-800 dark:bg-emerald-500/10 dark:text-slate-400"
				>
					<p class="font-semibold text-emerald-700 dark:text-emerald-400">What to prepare</p>
					<ul class="mt-3 space-y-2">
						<li>Origin and destination, including access considerations.</li>
						<li>Move date preferences and any flexibility.</li>
						<li>Inventory notes (rooms, vehicles, bulky or fragile items).</li>
						<li>Additional services like packing, storage or express delivery.</li>
					</ul>
				</div>
			</div>
			<div class="space-y-8">
				<h2 class="text-2xl font-semibold text-slate-900 dark:text-white">
					What are other ways to reach us?
				</h2>
				<div class="space-y-4 text-sm text-slate-600 dark:text-slate-400">
					<div
						class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-800/50"
					>
						<p class="font-semibold text-slate-900 dark:text-white">Call</p>
						<p class="mt-1 dark:text-slate-300">+61 7 2143 2557</p>
					</div>
					<div
						class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-800/50"
					>
						<p class="font-semibold text-slate-900 dark:text-white">Email</p>
						<p class="mt-1">
							<a
								class="text-emerald-600 hover:text-emerald-700 dark:text-emerald-400 dark:hover:text-emerald-300"
								href="mailto:removals@moveroo.com.au">removals@moveroo.com.au</a
							>
						</p>
					</div>
					<div
						class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-800/50"
					>
						<p class="font-semibold text-slate-900 dark:text-white">Moving quote portal</p>
						<p class="mt-1 text-slate-600 dark:text-slate-400">
							Easily review your quote, confirm a booking, or update your details anytime.
						</p>
						<a
							class="mt-3 inline-flex w-full items-center justify-center rounded-full border border-emerald-200 px-5 py-2 text-sm font-semibold text-emerald-700 transition hover:border-emerald-300 hover:bg-emerald-50 hover:text-emerald-900 dark:border-emerald-500/50 dark:text-emerald-400 dark:hover:border-emerald-400 dark:hover:bg-emerald-500/10 dark:hover:text-emerald-300"
							href="https://removalists.moveroo.com.au"
							rel="noopener noreferrer"
							target="_blank"
						>
							Visit portal
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section
		class="border-t border-slate-200 bg-slate-50 py-20 dark:border-slate-800 dark:bg-slate-800/30"
	>
		<div class="mx-auto max-w-3xl px-6">
			<h2 class="text-2xl font-semibold text-slate-900 dark:text-white">
				What happens after you contact us?
			</h2>
			<div class="mt-8 space-y-6 text-base text-slate-600 dark:text-slate-400">
				<p>
					Once you reach out, a dedicated move coordinator reviews your requirements and matches you
					with vetted partners from our nationwide network. We handle household relocations,
					interstate moves, vehicle transport and specialty freight across Australia.
				</p>
				<p>
					Expect a response within one business day. For callback bookings, your coordinator will
					phone at your chosen time to discuss logistics, answer questions and provide transparent
					pricing with no hidden fees.
				</p>
				<p>
					Whether you're moving a single vehicle or coordinating a full household relocation, our
					team streamlines the process so you can focus on settling into your new home. We pride
					ourselves on clear communication, reliable partners and support from first quote to final
					delivery.
				</p>
			</div>
			<div class="mt-10 grid gap-6 sm:grid-cols-3">
				<div class="text-center">
					<p class="text-3xl font-semibold text-emerald-600 dark:text-emerald-400">24hr</p>
					<p class="mt-1 text-sm text-slate-600 dark:text-slate-400">Response time</p>
				</div>
				<div class="text-center">
					<p class="text-3xl font-semibold text-emerald-600 dark:text-emerald-400">100+</p>
					<p class="mt-1 text-sm text-slate-600 dark:text-slate-400">Vetted partners</p>
				</div>
				<div class="text-center">
					<p class="text-3xl font-semibold text-emerald-600 dark:text-emerald-400">
						Australia-wide
					</p>
					<p class="mt-1 text-sm text-slate-600 dark:text-slate-400">Coverage</p>
				</div>
			</div>
		</div>
	</section>
</Layout>
