---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Moveroo | Transport Terms & Conditions">
	<section class="bg-slate-950 py-20">
		<div class="mx-auto max-w-3xl px-6">
			<h1 class="text-3xl font-semibold text-white">Transport Terms & Conditions</h1>
			<p class="mt-6 text-sm text-slate-300">
				Content from the original moveroo.com.au transport terms page will be migrated here. This placeholder confirms the route exists and prevents
				reference URLs from returning 404 responses while the new Astro build is under construction.
			</p>
			<p class="mt-4 text-sm text-slate-300">
				Refer to the archived export for full contractual wording until the refreshed copy is published.
			</p>
		</div>
	</section>
</Layout>
