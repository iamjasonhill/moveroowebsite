---
const title = "Moveroo Australia Agent/API";
const description =
	"Moveroo Australia publishes agent-readable discovery resources for customer-authorised household moving quotes, vehicle transport quotes, callbacks, and quote API documentation.";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={Astro.url.href} />
		<style>
			:root {
				color-scheme: light;
				font-family:
					Inter,
					ui-sans-serif,
					system-ui,
					-apple-system,
					BlinkMacSystemFont,
					"Segoe UI",
					sans-serif;
				color: #17202a;
				background: #f7f4ee;
			}
			body {
				margin: 0;
			}
			main {
				max-width: 920px;
				margin: 0 auto;
				padding: 48px 20px 64px;
			}
			h1 {
				font-size: clamp(2rem, 5vw, 3.75rem);
				line-height: 1;
				margin: 0 0 18px;
			}
			h2 {
				font-size: 1.25rem;
				margin: 34px 0 12px;
			}
			p,
			li {
				font-size: 1rem;
				line-height: 1.65;
			}
			a {
				color: #0b5cad;
				text-underline-offset: 3px;
			}
			code,
			pre {
				font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
			}
			pre {
				overflow-x: auto;
				background: #111827;
				color: #f9fafb;
				padding: 16px;
				border-radius: 8px;
			}
			.lede {
				font-size: 1.16rem;
				max-width: 760px;
			}
			.grid {
				display: grid;
				gap: 14px;
				grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
				margin-top: 18px;
			}
			.card {
				border: 1px solid #ddd4c7;
				border-radius: 8px;
				padding: 16px;
				background: #fffaf2;
			}
			.card h3 {
				margin: 0 0 8px;
				font-size: 1rem;
			}
		</style>
	</head>
	<body>
		<main>
			<h1>{title}</h1>
			<p class="lede">{description}</p>
			<h2>Supported Agent Actions</h2>
			<div class="grid">
				<section class="card">
					<h3>Household quote</h3><p>
						<a href="https://quotes.moveroo.com.au/quote/household">Open household quote flow</a>
					</p>
				</section>
				<section class="card">
					<h3>Vehicle quote</h3><p>
						<a href="https://quotes.moveroo.com.au/quote/vehicle">Open vehicle quote flow</a>
					</p>
				</section>
				<section class="card">
					<h3>Contact or callback</h3><p>
						<a href="https://quotes.moveroo.com.au/contact">Open contact page</a>
					</p>
				</section>
			</div>
			<h2>Machine-Readable Resources</h2>
			<ul>
				<li><a href="/llms.txt">LLM guidance</a></li>
				<li><a href="/.well-known/llms.txt">Well-known LLM guidance</a></li>
				<li><a href="/index.md">Markdown site summary</a></li>
				<li><a href="/.well-known/ai-catalog.json">Marketing site AI catalog</a></li>
				<li><a href="/.well-known/agent-skills/index.json">Agent skills index</a></li>
				<li><a href="/openapi.json">Quote OpenAPI alias</a></li>
				<li><a href="/quote-capability.json">Quote capability alias</a></li>
				<li><a href="/.well-known/ai-plugin.json">AI plugin compatibility alias</a></li>
			</ul>
			<h2>Canonical Quote Host</h2>
			<p>
				The quote API and operational contract are owned by <a href="https://quotes.moveroo.com.au/"
					>https://quotes.moveroo.com.au/</a
				>. Public submissions require customer consent and should use the official schemas exposed
				by the quote host.
			</p>
			<ul>
				<li><a href="https://quotes.moveroo.com.au/openapi.json">OpenAPI schema</a></li>
				<li>
					<a href="https://quotes.moveroo.com.au/quote-capability.json"
						>Quote capability manifest</a>
				</li>
				<li>
					<a href="https://quotes.moveroo.com.au/.well-known/ai-plugin.json"
						>AI plugin compatibility manifest</a>
				</li>
				<li><a href="https://quotes.moveroo.com.au/agents">Quote-host agent guide</a></li>
				<li><a href="https://quotes.moveroo.com.au/agents/examples">Quote-host examples</a></li>
			</ul>
		</main>
	</body>
</html>
