---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Moveroo | Privacy Policy">
	<section class="bg-slate-950 py-20">
		<div class="mx-auto max-w-3xl px-6">
			<h1 class="text-3xl font-semibold text-white">Privacy Policy</h1>
			<p class="mt-6 text-sm text-slate-300">
				This placeholder summarises the privacy commitments carried over from the original moveroo.com.au website. Updated policy copy will be published here after a legal and compliance review.
			</p>
			<p class="mt-4 text-sm text-slate-300">
				In the meantime, refer to the archived site export for historical details on data collection, storage and contact preferences.
			</p>
		</div>
	</section>
</Layout>
