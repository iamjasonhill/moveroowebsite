---
import Layout from "../layouts/Layout.astro";

const lastModified = new Date("2026-01-10T00:00:00.000Z");

// FAQ data for schema markup
const faqItems = [
	{
		question: "How does Moveroo protect my personal information?",
		answer:
			"Moveroo Australia is committed to safeguarding your privacy and managing personal information responsibly. We collect, use, store and protect your data in line with the Privacy Act 1988 (Cth). We take reasonable steps to keep information accurate, current and secure, and never sell your personal information.",
	},
	{
		question: "Can I access or correct my personal information held by Moveroo?",
		answer:
			"Yes, you may request access to personal information we hold about you by emailing removals@moveroo.com.au. If any details are inaccurate or incomplete, we will correct them promptly. We'll respond quickly and confirm once updates are complete.",
	},
];

const structuredData = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "WebPage",
			"@id": "https://moveroo.com.au/privacy-policy/",
			url: "https://moveroo.com.au/privacy-policy/",
			name: "Privacy Policy | How Moveroo Australia Protects Your Data",
			description:
				"Learn how Moveroo Australia protects your personal information and manages data responsibly in accordance with the Privacy Act 1988. Your privacy matters to us.",
			dateModified: lastModified.toISOString(),
		},
		{
			"@type": "FAQPage",
			"@id": "https://moveroo.com.au/privacy-policy/#faq",
			mainEntity: faqItems.map((faq) => ({
				"@type": "Question",
				name: faq.question,
				acceptedAnswer: {
					"@type": "Answer",
					text: faq.answer,
				},
			})),
		},
	],
};
---

<Layout
	title="Privacy Policy | How Moveroo Australia Protects Your Data"
	description="Learn how Moveroo Australia protects your personal information and manages data responsibly in accordance with the Privacy Act 1988. Your privacy matters to us."
	canonical="https://moveroo.com.au/privacy-policy/"
>
	<Fragment slot="head">
		<meta property="article:modified_time" content={lastModified.toISOString()} />
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
	</Fragment>

	<section class="page-hero page-hero--quiet">
		<div class="mx-auto max-w-3xl px-6">
			<p
				class="text-sm font-semibold uppercase tracking-[0.35em] text-emerald-700 dark:text-emerald-400"
			>
				Privacy Policy
			</p>
			<h1 class="mt-6 text-4xl font-semibold text-slate-900 dark:text-white">
				Protecting your personal information
			</h1>
			<p class="mt-6 text-base text-slate-600 dark:text-slate-400">
				Moveroo Australia is committed to safeguarding your privacy and managing your personal
				information responsibly. The policy below summarises how we collect, use, store and protect
				your data in line with the <em>Privacy Act 1988 (Cth)</em>.
			</p>
		</div>
	</section>

	<section class="bg-white py-20 dark:bg-slate-900">
		<div class="mx-auto max-w-3xl space-y-12 px-6 text-slate-600 dark:text-slate-400">
			<section class="space-y-4">
				<h2 class="text-2xl font-semibold text-slate-900 dark:text-white">
					What information do we collect?
				</h2>
				<p>
					We may request basic identifying details—such as your name, email address, phone number or
					postal address—when you submit enquiries, request quotes or participate in promotions. We
					do <strong>not</strong> seek sensitive information like your religious beliefs, health details,
					or criminal history.
				</p>
				<p>
					From time to time, we may run surveys or gather feedback to improve our services.
					Participation is optional.
				</p>
			</section>

			<section class="space-y-4">
				<h2 class="text-2xl font-semibold text-slate-900 dark:text-white">
					Cookies and website usage
				</h2>
				<p>
					Moveroo uses cookies to remember preferences and streamline your browsing experience.
					Cookies do not identify you personally but can make return visits more convenient. You can
					disable cookies in your browser settings; however, this may limit certain website
					features.
				</p>
			</section>

			<section class="space-y-4">
				<h2 class="text-2xl font-semibold text-slate-900 dark:text-white">
					Providing personal information
				</h2>
				<p>
					Sharing your personal information with us is voluntary. When you do, you consent to
					Moveroo collecting, storing and using it according to this policy. If you choose not to
					provide requested details, we may be unable to deliver the full benefits of offers,
					competitions or services.
				</p>
				<p>
					If you no longer wish to receive marketing communications, you can unsubscribe by clicking
					the link in the email or emailing
					<a
						class="text-emerald-600 hover:text-emerald-700 dark:text-emerald-400 dark:hover:text-emerald-300"
						href="mailto:removals@moveroo.com.au">removals@moveroo.com.au</a
					>. These requests are processed promptly.
				</p>
			</section>

			<section class="space-y-4">
				<h2 class="text-2xl font-semibold text-slate-900 dark:text-white">
					How do we use and disclose information?
				</h2>
				<p>
					Personal details you provide may include your full name, phone number, email address and
					service location. We also collect logistical information such as pickup & delivery
					addresses, vehicle details, access notes and scheduling preferences. Where relevant, we’ll
					ask for payment details or authorisations to complete the service.
				</p>
				<ul class="ml-6 list-disc space-y-2">
					<li>Support the functioning of the website or Moveroo business operations.</li>
					<li>Provide marketing or special offers you have opted to receive.</li>
					<li>Meet legal or regulatory obligations.</li>
					<li>Act with your express consent.</li>
				</ul>
				<p>We never sell your personal information.</p>
			</section>

			<section class="space-y-4">
				<h2 class="text-2xl font-semibold text-slate-900 dark:text-white">
					Security and retention
				</h2>
				<p>
					We take reasonable steps to keep your personal information accurate, current and secure.
					While no internet transmission can be guaranteed as risk-free, we actively monitor and
					protect the systems that store your data. When personal information is no longer required,
					we securely destroy or de-identify it unless the law requires us to retain it.
				</p>
			</section>

			<section class="space-y-4">
				<h2 class="text-2xl font-semibold text-slate-900 dark:text-white">
					Access and corrections
				</h2>
				<p>
					You may request access to the personal information we hold about you by emailing
					<a
						class="text-emerald-600 hover:text-emerald-700 dark:text-emerald-400 dark:hover:text-emerald-300"
						href="mailto:removals@moveroo.com.au">removals@moveroo.com.au</a
					>. If any details are inaccurate or incomplete, we will correct them promptly.
				</p>
				<p>
					If you need to correct or update your information, contact
					<a
						class="text-emerald-600 hover:text-emerald-700 dark:text-emerald-400 dark:hover:text-emerald-300"
						href="mailto:removals@moveroo.com.au">removals@moveroo.com.au</a
					>. We'll respond quickly and confirm once updates are complete.
				</p>
			</section>

			<section class="space-y-4">
				<h2 class="text-2xl font-semibold text-slate-900 dark:text-white">Unsubscribing</h2>
				<p>
					To opt out of promotional emails, send a message to
					<a
						class="text-emerald-600 hover:text-emerald-700 dark:text-emerald-400 dark:hover:text-emerald-300"
						href="mailto:removals@moveroo.com.au">removals@moveroo.com.au</a
					>
					with "UNSUBSCRIBE" in the subject line.
				</p>
			</section>

			<section class="space-y-4">
				<h2 class="text-2xl font-semibold text-slate-900 dark:text-white">
					Updates to this policy
				</h2>
				<p>
					We may update this policy to reflect operational changes or regulatory updates. When
					material changes occur, we’ll note the revision date on this page and communicate updates
					through relevant channels. 14 days before taking effect, where practical. Continuing to
					use the site after changes are published indicates acceptance of the updates.
				</p>
			</section>

			<section class="space-y-4">
				<h2 class="text-2xl font-semibold text-slate-900 dark:text-white">Contact</h2>
				<p>
					Questions about this Privacy Policy can be directed to <a
						class="text-emerald-600 hover:text-emerald-700 dark:text-emerald-400 dark:hover:text-emerald-300"
						href="mailto:removals@moveroo.com.au">removals@moveroo.com.au</a
					>.
				</p>
				<p class="mt-6 text-base text-slate-600 dark:text-slate-400">
					Moveroo collects personal information that helps us provide transport estimates,
					coordinate logistics, comply with legal obligations and deliver services. We only request
					what is necessary for your booking and we handle it in accordance with the <a
						class="text-emerald-600 hover:text-emerald-700 dark:text-emerald-400 dark:hover:text-emerald-300"
						href="https://www.legislation.gov.au/Details/C2020C00146"
						rel="noopener noreferrer"
						target="_blank">Privacy Act 1988 (Cth)</a
					>.
				</p>
				<p>
					To learn more about privacy rights in Australia, visit the
					<a
						class="text-emerald-600 hover:text-emerald-700 dark:text-emerald-400 dark:hover:text-emerald-300"
						href="https://www.oaic.gov.au"
						rel="noopener noreferrer"
						target="_blank">Office of the Australian Information Commissioner</a
					>.
				</p>
			</section>
		</div>
	</section>
</Layout>
