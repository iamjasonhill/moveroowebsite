{
	"trailingSlash": true,
	"redirects": [
		{
			"source": "/api/v1/agent/manifest",
			"destination": "/api/v1/agent/manifest/",
			"permanent": false
		},
		{
			"source": "/sitemap.xml",
			"destination": "/sitemap-index.xml",
			"permanent": true
		},
		{
			"source": "/contact/",
			"destination": "https://quotes.moveroo.com.au/contact",
			"permanent": true
		},
		{
			"source": "/contact-moveroo/",
			"destination": "https://quotes.moveroo.com.au/contact",
			"permanent": true
		},
		{
			"source": "/contact-au/",
			"destination": "https://quotes.moveroo.com.au/contact",
			"permanent": true
		},
		{
			"source": "/contact-page/",
			"destination": "https://quotes.moveroo.com.au/contact",
			"permanent": true
		},
		{
			"source": "/contact-us/",
			"destination": "https://quotes.moveroo.com.au/contact",
			"permanent": true
		},
		{
			"source": "/removalists-quote/",
			"destination": "https://quotes.moveroo.com.au/quote/household",
			"permanent": true
		},
		{
			"source": "/terms-and-conditions/",
			"destination": "/terms-and-conditions-transport/",
			"permanent": true
		},
		{
			"source": "/moveroo-customer-reviews/",
			"destination": "/",
			"permanent": true
		},
		{
			"source": "/:path*",
			"has": [
				{
					"type": "host",
					"value": "www.moveroo.com.au"
				}
			],
			"destination": "https://moveroo.com.au/:path*",
			"permanent": true
		},
		{
			"source": "/:path*",
			"has": [
				{
					"type": "host",
					"value": "moveroo.com.au"
				},
				{
					"type": "header",
					"key": "x-forwarded-proto",
					"value": "http"
				}
			],
			"destination": "https://moveroo.com.au/:path*",
			"permanent": true
		}
	],
	"headers": [
		{
			"source": "/_astro/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public,max-age=31536000,immutable"
				},
				{
					"key": "Access-Control-Allow-Origin",
					"value": "*"
				}
			]
		},
		{
			"source": "/fonts/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public,max-age=31536000,immutable"
				},
				{
					"key": "Access-Control-Allow-Origin",
					"value": "*"
				}
			]
		},
		{
			"source": "/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public,max-age=3600,must-revalidate"
				},
				{
					"key": "Strict-Transport-Security",
					"value": "max-age=31536000; includeSubDomains"
				},
				{
					"key": "X-Frame-Options",
					"value": "SAMEORIGIN"
				},
				{
					"key": "X-Content-Type-Options",
					"value": "nosniff"
				},
				{
					"key": "Referrer-Policy",
					"value": "strict-origin-when-cross-origin"
				},
				{
					"key": "Permissions-Policy",
					"value": "camera=(), microphone=(), geolocation=()"
				},
				{
					"key": "Content-Security-Policy",
					"value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://quotes.moveroo.com.au; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://www.google-analytics.com https://analytics.google.com https://*.google-analytics.com; frame-src https://quotes.moveroo.com.au; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; upgrade-insecure-requests;"
				}
			]
		}
	]
}
