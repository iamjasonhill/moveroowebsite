{
	"name": "moveroo-astro",
	"type": "module",
	"version": "0.0.1",
	"description": "Official website for Moveroo Australia - trusted moving and transport services nationwide",
	"author": "Moveroo Australia",
	"license": "UNLICENSED",
	"private": true,
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"check": "astro check",
		"check:contract": "node ./scripts/check-contract.mjs && node scripts/check-agent-discovery.mjs",
		"check:content": "node scripts/check-content-safety.mjs",
		"check:indexnow": "node scripts/check-indexnow.mjs",
		"check:seo": "node scripts/check-seo.mjs",
		"indexnow:prepare-key": "node scripts/indexnow-prepare-key.mjs",
		"indexnow:dry-run": "node ./scripts/indexnow-submit.mjs --dry-run",
		"indexnow:submit": "node ./scripts/indexnow-submit.mjs --live --force",
		"lint": "eslint . && astro check",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"seo:audit": "node scripts/seo-audit.mjs",
		"seo:page": "node scripts/seo-audit.mjs page",
		"seo:crawl": "node scripts/seo-audit.mjs crawl",
		"seo:status": "node scripts/seo-audit.mjs status",
		"seo:list": "node scripts/seo-audit.mjs list",
		"prepare": "husky",
		"check:agent-discovery": "node scripts/check-agent-discovery.mjs"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.6",
		"@astrojs/rss": "^4.0.18",
		"@astrojs/sitemap": "^3.6.0",
		"@astrojs/vercel": "^9.0.3",
		"@jdevalk/astro-seo-graph": "^1.4.1",
		"@jdevalk/seo-graph-core": "^0.6.2",
		"@sendgrid/mail": "^8.1.6",
		"@tailwindcss/vite": "^4.1.15",
		"astro": "^5.14.8",
		"dotenv": "^17.2.3",
		"tailwindcss": "^4.1.15",
		"typescript": "^5.9.3"
	},
	"devDependencies": {
		"@typescript-eslint/parser": "^8.52.0",
		"eslint": "^9.39.2",
		"eslint-plugin-astro": "^1.5.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"prettier": "^3.7.4",
		"prettier-plugin-astro": "^0.14.1"
	},
	"lint-staged": {
		"*.{js,mjs,ts}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.astro": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,md,css}": [
			"prettier --write"
		]
	}
}
